{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Web (Chrome)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "chrome"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome to localhost (run Flutter web first)",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
