<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="KaiFlow.Timesheets.Views.Shared.NavigationBackBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:KaiFlow.Timesheets.ViewModels.Base"
    x:DataType="base:BaseViewModel">

    <HorizontalStackLayout Padding="12,8,12,4" Spacing="10">
        <Button
            Text="← Back"
            Command="{Binding NavigateBackCommand}"
            Style="{StaticResource OutlinedButton}"
            FontSize="13"
            HeightRequest="40"
            Padding="14,6"
            MinimumWidthRequest="88" />
        <Button
            Text="Dashboard"
            Command="{Binding NavigateToDashboardCommand}"
            Style="{StaticResource SecondaryButton}"
            FontSize="13"
            HeightRequest="40"
            Padding="14,6"
            MinimumWidthRequest="110" />
    </HorizontalStackLayout>
</ContentView>
