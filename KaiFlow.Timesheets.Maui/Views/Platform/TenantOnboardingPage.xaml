<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Platform.TenantOnboardingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Platform"
    xmlns:kf="clr-namespace:KaiFlow.Timesheets.Controls"
    x:DataType="vm:TenantOnboardingViewModel"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="{Binding Title}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            <kf:SectionHeader Title="Welcome to KaiFlow" Subtitle="Let's set up your company" />
            <ProgressBar Progress="{Binding CompletionProgress}" ProgressColor="{StaticResource Primary}" />
            <Label Text="{Binding CompletionPercent, StringFormat='{0:F0}% complete'}" Style="{StaticResource Caption}" HorizontalOptions="Center" />

            <Border Padding="20" Stroke="{StaticResource Divider}" BackgroundColor="{StaticResource SurfaceCard}" StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="16">
                    <Label Text="{Binding CurrentStepTitle}" FontFamily="PoppinsBold" FontSize="20" TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Complete this step to continue. You can return to finish remaining steps later from Settings."
                           Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}" />
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Back" Command="{Binding GoBackCommand}" Style="{StaticResource SecondaryButton}" IsVisible="{Binding CanGoBack}" />
                        <Button Text="Mark complete" Command="{Binding CompleteCurrentStepCommand}" Style="{StaticResource PrimaryButton}" HorizontalOptions="FillAndExpand" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Skip for now" Command="{Binding SkipCommand}" Style="{StaticResource SecondaryButton}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
