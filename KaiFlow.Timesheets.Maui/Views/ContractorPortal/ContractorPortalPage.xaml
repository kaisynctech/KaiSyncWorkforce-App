<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.ContractorPortal.ContractorPortalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.ContractorPortal"
    xmlns:hrVm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:ContractorPortalViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sign out" Command="{Binding SignOutCommand}" />
    </ContentPage.ToolbarItems>

    <!-- Phase 2C: 7-tab workspace.
         Row 0 = compact identity header
         Row 1 = tab bar
         Row 2 = tab panels -->
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Compact header (always visible) ─────────────────────────────── -->
        <Frame Grid.Row="0" Style="{StaticResource CardFrame}" Padding="14,10" Margin="16,12,16,0">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                    <Label Text="Contractor portal" Style="{StaticResource Caption}" TextColor="{StaticResource Primary}" />
                    <Label Text="{Binding ContractorName}" Style="{StaticResource HeadlineSmall}" />
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="{Binding OnSiteBanner}"
                       FontFamily="PoppinsRegular" FontSize="11"
                       TextColor="{StaticResource Primary}"
                       HorizontalTextAlignment="End" VerticalOptions="Center"
                       MaxLines="2" LineBreakMode="WordWrap" />
            </Grid>
        </Frame>

        <!-- ── Tab bar ─────────────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="6" Padding="16,8,16,4">
                <Button Text="Home"
                        Command="{Binding ShowHomeTabCommand}"
                        BackgroundColor="{Binding IsHomeTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsHomeTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Information"
                        Command="{Binding ShowInformationTabCommand}"
                        BackgroundColor="{Binding IsInformationTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsInformationTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Compliance"
                        Command="{Binding ShowComplianceTabCommand}"
                        BackgroundColor="{Binding IsComplianceTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsComplianceTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Banking"
                        Command="{Binding ShowBankingTabCommand}"
                        BackgroundColor="{Binding IsBankingTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsBankingTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Team"
                        Command="{Binding ShowTeamTabCommand}"
                        BackgroundColor="{Binding IsTeamTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsTeamTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Jobs"
                        Command="{Binding ShowJobsTabCommand}"
                        BackgroundColor="{Binding IsJobsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsJobsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Payments"
                        Command="{Binding ShowPaymentsTabCommand}"
                        BackgroundColor="{Binding IsPaymentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsPaymentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Quotes"
                        Command="{Binding ShowQuotesTabCommand}"
                        BackgroundColor="{Binding IsQuotesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsQuotesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 0: HOME — Phase J contractor portal dashboard                 -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsHomeTab}">
            <VerticalStackLayout Padding="16,12,16,20" Spacing="14">

                <!-- ── Greeting ─────────────────────────────────────────── -->
                <VerticalStackLayout Spacing="2">
                    <Label Text="{Binding HomeGreeting}"
                           FontFamily="PoppinsRegular" FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                    <Label Text="{Binding ContractorName}"
                           FontFamily="PoppinsBold" FontSize="24"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding ContractorCode, StringFormat='Code: {0}'}"
                           FontFamily="PoppinsRegular" FontSize="11"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <!-- ── Alert: Payment hold ──────────────────────────────── -->
                <Frame IsVisible="{Binding HomeHasPaymentHold}"
                       BackgroundColor="#450A0A" BorderColor="#7F1D1D"
                       CornerRadius="10" Padding="14,10" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowInformationTabCommand}" />
                    </Frame.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠" FontSize="16" TextColor="#FCA5A5" VerticalOptions="Center" />
                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                            <Label Text="Payment hold is active"
                                   FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FCA5A5" />
                            <Label Text="Contact your manager to resolve. Tap for details."
                                   FontFamily="PoppinsRegular" FontSize="11" TextColor="#FCA5A5" Opacity="0.8" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- ── Alert: Compliance hold ───────────────────────────── -->
                <Frame IsVisible="{Binding HomeHasComplianceHold}"
                       BackgroundColor="#431407" BorderColor="#9A3412"
                       CornerRadius="10" Padding="14,10" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowComplianceTabCommand}" />
                    </Frame.GestureRecognizers>
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="⚠" FontSize="16" TextColor="#FDBA74" VerticalOptions="Center" />
                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                            <Label Text="Compliance hold is active"
                                   FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FDBA74" />
                            <Label Text="Upload outstanding documents to lift this hold. Tap to view."
                                   FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDBA74" Opacity="0.8" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- ── Alert: Compliance issues (no hold, but action needed) -->
                <Frame IsVisible="{Binding HomeHasComplianceAlert}"
                       BackgroundColor="#292012" BorderColor="#854D0E"
                       CornerRadius="10" Padding="14,10" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowComplianceTabCommand}" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="📋" FontSize="16" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                            <Label Text="{Binding HomeComplianceSummary}"
                                   FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FDE68A" />
                            <Label Text="Tap to view compliance documents."
                                   FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" Opacity="0.8" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="→"
                               FontFamily="PoppinsSemiBold" FontSize="16"
                               TextColor="#3B82F6" VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- ── Payment status KPIs ───────────────────────────────── -->
                <Label Text="PAYMENT STATUS"
                       FontFamily="PoppinsSemiBold" FontSize="11"
                       TextColor="{StaticResource TextSecondary}" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <!-- Pending -->
                    <Frame Grid.Column="0" BackgroundColor="#1C1505" BorderColor="#854D0E"
                           CornerRadius="10" Padding="12,10" HasShadow="False">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding HomePendingAmount}"
                                   FontFamily="PoppinsSemiBold" FontSize="15" TextColor="#FCD34D" />
                            <Label Text="Pending"
                                   FontFamily="PoppinsRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding HomePendingCount, StringFormat='{0} item(s)'}"
                                   FontFamily="PoppinsRegular" FontSize="10" TextColor="#FCD34D" />
                        </VerticalStackLayout>
                    </Frame>
                    <!-- Approved -->
                    <Frame Grid.Column="1" BackgroundColor="#0C1929" BorderColor="#1E40AF"
                           CornerRadius="10" Padding="12,10" HasShadow="False">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding HomeApprovedAmount}"
                                   FontFamily="PoppinsSemiBold" FontSize="15" TextColor="#60A5FA" />
                            <Label Text="Approved"
                                   FontFamily="PoppinsRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding HomeApprovedCount, StringFormat='{0} item(s)'}"
                                   FontFamily="PoppinsRegular" FontSize="10" TextColor="#60A5FA" />
                        </VerticalStackLayout>
                    </Frame>
                    <!-- Total received -->
                    <Frame Grid.Column="2" BackgroundColor="#052E16" BorderColor="#166534"
                           CornerRadius="10" Padding="12,10" HasShadow="False">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding HomeTotalPaid}"
                                   FontFamily="PoppinsSemiBold" FontSize="15" TextColor="#22C55E" />
                            <Label Text="Received"
                                   FontFamily="PoppinsRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding HomePaidCount, StringFormat='{0} settled'}"
                                   FontFamily="PoppinsRegular" FontSize="10" TextColor="#22C55E" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- ── Active jobs + compliance in one row ───────────────── -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Frame Grid.Column="0" Style="{StaticResource CardFrame}" Padding="14,12" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowJobsTabCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="JOBS" FontFamily="PoppinsSemiBold" FontSize="10"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding HomeActiveJobsDisplay}"
                                   FontFamily="PoppinsSemiBold" FontSize="14"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="Tap to view →" FontFamily="PoppinsRegular" FontSize="10"
                                   TextColor="{StaticResource Primary}" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" Style="{StaticResource CardFrame}" Padding="14,12" HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowComplianceTabCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="COMPLIANCE" FontFamily="PoppinsSemiBold" FontSize="10"
                                   TextColor="{StaticResource TextSecondary}" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding PortalScorePercent, StringFormat='{0}%'}"
                                       FontFamily="PoppinsBold" FontSize="20"
                                       TextColor="{Binding PortalScoreColor}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding HomeComplianceSummary}"
                                   FontFamily="PoppinsRegular" FontSize="10"
                                   TextColor="{StaticResource TextSecondary}"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- ── Recent payments ───────────────────────────────────── -->
                <Label Text="RECENT PAYMENTS"
                       FontFamily="PoppinsSemiBold" FontSize="11"
                       TextColor="{StaticResource TextSecondary}" />
                <CollectionView ItemsSource="{Binding HomeRecentPayouts}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No payment records yet."
                               Style="{StaticResource Caption}"
                               HorizontalOptions="Center" Margin="0,8" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ContractorPayout">
                            <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,8" Padding="14,10" HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="6" Padding="7,3"
                                           HasShadow="False" BorderColor="Transparent"
                                           BackgroundColor="{Binding StatusBadgeBg}"
                                           VerticalOptions="Center">
                                        <Label Text="{Binding FullStatusLabel}"
                                               FontFamily="PoppinsMedium" FontSize="9"
                                               TextColor="{Binding StatusBadgeFg}" />
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding JobDisplay}"
                                               FontFamily="PoppinsMedium" FontSize="12"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding BestDateDisplay}"
                                               FontFamily="PoppinsRegular" FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding NetDisplay}"
                                           FontFamily="PoppinsSemiBold" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="View all payments →"
                        Command="{Binding ShowPaymentsTabCommand}"
                        BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                        FontFamily="PoppinsMedium" FontSize="12"
                        BorderWidth="0" Padding="0" HorizontalOptions="Start" />

                <!-- ── Quick actions ─────────────────────────────────────── -->
                <Label Text="QUICK ACTIONS"
                       FontFamily="PoppinsSemiBold" FontSize="11"
                       TextColor="{StaticResource TextSecondary}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Button Grid.Row="0" Grid.Column="0"
                            Text="Submit Invoice"
                            Command="{Binding ShowJobsTabCommand}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            FontFamily="PoppinsMedium" FontSize="13"
                            CornerRadius="10" HeightRequest="46" BorderWidth="0" />
                    <Button Grid.Row="0" Grid.Column="1"
                            Text="Submit Quote"
                            Command="{Binding ShowQuotesTabCommand}"
                            BackgroundColor="#1E293B" TextColor="#94A3B8"
                            FontFamily="PoppinsMedium" FontSize="13"
                            CornerRadius="10" HeightRequest="46" BorderWidth="0" />
                    <Button Grid.Row="1" Grid.Column="0"
                            Text="Payments"
                            Command="{Binding ShowPaymentsTabCommand}"
                            BackgroundColor="#1E293B" TextColor="#94A3B8"
                            FontFamily="PoppinsMedium" FontSize="13"
                            CornerRadius="10" HeightRequest="46" BorderWidth="0" />
                    <Button Grid.Row="1" Grid.Column="1"
                            Text="Compliance Docs"
                            Command="{Binding ShowComplianceTabCommand}"
                            BackgroundColor="#1E293B" TextColor="#94A3B8"
                            FontFamily="PoppinsMedium" FontSize="13"
                            CornerRadius="10" HeightRequest="46" BorderWidth="0" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 1: INFORMATION — Phase 2C.2 contractor self-service profile    -->
        <!-- Sections: Company Profile · Tax & Identity · Contact · Status      -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsInformationTab}">
            <VerticalStackLayout Padding="16,0,16,20" Spacing="14">

                <!-- Profile not yet loaded: show loading notice -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding ProfileLoaded, Converter={StaticResource InverseBoolConverter}}">
                    <HorizontalStackLayout Spacing="10">
                        <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}"
                                           WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                        <Label Text="Loading profile…" FontFamily="PoppinsRegular" FontSize="13"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- Error banner (shown if save/load fails) -->
                <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                       BorderColor="#7F1D1D" BackgroundColor="#2D0A0A"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xE002;" FontFamily="MaterialIcons" FontSize="16"
                               TextColor="#FCA5A5" VerticalOptions="Center" />
                        <Label Text="{Binding ErrorMessage}"
                               FontFamily="PoppinsRegular" FontSize="12" TextColor="#FCA5A5"
                               LineBreakMode="WordWrap" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- ── Profile workspace ─────────────────────────────────────── -->
                <VerticalStackLayout Spacing="14"
                    IsVisible="{Binding ProfileLoaded}">

                    <!-- ── Action bar (Edit / Cancel / Save) ─────────────────── -->
                    <!-- WinUI: Button.Command is reliable; TapGestureRecognizer on Frame is not. -->
                    <Grid ColumnDefinitions="*,Auto">
                        <!-- Edit button (view mode only) -->
                        <Button Grid.Column="1" Text="Edit Profile"
                                Command="{Binding EditProfileCommand}"
                                IsVisible="{Binding IsViewingProfile}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="14,0" HeightRequest="36" BorderWidth="0" />
                        <!-- Cancel + Save (edit mode only) -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="8"
                                               IsVisible="{Binding IsEditingProfile}">
                            <Button Text="Cancel"
                                    Command="{Binding CancelProfileEditCommand}"
                                    BackgroundColor="#1E293B" TextColor="#94A3B8"
                                    FontFamily="PoppinsMedium" FontSize="12"
                                    CornerRadius="8" Padding="14,0" HeightRequest="36" BorderWidth="0" />
                            <Button Text="Save Profile"
                                    Command="{Binding SaveProfileCommand}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                    FontFamily="PoppinsSemiBold" FontSize="12"
                                    CornerRadius="8" Padding="14,0" HeightRequest="36" BorderWidth="0"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- ════════════════════════════════════════════════════════ -->
                    <!-- A. COMPANY PROFILE                                       -->
                    <!-- ════════════════════════════════════════════════════════ -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="COMPANY PROFILE" Style="{StaticResource LabelSection}" />

                            <!-- View mode ──────────────────────────────────── -->
                            <VerticalStackLayout Spacing="8"
                                IsVisible="{Binding IsViewingProfile}">
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Company Name"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EditProfileName}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Registration No." Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EditRegistrationNumber, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Edit mode ───────────────────────────────────── -->
                            <VerticalStackLayout Spacing="10"
                                IsVisible="{Binding IsEditingProfile}">
                                <Entry Placeholder="Company / trading name *"
                                       Text="{Binding EditProfileName, Mode=TwoWay}"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Placeholder="Registration number"
                                       Text="{Binding EditRegistrationNumber, Mode=TwoWay}"
                                       Style="{StaticResource DarkEntry}" />
                            </VerticalStackLayout>

                            <!-- Always read-only: codes + partner type ────── -->
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                            <Grid ColumnDefinitions="130,*">
                                <Label Grid.Column="0" Text="Company Code"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding CompanyCodeDisplay}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="130,*">
                                <Label Grid.Column="0" Text="Contractor Code" Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding ContractorCodeDisplay}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="130,*">
                                <Label Grid.Column="0" Text="Partner Type"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding ProfilePartnerKind}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- ════════════════════════════════════════════════════════ -->
                    <!-- B. TAX & IDENTITY                                        -->
                    <!-- ════════════════════════════════════════════════════════ -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="TAX &amp; IDENTITY" Style="{StaticResource LabelSection}" />

                            <!-- View mode ──────────────────────────────────── -->
                            <VerticalStackLayout Spacing="8"
                                IsVisible="{Binding IsViewingProfile}">
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Tax Number"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding ProfileTaxDisplay}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="VAT Status"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding ProfileVatStatus}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Edit mode ───────────────────────────────────── -->
                            <VerticalStackLayout Spacing="10"
                                IsVisible="{Binding IsEditingProfile}">
                                <Entry Placeholder="Tax number (SARS income tax ref.)"
                                       Text="{Binding EditTaxNumber, Mode=TwoWay}"
                                       Style="{StaticResource DarkEntry}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="VAT Registered" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                                    <Switch Grid.Column="1" IsToggled="{Binding EditIsVatRegistered, Mode=TwoWay}"
                                            OnColor="{StaticResource Primary}" />
                                </Grid>
                                <Entry Placeholder="VAT number"
                                       Text="{Binding EditVatNumber, Mode=TwoWay}"
                                       Style="{StaticResource DarkEntry}"
                                       IsEnabled="{Binding EditIsVatRegistered}" />
                                <!-- Informational note -->
                                <Frame CornerRadius="6" Padding="10,6" HasShadow="False"
                                       BorderColor="#334155" BackgroundColor="#0F172A">
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="14"
                                               TextColor="#64748B" VerticalOptions="Center" />
                                        <Label Text="Tax and VAT changes are recorded and may be reviewed by HR."
                                               FontFamily="PoppinsRegular" FontSize="11"
                                               TextColor="#64748B" LineBreakMode="WordWrap"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Frame>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- ════════════════════════════════════════════════════════ -->
                    <!-- C. CONTACT DETAILS                                       -->
                    <!-- ════════════════════════════════════════════════════════ -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="CONTACT DETAILS" Style="{StaticResource LabelSection}" />

                            <!-- View mode ──────────────────────────────────── -->
                            <VerticalStackLayout Spacing="8"
                                IsVisible="{Binding IsViewingProfile}">
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Contact Person" Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EditContactPerson, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Phone"         Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EditPhone, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Email"         Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EditEmail, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                <Grid ColumnDefinitions="130,*">
                                    <Label Grid.Column="0" Text="Address"       Style="{StaticResource Caption}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EditAddress, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" LineBreakMode="WordWrap" />
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Edit mode ───────────────────────────────────── -->
                            <VerticalStackLayout Spacing="10"
                                IsVisible="{Binding IsEditingProfile}">
                                <Entry Placeholder="Contact person"
                                       Text="{Binding EditContactPerson, Mode=TwoWay}"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Placeholder="Phone"
                                       Text="{Binding EditPhone, Mode=TwoWay}"
                                       Keyboard="Telephone" Style="{StaticResource DarkEntry}" />
                                <Entry Placeholder="Email"
                                       Text="{Binding EditEmail, Mode=TwoWay}"
                                       Keyboard="Email" Style="{StaticResource DarkEntry}" />
                                <Editor Placeholder="Address"
                                        Text="{Binding EditAddress, Mode=TwoWay}"
                                        AutoSize="TextChanges" MinimumHeightRequest="56"
                                        TextColor="{StaticResource TextPrimary}"
                                        PlaceholderColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- ════════════════════════════════════════════════════════ -->
                    <!-- D. ACCOUNT STATUS  (always read-only — HR managed)       -->
                    <!-- ════════════════════════════════════════════════════════ -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ACCOUNT STATUS" Style="{StaticResource LabelSection}" />

                            <!-- Status badges row -->
                            <HorizontalStackLayout Spacing="8" Margin="0,2,0,6">
                                <!-- Active / Inactive -->
                                <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                       BackgroundColor="#14532D">
                                    <Label Text="Active" FontFamily="PoppinsMedium" FontSize="11" TextColor="#22C55E" />
                                </Frame>
                                <!-- Payment Hold -->
                                <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                       BackgroundColor="{Binding ProfilePaymentHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#78350F|#1E293B'}"
                                       IsVisible="{Binding ProfilePaymentHold}">
                                    <Label Text="Payment Hold" FontFamily="PoppinsMedium" FontSize="11"
                                           TextColor="{Binding ProfilePaymentHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FCD34D|#64748B'}" />
                                </Frame>
                                <!-- Compliance Hold -->
                                <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                       BackgroundColor="{Binding ProfileComplianceHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7F1D1D|#1E293B'}"
                                       IsVisible="{Binding ProfileComplianceHold}">
                                    <Label Text="Compliance Hold" FontFamily="PoppinsMedium" FontSize="11"
                                           TextColor="{Binding ProfileComplianceHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FCA5A5|#64748B'}" />
                                </Frame>
                                <!-- Banking Verified -->
                                <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                       BackgroundColor="{Binding ProfileBankingVerified, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#14532D|#1E293B'}">
                                    <Label Text="{Binding ProfileBankingVerified, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Banking Verified|Banking Unverified'}"
                                           FontFamily="PoppinsMedium" FontSize="11"
                                           TextColor="{Binding ProfileBankingVerified, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#22C55E|#64748B'}" />
                                </Frame>
                            </HorizontalStackLayout>

                            <!-- Detail rows (Rating is intentionally absent — internal HR only) -->
                            <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <Label Grid.Row="0" Grid.Column="0" Text="Payment Terms"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding ProfilePaymentTerms}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                <Label Grid.Row="1" Grid.Column="0" Text="Payment Method"  Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding ProfilePaymentMethod}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Compliance Pack"  Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding ProfileCompliancePack}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            </Grid>

                            <Label Text="These settings are managed by your HR team."
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" Margin="0,4,0,0" />

                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 2: COMPLIANCE  (all existing compliance content preserved)    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsComplianceTab}">
            <VerticalStackLayout Spacing="14" Padding="16,0,16,16">

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" HorizontalOptions="Center" Margin="0,24" />

                <!-- ── Score card ──────────────────────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="18">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding PortalScorePercent, StringFormat='{0}%'}"
                                       FontFamily="PoppinsBold" FontSize="32" TextColor="{Binding PortalScoreColor}" />
                                <Label Text="Compliance score" FontFamily="PoppinsRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <ProgressBar Grid.Column="1"
                                         Progress="{Binding PortalScoreProgress}"
                                         ProgressColor="{Binding PortalScoreColor, Converter={StaticResource HexToColorConverter}}"
                                         BackgroundColor="#1E293B" HeightRequest="10" VerticalOptions="Center" />
                            <Frame Grid.Column="2" CornerRadius="8" Padding="10,6" HasShadow="False" BorderColor="Transparent"
                                   BackgroundColor="{Binding PortalStatusBadgeBg}" VerticalOptions="Center">
                                <Label Text="{Binding PortalStatusLabel}" FontFamily="PoppinsMedium" FontSize="12" TextColor="{Binding PortalStatusBadgeFg}" />
                            </Frame>
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                            <Frame Grid.Column="0" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#14532D">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PortalApprovedCount}" FontFamily="PoppinsSemiBold" FontSize="16" TextColor="#22C55E" HorizontalTextAlignment="Center" />
                                    <Label Text="Approved" FontFamily="PoppinsRegular" FontSize="9" TextColor="#4ADE80" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="1" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#450A0A">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PortalMissingCount}" FontFamily="PoppinsSemiBold" FontSize="16" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                    <Label Text="Missing" FontFamily="PoppinsRegular" FontSize="9" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="2" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#292012">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PortalExpiringCount}" FontFamily="PoppinsSemiBold" FontSize="16" TextColor="#FCD34D" HorizontalTextAlignment="Center" />
                                    <Label Text="Expiring" FontFamily="PoppinsRegular" FontSize="9" TextColor="#FCD34D" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="3" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#7F1D1D">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PortalRejectedCount}" FontFamily="PoppinsSemiBold" FontSize="16" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                    <Label Text="Rejected" FontFamily="PoppinsRegular" FontSize="9" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="4" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#1E293B">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PortalRequiredCount}" FontFamily="PoppinsSemiBold" FontSize="16" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                                    <Label Text="Required" FontFamily="PoppinsRegular" FontSize="9" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Missing Required Documents ─────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding MissingRows.Count, Converter={StaticResource IsNotZeroConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="MISSING REQUIRED DOCUMENTS" Style="{StaticResource LabelSection}" />
                        <Label Text="These documents are required by your assigned compliance pack. Please upload them for HR review."
                               FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,6" ColumnSpacing="10" BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Type"     Style="{StaticResource DataTableHeaderLabel}" WidthRequest="50" />
                            <Label Grid.Column="1" Text="Document" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text=""         Style="{StaticResource DataTableHeaderLabel}" WidthRequest="80" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding MissingRows}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="hrVm:PackChecklistRow">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,8" ColumnSpacing="10">
                                            <Frame Grid.Column="0" CornerRadius="5" Padding="5,2" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding RequirementBg}" VerticalOptions="Center">
                                                <Label Text="{Binding RequirementLabel}" FontFamily="PoppinsMedium" FontSize="9" TextColor="{Binding RequirementFg}" />
                                            </Frame>
                                            <Label Grid.Column="1" Text="{Binding TypeLabel}"
                                                   FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Button Grid.Column="2" Text="Upload"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.UploadMissingDocumentCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    CornerRadius="6" Padding="8,0" HeightRequest="30" BorderWidth="0" />
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Expiring Soon ───────────────────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding ExpiringDocs.Count, Converter={StaticResource IsNotZeroConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="EXPIRING WITHIN 30 DAYS" Style="{StaticResource LabelSection}" />
                        <Label Text="These documents are still valid but will expire soon. Upload a renewed version now to stay compliant."
                               FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="4,6" ColumnSpacing="10" BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Document" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Expires"  Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text=""         Style="{StaticResource DataTableHeaderLabel}" WidthRequest="80" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding ExpiringDocs}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ContractorDocument">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="4,8" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                                <Label Text="{Binding DocumentName}" FontFamily="PoppinsRegular" FontSize="12"
                                                       TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding TypeLabel}" FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding ExpiryDisplay}"
                                                   FontFamily="PoppinsMedium" FontSize="12" TextColor="#FCD34D" VerticalOptions="Center" />
                                            <Button Grid.Column="2" Text="Replace"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.ReplaceDocumentCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#78350F" TextColor="#FCD34D"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    CornerRadius="6" Padding="8,0" HeightRequest="30" BorderWidth="0" />
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Rejected Documents ─────────────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding RejectedDocs.Count, Converter={StaticResource IsNotZeroConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="REJECTED DOCUMENTS" Style="{StaticResource LabelSection}" />
                        <Label Text="These documents were reviewed and rejected by HR. Please re-upload a corrected version."
                               FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="*,Auto" Padding="4,6" ColumnSpacing="10" BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Document" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text=""         Style="{StaticResource DataTableHeaderLabel}" WidthRequest="90" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding RejectedDocs}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ContractorDocument">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="*,Auto" Padding="4,8" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding DocumentName}" FontFamily="PoppinsRegular" FontSize="12"
                                                       TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding RejectedReason, StringFormat='Reason: {0}'}"
                                                       FontFamily="PoppinsRegular" FontSize="10" TextColor="#FCA5A5"
                                                       LineBreakMode="TailTruncation"
                                                       IsVisible="{Binding RejectedReason, Converter={StaticResource IsNotNullConverter}}" />
                                            </VerticalStackLayout>
                                            <Button Grid.Column="1" Text="Re-upload"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.ReplaceDocumentCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    CornerRadius="6" Padding="8,0" HeightRequest="30" BorderWidth="0" />
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Submitted Documents ────────────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="SUBMITTED DOCUMENTS"
                                   Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="+ Upload Document"
                                    Command="{Binding UploadAdditionalDocumentCommand}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                    FontFamily="PoppinsMedium" FontSize="11"
                                    CornerRadius="6" Padding="10,0" HeightRequest="32" BorderWidth="0" />
                        </Grid>
                        <Label Text="No documents submitted yet. Use '+ Upload Document' to add your first compliance document."
                               FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}"
                               LineBreakMode="WordWrap"
                               IsVisible="{Binding PortalDocuments.Count, Converter={StaticResource IsZeroConverter}}" />
                        <ScrollView Orientation="Horizontal"
                                    IsVisible="{Binding PortalDocuments.Count, Converter={StaticResource IsNotZeroConverter}}">
                            <VerticalStackLayout WidthRequest="720" Spacing="0">
                                <Grid ColumnDefinitions="145,150,100,85,85,125" Padding="4,7" ColumnSpacing="8" BackgroundColor="{StaticResource SurfaceElevated}">
                                    <Label Grid.Column="0" Text="Type"     Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="1" Text="Document" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="2" Text="Status"   Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="3" Text="Uploaded" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="4" Text="Expires"  Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="5" Text="Actions"  Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding PortalDocuments}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ContractorDocument">
                                            <VerticalStackLayout Spacing="0">
                                                <Grid ColumnDefinitions="145,150,100,85,85,125" Padding="4,8" ColumnSpacing="8">
                                                    <Label Grid.Column="0" Text="{Binding TypeLabel}"
                                                           FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                                    <Label Grid.Column="1" Text="{Binding DocumentName}"
                                                           FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                                    <Frame Grid.Column="2" CornerRadius="6" Padding="6,2" HasShadow="False" BorderColor="Transparent"
                                                           BackgroundColor="{Binding ApprovalBadgeBg}" HorizontalOptions="Start" VerticalOptions="Center">
                                                        <Label Text="{Binding StatusTableLabel}" FontFamily="PoppinsMedium" FontSize="9" TextColor="{Binding ApprovalBadgeFg}" />
                                                    </Frame>
                                                    <Label Grid.Column="3" Text="{Binding UploadedDateDisplay}"
                                                           FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                                    <Label Grid.Column="4" Text="{Binding ExpiryDisplay}"
                                                           FontFamily="PoppinsRegular" FontSize="11" TextColor="{Binding ExpiryDateColor}" VerticalOptions="Center" />
                                                    <HorizontalStackLayout Grid.Column="5" Spacing="2" HorizontalOptions="End" VerticalOptions="Center">
                                                        <Button Text="View"
                                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.ViewPortalDocumentCommand}"
                                                                CommandParameter="{Binding .}"
                                                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                                                FontFamily="PoppinsMedium" FontSize="11" BorderWidth="0" HeightRequest="30" Padding="5,0" />
                                                        <Button Text="Replace"
                                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.ReplaceDocumentCommand}"
                                                                CommandParameter="{Binding .}"
                                                                BackgroundColor="Transparent" TextColor="#94A3B8"
                                                                FontFamily="PoppinsMedium" FontSize="11" BorderWidth="0" HeightRequest="30" Padding="5,0" />
                                                    </HorizontalStackLayout>
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Compliance Progress ─────────────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding PortalChecklist.Count, Converter={StaticResource IsNotZeroConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="COMPLIANCE PROGRESS" Style="{StaticResource LabelSection}" />
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="4,6" ColumnSpacing="10" BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Type"     Style="{StaticResource DataTableHeaderLabel}" WidthRequest="50" />
                            <Label Grid.Column="1" Text="Document" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Expires"  Style="{StaticResource DataTableHeaderLabel}" WidthRequest="90" />
                            <Label Grid.Column="3" Text="Status"   Style="{StaticResource DataTableHeaderLabel}" WidthRequest="90" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding PortalChecklist}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="hrVm:PackChecklistRow">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="4,7" ColumnSpacing="10">
                                            <Frame Grid.Column="0" CornerRadius="5" Padding="5,2" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding RequirementBg}" VerticalOptions="Center">
                                                <Label Text="{Binding RequirementLabel}" FontFamily="PoppinsMedium" FontSize="9" TextColor="{Binding RequirementFg}" />
                                            </Frame>
                                            <Label Grid.Column="1" Text="{Binding TypeLabel}"
                                                   FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="2" Text="{Binding ExpiryDisplay}"
                                                   FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" IsVisible="{Binding ShowExpiry}" />
                                            <Frame Grid.Column="3" CornerRadius="8" Padding="8,3" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding StatusBadgeBg}" VerticalOptions="Center">
                                                <Label Text="{Binding StatusLabel}" FontFamily="PoppinsMedium" FontSize="10" TextColor="{Binding StatusBadgeFg}" />
                                            </Frame>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 3: BANKING  (Phase 2C.3 — self-service banking submission)    -->
        <!-- A. Current status (masked)  B. Pending banner  C. Submit form     -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsBankingTab}">
            <VerticalStackLayout Padding="16,0,16,20" Spacing="14">

                <!-- Loading -->
                <Frame Style="{StaticResource CardFrame}" Padding="14"
                       IsVisible="{Binding BankingLoading}">
                    <HorizontalStackLayout Spacing="10">
                        <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}"
                                           WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                        <Label Text="Loading banking details…" FontFamily="PoppinsRegular" FontSize="13"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- ── A. Current Banking Status ──────────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding BankingLoaded}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="CURRENT BANKING STATUS" Style="{StaticResource LabelSection}" />

                        <!-- Status badges -->
                        <HorizontalStackLayout Spacing="8" Margin="0,2,0,4">
                            <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                   BackgroundColor="{Binding BankVerified, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#14532D|#1E293B'}">
                                <Label Text="{Binding BankVerified, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Banking Verified|Banking Unverified'}"
                                       FontFamily="PoppinsMedium" FontSize="10"
                                       TextColor="{Binding BankVerified, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#22C55E|#64748B'}" />
                            </Frame>
                            <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                   BackgroundColor="{Binding BankPaymentHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#78350F|#1E293B'}"
                                   IsVisible="{Binding BankPaymentHold}">
                                <Label Text="Payment Hold" FontFamily="PoppinsMedium" FontSize="10" TextColor="#FCD34D" />
                            </Frame>
                            <Frame CornerRadius="8" Padding="9,4" HasShadow="False" BorderColor="Transparent"
                                   BackgroundColor="{Binding BankComplianceHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#7F1D1D|#1E293B'}"
                                   IsVisible="{Binding BankComplianceHold}">
                                <Label Text="Compliance Hold" FontFamily="PoppinsMedium" FontSize="10" TextColor="#FCA5A5" />
                            </Frame>
                        </HorizontalStackLayout>

                        <!-- No banking on file -->
                        <Label Text="No banking details on file. Use the form below to submit your banking information for HR review."
                               FontFamily="PoppinsRegular" FontSize="12"
                               TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap"
                               IsVisible="{Binding BankHasDetails, Converter={StaticResource InverseBoolConverter}}" />

                        <!-- Banking detail rows -->
                        <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="8" IsVisible="{Binding BankHasDetails}">
                            <Label Grid.Row="0" Grid.Column="0" Text="Account Holder"  Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding BankAccountHolder}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Bank"             Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding BankBankName}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                            <Label Grid.Row="2" Grid.Column="0" Text="Account No."      Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding BankMaskedAccount}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                            <Label Grid.Row="3" Grid.Column="0" Text="Account Type"    Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding BankAccountType}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            <Label Grid.Row="4" Grid.Column="0" Text="Branch Code"     Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="4" Grid.Column="1" Text="{Binding BankBranchCode, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            <Label Grid.Row="5" Grid.Column="0" Text="SWIFT/BIC"       Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="5" Grid.Column="1" Text="{Binding BankSwiftBic, FallbackValue='—', TargetNullValue='—'}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            <Label Grid.Row="6" Grid.Column="0" Text="Payment Terms"   Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="6" Grid.Column="1" Text="{Binding BankPaymentTerms}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            <Label Grid.Row="7" Grid.Column="0" Text="Payment Method"  Style="{StaticResource Caption}" VerticalOptions="Center" />
                            <Label Grid.Row="7" Grid.Column="1" Text="{Binding BankPaymentMethod}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── B. Decision cards (pending / approved / rejected) ──── -->

                <!-- B1: Pending -->
                <Frame CornerRadius="10" Padding="14" HasShadow="False"
                       BorderColor="#78350F" BackgroundColor="#1A1200"
                       IsVisible="{Binding HasPendingBanking}">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="16"
                                   TextColor="#FCD34D" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Banking update pending HR review"
                                       FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FCD34D" />
                                <Label Text="{Binding PendingBankSubmittedAt, StringFormat='Submitted: {0}'}"
                                       FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4" Margin="0,4,0,0">
                            <Label Grid.Row="0" Grid.Column="0" Text="Account Holder" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding PendingBankAccountHolder}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FFFFFF" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Bank" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding PendingBankBankName}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FFFFFF" />
                            <Label Grid.Row="2" Grid.Column="0" Text="Account No." FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding PendingBankMaskedAccount}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FFFFFF" />
                        </Grid>
                        <Label Text="Submitting new banking details will replace this pending update."
                               FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A"
                               LineBreakMode="WordWrap" Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Frame>

                <!-- B2: Approved -->
                <Frame CornerRadius="10" Padding="14" HasShadow="False"
                       BorderColor="#14532D" BackgroundColor="#0A1F0F"
                       IsVisible="{Binding HasApprovedDecision}">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xE876;" FontFamily="MaterialIcons" FontSize="18"
                                   TextColor="#22C55E" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Banking update approved by HR"
                                       FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#22C55E" />
                                <Label Text="{Binding DecisionReviewedAt, StringFormat='Reviewed: {0}'}"
                                       FontFamily="PoppinsRegular" FontSize="11" TextColor="#4ADE80" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Label Text="Your banking details have been updated and are now active. Banking verification may still be required by HR before payments are released."
                               FontFamily="PoppinsRegular" FontSize="12"
                               TextColor="#86EFAC" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <!-- B3: Rejected -->
                <Frame CornerRadius="10" Padding="14" HasShadow="False"
                       BorderColor="#7F1D1D" BackgroundColor="#1A0707"
                       IsVisible="{Binding HasRejectedDecision}">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xE897;" FontFamily="MaterialIcons" FontSize="18"
                                   TextColor="#FCA5A5" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Banking update rejected by HR"
                                       FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FCA5A5" />
                                <Label Text="{Binding DecisionReviewedAt, StringFormat='Reviewed: {0}'}"
                                       FontFamily="PoppinsRegular" FontSize="11" TextColor="#FCA5A5" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <!-- Rejection reason -->
                        <Frame CornerRadius="6" Padding="10,7" HasShadow="False" BorderColor="Transparent"
                               BackgroundColor="#2D0A0A"
                               IsVisible="{Binding DecisionRejectionReason, Converter={StaticResource IsNotNullConverter}}">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Reason from HR:" FontFamily="PoppinsMedium" FontSize="11" TextColor="#FCA5A5" />
                                <Label Text="{Binding DecisionRejectionReason}" FontFamily="PoppinsRegular"
                                       FontSize="12" TextColor="#FDE8E8" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Frame>
                        <Label Text="Please submit corrected banking details using the form below."
                               FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── C. Submit Banking Update Form ──────────────────────── -->
                <Frame Style="{StaticResource CardFrame}" Padding="16"
                       IsVisible="{Binding BankingLoaded}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="SUBMIT BANKING UPDATE" Style="{StaticResource LabelSection}" />
                        <Label Text="Complete the form below and submit for HR review. Your current banking details will not change until HR approves the update."
                               FontFamily="PoppinsRegular" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />

                        <Entry Placeholder="Account holder name *"
                               Text="{Binding EditBankAccountHolder, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Bank name *"
                               Text="{Binding EditBankName, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Account number *"
                               Text="{Binding EditBankAccount, Mode=TwoWay}"
                               Keyboard="Numeric" Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Branch code"
                               Text="{Binding EditBranchCode, Mode=TwoWay}"
                               Keyboard="Numeric" Style="{StaticResource DarkEntry}" />
                        <Picker Title="Account type"
                                ItemsSource="{Binding BankAccountTypeItems}"
                                SelectedItem="{Binding EditAccountTypeLabel, Mode=TwoWay}"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}" />
                        <Entry Placeholder="SWIFT / BIC (international transfers)"
                               Text="{Binding EditSwiftBic, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />

                        <!-- Security note -->
                        <Frame CornerRadius="6" Padding="10,7" HasShadow="False"
                               BorderColor="#334155" BackgroundColor="#0F172A">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xE897;" FontFamily="MaterialIcons" FontSize="14"
                                       TextColor="#FCD34D" VerticalOptions="Center" />
                                <Label Text="Banking changes require HR approval and will not take effect until reviewed."
                                       FontFamily="PoppinsRegular" FontSize="11" TextColor="#64748B"
                                       LineBreakMode="WordWrap" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>

                        <!-- Submit button — WinUI-reliable Button.Command -->
                        <Button Text="Submit to HR"
                                Command="{Binding SubmitBankingCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" HeightRequest="44"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 4: TEAM  (placeholder)                                        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsTeamTab}">
            <VerticalStackLayout Padding="16,0,16,16" Spacing="14">
                <Frame Style="{StaticResource CardFrame}" Padding="18">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="TEAM" Style="{StaticResource LabelSection}" />
                        <Label Text="Team member management is coming soon."
                               FontFamily="PoppinsRegular" FontSize="13"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 5: JOBS  (existing content, unchanged)                        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding IsJobsTab}">
            <CollectionView ItemsSource="{Binding Jobs}">
                <CollectionView.EmptyView>
                    <Label Text="No jobs assigned to your contractor profile yet." Style="{StaticResource EmptyState}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Job">
                        <Frame Style="{StaticResource CardFrame}" Margin="16,6,16,0" Padding="16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontFamily="PoppinsSemiBold" FontSize="15" TextColor="{StaticResource TextPrimary}" />
                                    <Frame BackgroundColor="{StaticResource SurfaceElevated}" BorderColor="{StaticResource Divider}"
                                           CornerRadius="8" Padding="8,3" HasShadow="False" HorizontalOptions="Start">
                                        <Label Text="{Binding StatusRaw}" FontFamily="PoppinsMedium" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                    </Frame>
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Open" VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ContractorPortalViewModel}}, Path=OpenJobCommand}"
                                        CommandParameter="{Binding .}" Style="{StaticResource PrimaryButton}" FontSize="12" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 6: PAYMENTS  (Phase I — enriched payment history)            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding IsPaymentsTab}">
            <ScrollView>
                <VerticalStackLayout Padding="16,0,16,16" Spacing="0">

                    <!-- ── Summary card ─────────────────────────────────────── -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                <Label Text="Outstanding (unpaid / pending)" Style="{StaticResource BodySmall}"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="Excludes paid settlements." FontFamily="PoppinsRegular" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding OutstandingPayoutsDisplay}"
                                   FontFamily="PoppinsSemiBold" FontSize="20"
                                   TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <!-- ── Filter chips ──────────────────────────────────────── -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,0,0,12">
                        <HorizontalStackLayout Spacing="6">
                            <Button Text="All"
                                    Command="{Binding SetPaymentsFilterCommand}" CommandParameter="All"
                                    BackgroundColor="{Binding IsPaymentsFilterAll, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                                    TextColor="{Binding IsPaymentsFilterAll, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                    FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                    Padding="12,0" HeightRequest="32" BorderWidth="0" />
                            <Button Text="Pending"
                                    Command="{Binding SetPaymentsFilterCommand}" CommandParameter="Pending"
                                    BackgroundColor="{Binding IsPaymentsFilterPending, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                                    TextColor="{Binding IsPaymentsFilterPending, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                    FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                    Padding="12,0" HeightRequest="32" BorderWidth="0" />
                            <Button Text="Approved"
                                    Command="{Binding SetPaymentsFilterCommand}" CommandParameter="Approved"
                                    BackgroundColor="{Binding IsPaymentsFilterApproved, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                                    TextColor="{Binding IsPaymentsFilterApproved, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                    FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                    Padding="12,0" HeightRequest="32" BorderWidth="0" />
                            <Button Text="Paid"
                                    Command="{Binding SetPaymentsFilterCommand}" CommandParameter="Paid"
                                    BackgroundColor="{Binding IsPaymentsFilterPaid, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                                    TextColor="{Binding IsPaymentsFilterPaid, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                    FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                    Padding="12,0" HeightRequest="32" BorderWidth="0" />
                            <Button Text="Rejected"
                                    Command="{Binding SetPaymentsFilterCommand}" CommandParameter="Rejected"
                                    BackgroundColor="{Binding IsPaymentsFilterRejected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|#1E293B'}"
                                    TextColor="{Binding IsPaymentsFilterRejected, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                    FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                    Padding="12,0" HeightRequest="32" BorderWidth="0" />
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- ── Phase P: inline revise form ───────────────────────── -->
                    <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,12" Padding="16"
                           IsVisible="{Binding IsReviseMode}"
                           BorderColor="#EF4444" BackgroundColor="#1C0A0A">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="REVISE &amp; RESUBMIT" FontFamily="PoppinsSemiBold" FontSize="10"
                                           TextColor="#EF4444" CharacterSpacing="1.2" />
                                    <Label Text="{Binding ReviseOriginalRef, StringFormat='Ref: {0}'}"
                                           FontFamily="PoppinsRegular" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Cancel"
                                        Command="{Binding CancelReviseCommand}"
                                        BackgroundColor="Transparent" TextColor="{StaticResource TextSecondary}"
                                        FontFamily="PoppinsMedium" FontSize="12" HeightRequest="32" Padding="8,0" />
                            </Grid>

                            <Label Text="{Binding ReviseJobDisplay, StringFormat='Job: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}"
                                   IsVisible="{Binding ReviseHasJob}" />

                            <VerticalStackLayout Spacing="3">
                                <Label Text="Revised Amount (R)" FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Entry Text="{Binding ReviseAmount}" Keyboard="Numeric"
                                       FontFamily="PoppinsRegular" FontSize="14"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="{StaticResource SurfaceCard}"
                                       Placeholder="0.00" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="3">
                                <Label Text="Invoice Reference" FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Entry Text="{Binding ReviseInvoiceRef}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="{StaticResource SurfaceCard}"
                                       Placeholder="e.g. INV-2024-001" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="3">
                                <Label Text="Note to HR (optional)" FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Editor Text="{Binding ReviseNotes}" AutoSize="TextChanges"
                                        FontFamily="PoppinsRegular" FontSize="13"
                                        TextColor="{StaticResource TextPrimary}"
                                        BackgroundColor="{StaticResource SurfaceCard}"
                                        MinimumHeightRequest="56"
                                        Placeholder="Explain the correction…" />
                            </VerticalStackLayout>

                            <Button Text="Submit Revised Invoice"
                                    Command="{Binding SubmitReviseCommand}"
                                    Style="{StaticResource PrimaryButton}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- ── Payment list ───────────────────────────────────────── -->
                    <CollectionView ItemsSource="{Binding FilteredPayouts}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No payment records match this filter."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ContractorPayout">
                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,10" Padding="16">
                                    <VerticalStackLayout Spacing="8">

                                        <!-- Row 1: status badge + date -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <Frame Grid.Column="0" CornerRadius="6" Padding="8,3"
                                                   HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding StatusBadgeBg}"
                                                   VerticalOptions="Center">
                                                <Label Text="{Binding FullStatusLabel}"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{Binding StatusBadgeFg}" />
                                            </Frame>
                                            <Label Grid.Column="2" Text="{Binding BestDateDisplay}"
                                                   FontFamily="PoppinsRegular" FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" HorizontalTextAlignment="End" />
                                        </Grid>

                                        <!-- Row 2: job (if available) -->
                                        <HorizontalStackLayout Spacing="6" IsVisible="{Binding HasJobDisplay}">
                                            <Label Text="&#xE8A7;" FontFamily="MaterialIcons" FontSize="13"
                                                   TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                            <Label Text="{Binding JobDisplay}"
                                                   FontFamily="PoppinsMedium" FontSize="13"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <!-- Row 3: invoice reference from notes -->
                                        <HorizontalStackLayout Spacing="6" IsVisible="{Binding HasInvoiceReference}">
                                            <Label Text="&#xE873;" FontFamily="MaterialIcons" FontSize="13"
                                                   TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                            <Label Text="{Binding InvoiceReferenceDisplay}"
                                                   FontFamily="PoppinsRegular" FontSize="12"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <!-- Row 4: amounts + source badge -->
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding NetDisplay}"
                                                       FontFamily="PoppinsSemiBold" FontSize="16"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label Text="{Binding TotalDisplay, StringFormat='Gross {0}'}"
                                                       FontFamily="PoppinsRegular" FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}" />
                                                <Label Text="{Binding RetentionDisplay, StringFormat='Retention: {0}'}"
                                                       FontFamily="PoppinsRegular" FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       IsVisible="{Binding HasRetention}" />
                                            </VerticalStackLayout>
                                            <Frame Grid.Column="1" CornerRadius="6" Padding="8,3"
                                                   HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding IsPortalSubmission, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                                                   VerticalOptions="Center">
                                                <Label Text="{Binding SourceLabel}"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{Binding IsPortalSubmission, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#60A5FA|#64748B'}" />
                                            </Frame>
                                        </Grid>

                                        <!-- Row 5: status timeline (Phase K) -->
                                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}"
                                                 Margin="0,4,0,4" />
                                        <Grid ColumnDefinitions="14,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto" RowSpacing="0">
                                            <!-- Step 1: Submitted (always) -->
                                            <Ellipse Grid.Row="0" Grid.Column="0"
                                                     Fill="#22C55E" WidthRequest="10" HeightRequest="10"
                                                     VerticalOptions="Center" HorizontalOptions="Center" />
                                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="0" Margin="0,4,0,6">
                                                <Label Text="Submitted"
                                                       FontFamily="PoppinsMedium" FontSize="11"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label Text="{Binding TimelineSubmittedAt}"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                            <!-- Step 2: Approved / Rejected -->
                                            <Ellipse Grid.Row="1" Grid.Column="0"
                                                     Fill="{Binding TimelineApprovalStepColor}"
                                                     WidthRequest="10" HeightRequest="10"
                                                     VerticalOptions="Center" HorizontalOptions="Center" />
                                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="0" Margin="0,4,0,6">
                                                <Label Text="{Binding TimelineApprovalStepLabel}"
                                                       FontFamily="PoppinsMedium" FontSize="11"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label Text="{Binding TimelineApprovedAt}"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                            <!-- Step 3: Paid -->
                                            <Ellipse Grid.Row="2" Grid.Column="0"
                                                     Fill="{Binding TimelinePaid, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#22C55E|#334155'}"
                                                     WidthRequest="10" HeightRequest="10"
                                                     VerticalOptions="Center" HorizontalOptions="Center" />
                                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="0" Margin="0,4,0,0">
                                                <Label Text="Paid"
                                                       FontFamily="PoppinsMedium" FontSize="11"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label Text="{Binding TimelinePaidAt}"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Phase P: rejection reason + revise action -->
                                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsRejected}"
                                                             Margin="0,8,0,0">
                                            <BoxView HeightRequest="1" BackgroundColor="#7F1D1D" Margin="0,0,0,0" />
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="&#xE5CD;" FontFamily="MaterialIcons" FontSize="14"
                                                       TextColor="#FCA5A5" VerticalOptions="Center" />
                                                <Label Text="{Binding RejectionReasonDisplay}"
                                                       FontFamily="PoppinsRegular" FontSize="12"
                                                       TextColor="#FCA5A5"
                                                       LineBreakMode="WordWrap" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <Button Text="Revise &amp; Resubmit"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ContractorPortalViewModel}}, Path=StartRevisePayoutCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                                                    FontFamily="PoppinsMedium" FontSize="12"
                                                    HeightRequest="36" CornerRadius="8" />
                                        </VerticalStackLayout>

                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 7: QUOTES  (Phase 2D.2)                                       -->
        <!-- Sub-views: list | create | upload | detail                        -->
        <!-- All in Grid.Row="2" with IsVisible switching                      -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <!-- ── QUOTES: List view ──────────────────────────────────────────── -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" IsVisible="{Binding IsQuotesTab}">

            <!-- Action bar + filter -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8"
                  Padding="16,10,16,4"
                  IsVisible="{Binding IsQuoteListView}">
                <Button Grid.Column="0" Text="+ Create Quote"
                        Command="{Binding ShowCreateQuoteCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        FontFamily="PoppinsMedium" FontSize="12"
                        CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Grid.Column="1" Text="+ Upload Quote"
                        Command="{Binding ShowUploadQuoteCommand}"
                        BackgroundColor="#1E293B" TextColor="#94A3B8"
                        FontFamily="PoppinsMedium" FontSize="12"
                        CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Picker Grid.Column="3"
                        ItemsSource="{Binding QuoteFilterOptions}"
                        SelectedItem="{Binding QuotesFilter, Mode=TwoWay}"
                        TitleColor="{StaticResource TextSecondary}"
                        TextColor="{StaticResource TextPrimary}"
                        FontFamily="PoppinsRegular" FontSize="12"
                        WidthRequest="140" />
            </Grid>

            <!-- Quote list -->
            <ScrollView Grid.Row="1" IsVisible="{Binding IsQuoteListView}">
                <VerticalStackLayout Padding="16,4,16,16" Spacing="0">
                    <ActivityIndicator IsRunning="{Binding QuotesLoading}"
                                       IsVisible="{Binding QuotesLoading}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" Margin="0,20" />
                    <Label Text="No quotes yet. Tap '+ Create Quote' to submit your first quote."
                           Style="{StaticResource EmptyState}" Margin="0,24"
                           IsVisible="{Binding FilteredQuotes.Count, Converter={StaticResource IsZeroConverter}}" />
                    <CollectionView ItemsSource="{Binding FilteredQuotes}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ContractorQuote">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="0,10" ColumnSpacing="10">
                                        <!-- Status badge -->
                                        <Frame Grid.Column="0" CornerRadius="6" Padding="7,3"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding StatusBadgeBg}"
                                               VerticalOptions="Start" WidthRequest="88">
                                            <Label Text="{Binding StatusLabel}"
                                                   FontFamily="PoppinsMedium" FontSize="10"
                                                   TextColor="{Binding StatusBadgeFg}"
                                                   HorizontalTextAlignment="Center" />
                                        </Frame>
                                        <!-- Title + meta -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Title}"
                                                   FontFamily="PoppinsMedium" FontSize="13"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding QuoteNumberDisplay}"
                                                   FontFamily="PoppinsRegular" FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <!-- Amount -->
                                        <Label Grid.Column="2" Text="{Binding TotalDisplay}"
                                               FontFamily="PoppinsSemiBold" FontSize="13"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center" />
                                        <!-- Actions -->
                                        <VerticalStackLayout Grid.Column="3" Spacing="4" VerticalOptions="Center">
                                            <Button Text="View"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.ViewQuoteCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    BorderWidth="0" HeightRequest="28" Padding="5,0" />
                                            <!-- Edit: draft OR revision_requested -->
                                            <Button Text="Edit"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.EditDraftCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding CanEdit}"
                                                    BackgroundColor="Transparent" TextColor="#94A3B8"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    BorderWidth="0" HeightRequest="28" Padding="5,0" />
                                            <!-- Submit: draft only -->
                                            <Button Text="Submit"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.SubmitExistingDraftCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding IsDraft}"
                                                    BackgroundColor="Transparent" TextColor="#22C55E"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    BorderWidth="0" HeightRequest="28" Padding="5,0" />
                                            <!-- Resubmit: revision_requested only -->
                                            <Button Text="Resubmit"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.ResubmitQuoteCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding CanResubmit}"
                                                    BackgroundColor="Transparent" TextColor="#FDBA74"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    BorderWidth="0" HeightRequest="28" Padding="5,0" />
                                            <!-- Delete: draft only -->
                                            <Button Text="Delete"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.DeleteDraftCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding IsDraft}"
                                                    BackgroundColor="Transparent" TextColor="{StaticResource Error}"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    BorderWidth="0" HeightRequest="28" Padding="5,0" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <!-- ── QUOTES: Create / Edit form ────────────────────────────── -->
            <ScrollView Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding IsCreateQuoteView}">
                <VerticalStackLayout Padding="16,10,16,24" Spacing="14">

                    <!-- Error banner -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#7F1D1D" BackgroundColor="#2D0A0A"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                        <Label Text="{Binding ErrorMessage}" FontFamily="PoppinsRegular"
                               FontSize="12" TextColor="#FCA5A5" LineBreakMode="WordWrap" />
                    </Frame>

                    <!-- ── Header action bar ─────────────────────────────────── -->
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="CREATE QUOTE"
                               Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Cancel"
                                Command="{Binding BackToQuoteListCommand}"
                                BackgroundColor="#1E293B" TextColor="#94A3B8"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0" />
                        <Button Grid.Column="2" Text="Save Draft"
                                Command="{Binding SaveDraftCommand}"
                                BackgroundColor="#1E293B" TextColor="#94A3B8"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="3" Text="Submit to HR"
                                Command="{Binding SaveAndSubmitQuoteCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>

                    <!-- ── A. Quote header — labeled field rows ──────────────── -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="QUOTE DETAILS" Style="{StaticResource LabelSection}" Margin="0,0,0,10" />

                            <!-- Reusable field-row helper: Label(150) + Entry(*) -->
                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Title *"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateTitle, Mode=TwoWay}"
                                       Placeholder="e.g. Security Installation Q3 2026"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Description"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateDescription, Mode=TwoWay}"
                                       Placeholder="Brief scope of work (optional)"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Quote Reference"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateQuoteNumber, Mode=TwoWay}"
                                       Placeholder="Your own reference number (optional)"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Valid Until"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateValidUntilText, Mode=TwoWay}"
                                       Placeholder="dd/MM/yyyy"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Payment Terms"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateTerms, Mode=TwoWay}"
                                       Placeholder="e.g. 30 days EFT"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Notes"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Start"
                                       Margin="0,8,0,0" />
                                <Editor Grid.Column="1" Text="{Binding CreateNotes, Mode=TwoWay}"
                                        Placeholder="Additional notes (optional)"
                                        AutoSize="TextChanges" MinimumHeightRequest="48"
                                        TextColor="{StaticResource TextPrimary}"
                                        PlaceholderColor="{StaticResource TextSecondary}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- ── B. Line items — professional table ────────────────── -->
                    <!-- Horizontal scroll: table fits any screen width cleanly   -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14">
                        <VerticalStackLayout Spacing="10">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="LINE ITEMS"
                                       Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="+ Add Line"
                                        Command="{Binding AddLineItemCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsMedium" FontSize="11"
                                        CornerRadius="6" Padding="10,0" HeightRequest="30" BorderWidth="0" />
                            </Grid>

                            <!-- Table — horizontal scroll for desktop. Columns:
                                 Description(230) | Qty(70) | Unit Price(95) | Discount(90) | Line Total(95) | ×(50) = 630px -->
                            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                <VerticalStackLayout WidthRequest="650" Spacing="0">

                                    <!-- Header row -->
                                    <Grid ColumnDefinitions="230,70,95,90,95,50" Padding="6,7"
                                          ColumnSpacing="6" BackgroundColor="{StaticResource SurfaceElevated}">
                                        <Label Grid.Column="0" Text="Description / Service"
                                               FontFamily="PoppinsMedium" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Grid.Column="1" Text="Qty"
                                               FontFamily="PoppinsMedium" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalTextAlignment="Center" />
                                        <Label Grid.Column="2" Text="Unit Price"
                                               FontFamily="PoppinsMedium" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalTextAlignment="End" />
                                        <Label Grid.Column="3" Text="Discount"
                                               FontFamily="PoppinsMedium" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalTextAlignment="End" />
                                        <Label Grid.Column="4" Text="Line Total"
                                               FontFamily="PoppinsMedium" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalTextAlignment="End" />
                                        <Label Grid.Column="5" Text=""
                                               FontFamily="PoppinsMedium" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                                    <!-- Data rows (one per line item) -->
                                    <CollectionView ItemsSource="{Binding CreateLineItems}">
                                        <CollectionView.EmptyView>
                                            <Label Text="No line items yet — tap '+ Add Line' to begin."
                                                   FontFamily="PoppinsRegular" FontSize="12"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   HorizontalTextAlignment="Center" Margin="0,12" />
                                        </CollectionView.EmptyView>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:QuoteLineItemRow">
                                                <VerticalStackLayout Spacing="0">
                                                    <Grid ColumnDefinitions="230,70,95,90,95,50"
                                                          Padding="4,4" ColumnSpacing="6"
                                                          BackgroundColor="{StaticResource SurfaceCard}">

                                                        <!-- Description -->
                                                        <Entry Grid.Column="0"
                                                               Text="{Binding Description, Mode=TwoWay}"
                                                               Placeholder="Item or service"
                                                               FontFamily="PoppinsRegular" FontSize="12"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               PlaceholderColor="{StaticResource TextSecondary}"
                                                               BackgroundColor="Transparent"
                                                               HeightRequest="36" />

                                                        <!-- Qty -->
                                                        <Entry Grid.Column="1"
                                                               Text="{Binding Quantity, Mode=TwoWay}"
                                                               Keyboard="Numeric"
                                                               FontFamily="PoppinsRegular" FontSize="12"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               PlaceholderColor="{StaticResource TextSecondary}"
                                                               BackgroundColor="Transparent"
                                                               HorizontalTextAlignment="Center"
                                                               HeightRequest="36" />

                                                        <!-- Unit Price -->
                                                        <Entry Grid.Column="2"
                                                               Text="{Binding UnitPrice, Mode=TwoWay}"
                                                               Keyboard="Numeric"
                                                               FontFamily="PoppinsRegular" FontSize="12"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               PlaceholderColor="{StaticResource TextSecondary}"
                                                               BackgroundColor="Transparent"
                                                               HorizontalTextAlignment="End"
                                                               HeightRequest="36" />

                                                        <!-- Discount -->
                                                        <Entry Grid.Column="3"
                                                               Text="{Binding DiscountAmount, Mode=TwoWay}"
                                                               Keyboard="Numeric"
                                                               FontFamily="PoppinsRegular" FontSize="12"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               PlaceholderColor="{StaticResource TextSecondary}"
                                                               BackgroundColor="Transparent"
                                                               HorizontalTextAlignment="End"
                                                               HeightRequest="36" />

                                                        <!-- Line Total (read-only computed) -->
                                                        <Label Grid.Column="4"
                                                               Text="{Binding LineTotalDisplay}"
                                                               FontFamily="PoppinsMedium" FontSize="12"
                                                               TextColor="{StaticResource TextPrimary}"
                                                               HorizontalTextAlignment="End"
                                                               VerticalOptions="Center" />

                                                        <!-- Remove — WinUI-reliable Button -->
                                                        <Button Grid.Column="5" Text="×"
                                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.RemoveLineItemCommand}"
                                                                CommandParameter="{Binding .}"
                                                                BackgroundColor="Transparent"
                                                                TextColor="{StaticResource Error}"
                                                                FontFamily="PoppinsMedium" FontSize="16"
                                                                BorderWidth="0" HeightRequest="36"
                                                                Padding="0" />
                                                    </Grid>
                                                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                </VerticalStackLayout>
                            </ScrollView>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- ── C. Adjustments & VAT ─────────────────────────────── -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="ADJUSTMENTS &amp; CHARGES" Style="{StaticResource LabelSection}" Margin="0,0,0,8" />

                            <!-- VAT mode row + description helper -->
                            <Grid ColumnDefinitions="150,*" ColumnSpacing="12" Padding="0,5">
                                <Label Grid.Column="0" Text="VAT Mode"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding VatModeDisplayOptions}"
                                        SelectedItem="{Binding CreateVatModeDisplay, Mode=TwoWay}"
                                        TitleColor="{StaticResource TextSecondary}"
                                        TextColor="{StaticResource TextPrimary}" />
                            </Grid>
                            <!-- Mode description -->
                            <Label Text="{Binding CreateVatModeDescription}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="#60A5FA" Margin="162,0,0,6"
                                   LineBreakMode="WordWrap" />

                            <!-- VAT rate (% — only when mode is not None) -->
                            <Grid ColumnDefinitions="150,*,Auto" ColumnSpacing="8" Padding="0,3"
                                  IsVisible="{Binding CreateShowVatRate}">
                                <Label Grid.Column="0" Text="VAT Rate"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding CreateVatRatePct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="15"
                                       Style="{StaticResource DarkEntry}" />
                                <Label Grid.Column="2" Text="%"
                                       FontFamily="PoppinsRegular" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" Margin="0,4,0,8" />

                            <!-- Adjustment grid header -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,0,0,4">
                                <Label Grid.Column="1" Text="Amount (R)"
                                       FontFamily="PoppinsMedium" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="Start" />
                                <Label Grid.Column="2" Text="%"
                                       FontFamily="PoppinsMedium" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="Center" />
                            </Grid>

                            <!-- Discount -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Discount (−)"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateDiscount, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding CreateDiscountPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Freight -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Freight / Delivery"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateFreight, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding CreateFreightPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Duty -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Duty"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateDuty, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding CreateDutyPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Levies -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Levies"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateLevies, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding CreateLeviesPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Other Charges -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Other Charges"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding CreateOtherCharges, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding CreateOtherChargesPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- ── D. Totals summary panel ───────────────────────────── -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16" BackgroundColor="{StaticResource SurfaceElevated}">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="TOTALS" Style="{StaticResource LabelSection}" Margin="0,0,0,8" />

                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Line Items Subtotal"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding CreateLineSubtotalDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Discount"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="#F87171" />
                                <Label Grid.Column="1" Text="{Binding CreateDiscountLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="#F87171"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Freight / Delivery"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding CreateFreightLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Duty"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding CreateDutyLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Levies"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding CreateLeviesLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Other Charges"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding CreateOtherChargesLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,4" />

                            <Grid ColumnDefinitions="*,Auto" Padding="0,5">
                                <Label Grid.Column="0" Text="Taxable Amount"
                                       FontFamily="PoppinsMedium" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Column="1" Text="{Binding CreateTaxableDisplay}"
                                       FontFamily="PoppinsMedium" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4"
                                  IsVisible="{Binding CreateShowVatRate}">
                                <Label Grid.Column="0" Text="{Binding CreateVatLabel}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding CreateVatAmountDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <BoxView HeightRequest="2" Color="{StaticResource Primary}" Opacity="0.4" Margin="0,6" />

                            <!-- Grand total — highlighted -->
                            <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                                   BorderColor="Transparent" BackgroundColor="#1E3A5F">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="GRAND TOTAL"
                                           FontFamily="PoppinsSemiBold" FontSize="15"
                                           TextColor="#FFFFFF" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding CreateGrandTotalDisplay}"
                                           FontFamily="PoppinsBold" FontSize="18"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalTextAlignment="End" VerticalOptions="Center" />
                                </Grid>
                            </Frame>

                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ── QUOTES: Upload form ────────────────────────────────────── -->
            <ScrollView Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding IsUploadQuoteView}">
                <VerticalStackLayout Padding="16,10,16,24" Spacing="14">

                    <!-- Error banner -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#7F1D1D" BackgroundColor="#2D0A0A"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}">
                        <Label Text="{Binding ErrorMessage}" FontFamily="PoppinsRegular"
                               FontSize="12" TextColor="#FCA5A5" LineBreakMode="WordWrap" />
                    </Frame>

                    <!-- Header bar -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="UPLOAD QUOTE"
                               Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Cancel"
                                Command="{Binding BackToQuoteListCommand}"
                                BackgroundColor="#1E293B" TextColor="#94A3B8"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0" />
                        <Button Grid.Column="2" Text="Submit to HR"
                                Command="{Binding SubmitUploadedQuoteCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                    </Grid>

                    <!-- ── All fields in one labeled-row card ────────────────── -->
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <VerticalStackLayout Spacing="0">

                            <!-- File picker row -->
                            <Label Text="DOCUMENT" Style="{StaticResource LabelSection}" Margin="0,0,0,10" />
                            <Grid ColumnDefinitions="150,*,Auto" ColumnSpacing="12" Padding="0,5">
                                <Label Grid.Column="0" Text="Quote Document *"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding PickedQuoteFileName}"
                                       FontFamily="PoppinsRegular" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                <Button Grid.Column="2" Text="Choose File"
                                        Command="{Binding PickQuoteFileCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsMedium" FontSize="11"
                                        CornerRadius="6" Padding="10,0" HeightRequest="32" BorderWidth="0" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" Margin="0,6" />

                            <!-- Quote details -->
                            <Label Text="QUOTE DETAILS" Style="{StaticResource LabelSection}" Margin="0,4,0,10" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Quote Title *"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadTitle, Mode=TwoWay}"
                                       Placeholder="e.g. Maintenance Contract Oct 2026"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Description"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadDescription, Mode=TwoWay}"
                                       Placeholder="Brief description (optional)"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Quote Reference"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadQuoteNumber, Mode=TwoWay}"
                                       Placeholder="Your reference number (optional)"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Valid Until"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadValidUntilText, Mode=TwoWay}"
                                       Placeholder="dd/MM/yyyy"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Notes"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Start"
                                       Margin="0,8,0,0" />
                                <Editor Grid.Column="1" Text="{Binding UploadNotes, Mode=TwoWay}"
                                        Placeholder="Additional notes (optional)"
                                        AutoSize="TextChanges" MinimumHeightRequest="48"
                                        TextColor="{StaticResource TextPrimary}"
                                        PlaceholderColor="{StaticResource TextSecondary}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" Margin="0,6" />

                            <!-- Amount and VAT -->
                            <Label Text="AMOUNT &amp; VAT" Style="{StaticResource LabelSection}" Margin="0,4,0,8" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{Binding UploadAmountLabel}"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadAmountText, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />

                            <Grid ColumnDefinitions="150,*" Padding="0,5" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="VAT Mode"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding VatModeDisplayOptions}"
                                        SelectedItem="{Binding UploadVatModeDisplay, Mode=TwoWay}"
                                        TitleColor="{StaticResource TextSecondary}"
                                        TextColor="{StaticResource TextPrimary}" />
                            </Grid>
                            <!-- Mode description -->
                            <Label Text="{Binding UploadVatModeDescription}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="#60A5FA" Margin="162,0,0,6"
                                   LineBreakMode="WordWrap" />

                            <Grid ColumnDefinitions="150,*,Auto" ColumnSpacing="8" Padding="0,3"
                                  IsVisible="{Binding UploadShowVatRate}">
                                <Label Grid.Column="0" Text="VAT Rate"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Text="{Binding UploadVatRatePct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="15"
                                       Style="{StaticResource DarkEntry}" />
                                <Label Grid.Column="2" Text="%"
                                       FontFamily="PoppinsRegular" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" Margin="0,4,0,8" />

                            <!-- Adjustments header -->
                            <Label Text="ADJUSTMENTS &amp; CHARGES" Style="{StaticResource LabelSection}" Margin="0,4,0,4" />
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,0,0,4">
                                <Label Grid.Column="1" Text="Amount (R)"
                                       FontFamily="PoppinsMedium" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="Start" />
                                <Label Grid.Column="2" Text="%"
                                       FontFamily="PoppinsMedium" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="Center" />
                            </Grid>

                            <!-- Discount -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Discount (−)"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadDiscount, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding UploadDiscountPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Freight -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Freight / Delivery"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadFreight, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding UploadFreightPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Duty -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Duty"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadDuty, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding UploadDutyPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Levies -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Levies"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadLevies, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding UploadLeviesPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />

                            <!-- Other Charges -->
                            <Grid ColumnDefinitions="150,*,84" ColumnSpacing="8" Padding="0,3">
                                <Label Grid.Column="0" Text="Other Charges"
                                       FontFamily="PoppinsMedium" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Entry Grid.Column="1" Text="{Binding UploadOtherCharges, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                                <Entry Grid.Column="2" Text="{Binding UploadOtherChargesPct, Mode=TwoWay}"
                                       Keyboard="Numeric" Placeholder="0.00"
                                       Style="{StaticResource DarkEntry}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" Margin="0,6" />

                            <!-- Computed totals -->
                            <Label Text="TOTALS" Style="{StaticResource LabelSection}" Margin="0,4,0,8" />

                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Base Amount"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding UploadAmountText, StringFormat='R{0}'}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Discount"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="#F87171" />
                                <Label Grid.Column="1" Text="{Binding UploadDiscountLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="#F87171"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Freight / Delivery"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding UploadFreightLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Duty"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding UploadDutyLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Levies"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding UploadLeviesLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Other Charges"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding UploadOtherChargesLineDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,4" />

                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0" Text="Taxable Amount"
                                       FontFamily="PoppinsMedium" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Column="1" Text="{Binding UploadTaxableDisplay}"
                                       FontFamily="PoppinsMedium" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4"
                                  IsVisible="{Binding UploadShowVatRate}">
                                <Label Grid.Column="0" Text="VAT"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Column="1" Text="{Binding UploadVatDisplay}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                            <BoxView HeightRequest="2" Color="{StaticResource Primary}" Opacity="0.4" Margin="0,6" />
                            <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                                   BorderColor="Transparent" BackgroundColor="#1E3A5F">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="TOTAL"
                                           FontFamily="PoppinsSemiBold" FontSize="15"
                                           TextColor="#FFFFFF" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding UploadTotalDisplay}"
                                           FontFamily="PoppinsBold" FontSize="18"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalTextAlignment="End" VerticalOptions="Center" />
                                </Grid>
                            </Frame>

                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ── QUOTES: Detail view ────────────────────────────────────── -->
            <ScrollView Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding IsQuoteDetailView}">
                <VerticalStackLayout Padding="16,10,16,20" Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="QUOTE DETAILS" Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="← Back"
                                Command="{Binding BackToQuoteListCommand}"
                                BackgroundColor="#1E293B" TextColor="#94A3B8"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="34" BorderWidth="0" />
                    </Grid>
                    <!-- Quote header card -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding SelectedQuote.Title}"
                                       FontFamily="PoppinsSemiBold" FontSize="16"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Frame Grid.Column="1" CornerRadius="6" Padding="8,3"
                                       HasShadow="False" BorderColor="Transparent"
                                       BackgroundColor="{Binding SelectedQuote.StatusBadgeBg}"
                                       VerticalOptions="Center">
                                    <Label Text="{Binding SelectedQuote.StatusLabel}"
                                           FontFamily="PoppinsMedium" FontSize="10"
                                           TextColor="{Binding SelectedQuote.StatusBadgeFg}" />
                                </Frame>
                            </Grid>
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">
                                <Label Grid.Row="0" Grid.Column="0" Text="Quote #"     Style="{StaticResource Caption}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedQuote.QuoteNumberDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="1" Grid.Column="0" Text="Quote Date"  Style="{StaticResource Caption}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedQuote.QuoteDateDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Valid Until" Style="{StaticResource Caption}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedQuote.ValidUntilDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="3" Grid.Column="0" Text="Type"        Style="{StaticResource Caption}" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedQuote.SourceLabel}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                    <!-- Revision comments (revision_requested) — contractor action needed -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#92400E" BackgroundColor="#1C0F00"
                           IsVisible="{Binding SelectedQuote.IsRevisionRequested}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="↩ Revision Requested by HR"
                                   FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FDBA74" />
                            <Label Text="{Binding SelectedQuote.RevisionComments}"
                                   FontFamily="PoppinsRegular" FontSize="12"
                                   TextColor="#FEF3C7" LineBreakMode="WordWrap" />
                            <Label Text="{Binding SelectedQuote.ReviewedAtDisplay, StringFormat='Requested: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                            <!-- Action buttons for revision_requested -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4,0,0">
                                <Button Grid.Column="0" Text="Edit Quote"
                                        Command="{Binding EditDraftCommand}"
                                        CommandParameter="{Binding SelectedQuote}"
                                        BackgroundColor="#1E293B" TextColor="#94A3B8"
                                        FontFamily="PoppinsMedium" FontSize="12"
                                        CornerRadius="8" HeightRequest="36" BorderWidth="0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                                <Button Grid.Column="1" Text="Resubmit to HR"
                                        Command="{Binding ResubmitQuoteCommand}"
                                        CommandParameter="{Binding SelectedQuote}"
                                        BackgroundColor="#FDBA74" TextColor="#1C0F00"
                                        FontFamily="PoppinsSemiBold" FontSize="12"
                                        CornerRadius="8" HeightRequest="36" BorderWidth="0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Rejection reason (if rejected) -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#7F1D1D" BackgroundColor="#1A0707"
                           IsVisible="{Binding SelectedQuote.IsRejected}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="✕ Quote Not Approved" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FCA5A5" />
                            <Label Text="{Binding SelectedQuote.RejectionReason}" FontFamily="PoppinsRegular" FontSize="12" TextColor="#FDE8E8" LineBreakMode="WordWrap" />
                            <Label Text="{Binding SelectedQuote.ReviewedAtDisplay, StringFormat='Rejected: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Approved banner -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#14532D" BackgroundColor="#071A0F"
                           IsVisible="{Binding SelectedQuote.IsApproved}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="✓ Quote Approved" FontFamily="PoppinsMedium" FontSize="12" TextColor="#22C55E" />
                            <Label Text="{Binding SelectedQuote.ReviewedAtDisplay, StringFormat='Approved: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Linked to Job banner (Phase 2D.4 / 2D.5) -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#1E3A5F" BackgroundColor="#050F1E"
                           IsVisible="{Binding SelectedQuote.IsConverted}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="⚡ Quote Linked to Job"
                                   FontFamily="PoppinsSemiBold" FontSize="12" TextColor="#60A5FA" />
                            <Label Text="This quote has been accepted and linked to a job by your HR team."
                                   FontFamily="PoppinsRegular" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"
                                   LineBreakMode="WordWrap" />
                            <Label Text="{Binding SelectedQuote.ConvertedAtDisplay, StringFormat='Linked: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Line items (manual quotes) -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14"
                           IsVisible="{Binding SelectedQuote.IsManual}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="LINE ITEMS" Style="{StaticResource LabelSection}" />
                            <CollectionView ItemsSource="{Binding SelectedQuote.Items}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorQuoteItem">
                                        <VerticalStackLayout Spacing="0">
                                            <Grid ColumnDefinitions="*,Auto" Padding="0,6">
                                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                                    <Label Text="{Binding Description}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                                                    <Label Text="{Binding Quantity, StringFormat='Qty: {0:F2}  ×  R{1:N2}'}" FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1" Text="{Binding LineTotalDisplay}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                            </Grid>
                                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.3" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <!-- Totals -->
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3" Margin="0,4,0,0">
                                <Label Grid.Row="0" Grid.Column="0" Text="Subtotal" Style="{StaticResource Caption}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedQuote.SubtotalDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="1" Grid.Column="0" Text="VAT" Style="{StaticResource Caption}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedQuote.VatDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Total" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedQuote.TotalDisplay}" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource Primary}" HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                    <!-- Attachment (upload quotes) -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14"
                           IsVisible="{Binding SelectedQuote.IsUpload}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="UPLOADED DOCUMENT" Style="{StaticResource LabelSection}" />
                            <CollectionView ItemsSource="{Binding SelectedQuote.Attachments}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorQuoteAttachment">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                            <Label Grid.Column="0" Text="{Binding FileName}"
                                                   FontFamily="PoppinsRegular" FontSize="12"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Button Grid.Column="1" Text="Open"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.ViewQuoteDocumentCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    CornerRadius="6" Padding="10,0" HeightRequest="30" BorderWidth="0" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <!-- Financial summary for upload quotes -->
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                                <Label Grid.Row="0" Grid.Column="0" Text="Subtotal" Style="{StaticResource Caption}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedQuote.SubtotalDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="1" Grid.Column="0" Text="VAT" Style="{StaticResource Caption}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedQuote.VatDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Total" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedQuote.TotalDisplay}" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource Primary}" HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>

    </Grid>
</ContentPage>
