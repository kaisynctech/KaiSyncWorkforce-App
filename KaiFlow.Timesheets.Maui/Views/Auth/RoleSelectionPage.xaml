<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Auth.RoleSelectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Auth"
    x:DataType="vm:RoleSelectionViewModel"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="Select Role">

    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">
        <Label Text="Continue as" Style="{StaticResource HeadlineMedium}" HorizontalOptions="Center" />
        <Button Text="Employee" Command="{Binding SelectEmployeeCommand}" Style="{StaticResource PrimaryButton}" />
        <Button Text="HR / Manager" Command="{Binding SelectHrCommand}" Style="{StaticResource OutlinedButton}" />
    </VerticalStackLayout>
</ContentPage>
