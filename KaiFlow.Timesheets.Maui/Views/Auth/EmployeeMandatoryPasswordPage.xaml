<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Auth.EmployeeMandatoryPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Auth"
    x:DataType="vm:EmployeeMandatoryPasswordViewModel"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="Set Your Password"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,48" Spacing="24" VerticalOptions="Center">

            <Label Text="Set Your Password"
                   Style="{StaticResource HeadlineLarge}"
                   HorizontalOptions="Center" />

            <Label Text="You need to set a password before you can sign in with email next time."
                   Style="{StaticResource BodyMedium}"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center" />

            <!-- Password field -->
            <Frame Style="{StaticResource CardFrame}">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0"
                           Text="{Binding Password}"
                           Placeholder="Password (min. 8 characters)"
                           IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                           PlaceholderColor="{StaticResource TextSecondary}"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="Transparent" />
                    <Button Grid.Column="1"
                            Text="{Binding IsPasswordVisible, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Hide|Show'}"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            Style="{StaticResource TextButton}" FontSize="12" />
                </Grid>
            </Frame>

            <!-- Confirm password -->
            <Frame Style="{StaticResource CardFrame}">
                <Entry Text="{Binding ConfirmPassword}"
                       Placeholder="Confirm password"
                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                       PlaceholderColor="{StaticResource TextSecondary}"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="Transparent" />
            </Frame>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

            <Button Text="Set Password"
                    Command="{Binding SetPasswordCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    Style="{StaticResource PrimaryButton}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
