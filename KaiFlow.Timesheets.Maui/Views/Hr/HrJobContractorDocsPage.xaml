<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrJobContractorDocsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:HrJobContractorDocsViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Subtitle (job title) -->
            <Label Text="{Binding SubTitle}"
                   FontSize="13" TextColor="{StaticResource TextSecondary}"
                   IsVisible="{Binding SubTitle, Converter={StaticResource IsNotNullConverter}}" />

            <!-- Error banner -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#FCA5A5" FontSize="13" FontFamily="PoppinsSemiBold"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

            <!-- Main card -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">

                    <!-- Section header -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Text="ASSIGNMENT DOCUMENTS"
                               Style="{StaticResource LabelSection}"
                               VerticalOptions="Center" />
                        <ActivityIndicator Grid.Column="1"
                                           IsRunning="{Binding IsDocsBusy}"
                                           IsVisible="{Binding IsDocsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="24" WidthRequest="24"
                                           VerticalOptions="Center" />
                        <Button Grid.Column="2"
                                Text="Upload"
                                Command="{Binding UploadDocCommand}"
                                IsEnabled="{Binding IsDocsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="12" HeightRequest="36" Padding="14,6" />
                    </Grid>

                    <!-- Document type picker -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Text="Type:"
                               FontSize="12" TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding DocumentTypeLabels}"
                                SelectedItem="{Binding SelectedDocTypeLabel}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent" />
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource Divider}" />

                    <!-- Documents list -->
                    <CollectionView ItemsSource="{Binding Docs}">
                        <CollectionView.EmptyView>
                            <Label Text="No documents uploaded yet."
                                   Style="{StaticResource EmptyState}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:JobContractorDocument">
                                <Grid ColumnDefinitions="30,*,Auto,Auto"
                                      Padding="0,6" ColumnSpacing="8">

                                    <!-- Type icon -->
                                    <Label Text="{Binding TypeIcon}"
                                           FontSize="18"
                                           VerticalOptions="Center" />

                                    <!-- Name + type + date -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding DocumentName}"
                                               FontFamily="PoppinsSemiBold" FontSize="13"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding TypeLabel}"
                                               FontSize="11"
                                               TextColor="{StaticResource Primary}" />
                                        <Label Text="{Binding CreatedDisplay}"
                                               FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>

                                    <!-- Open button -->
                                    <Button Grid.Column="2"
                                            Text="Open"
                                            Command="{Binding Source={x:Reference Self}, Path=BindingContext.OpenDocCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource OutlinedButton}"
                                            FontSize="11" HeightRequest="32" Padding="10,4" />

                                    <!-- Delete button -->
                                    <Button Grid.Column="3"
                                            Text="✕"
                                            Command="{Binding Source={x:Reference Self}, Path=BindingContext.DeleteDocCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource TextSecondary}"
                                            FontSize="12"
                                            HeightRequest="32" WidthRequest="36"
                                            Padding="0" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
