<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrContractorDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:HrContractorDetailsViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="">

    <!-- Phase 2C: Tab-based workspace.
         Row 0 = header (title + Save)
         Row 1 = tab bar
         Row 2 = tab panels (all same cell; IsVisible controls which is visible) -->
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,12,16,4" ColumnSpacing="12">
            <Label Text="{Binding Title}" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Save" Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    FontFamily="PoppinsSemiBold" FontSize="16"
                    CornerRadius="8" Padding="20,0" HeightRequest="44" MinimumWidthRequest="96" />
        </Grid>

        <!-- ── Tab bar ─────────────────────────────────────────────────────── -->
        <!-- Horizontal-scrollable so 7 tabs fit on any screen width.
             WinUI note: Buttons reliably fire Command; TapGestureRecognizer on Frame does not. -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="6" Padding="16,8,16,4">
                <Button Text="Information"
                        Command="{Binding ShowInformationTabCommand}"
                        BackgroundColor="{Binding IsInformationTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsInformationTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Compliance"
                        Command="{Binding ShowComplianceTabCommand}"
                        BackgroundColor="{Binding IsComplianceTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsComplianceTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Payments"
                        Command="{Binding ShowPaymentsTabCommand}"
                        BackgroundColor="{Binding IsPaymentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsPaymentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Team"
                        Command="{Binding ShowTeamTabCommand}"
                        BackgroundColor="{Binding IsTeamTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsTeamTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <!-- Phase 2D.5: operational tabs -->
                <Button Text="Jobs"
                        Command="{Binding ShowJobsTabCommand}"
                        BackgroundColor="{Binding IsJobsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsJobsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Projects"
                        Command="{Binding ShowProjectsTabCommand}"
                        BackgroundColor="{Binding IsProjectsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsProjectsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Incidents"
                        Command="{Binding ShowIncidentsTabCommand}"
                        BackgroundColor="{Binding IsIncidentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                        TextColor="{Binding IsIncidentsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Activity"
                        Command="{Binding ShowActivityTabCommand}"
                        BackgroundColor="{Binding IsActivityTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsActivityTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Quotes"
                        Command="{Binding ShowQuotesTabCommand}"
                        BackgroundColor="{Binding IsQuotesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsQuotesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                <Button Text="Invoices"
                        Command="{Binding ShowInvoicesTabCommand}"
                        BackgroundColor="{Binding IsInvoicesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                        TextColor="{Binding IsInvoicesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 1: INFORMATION                                                 -->
        <!-- Company details · Tax & ID · Portal code · Contact · Notes        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsInformationTab}">
            <VerticalStackLayout Padding="16,0,16,24" Spacing="16"
                                 IsVisible="{Binding Contractor, Converter={StaticResource IsNotNullConverter}}">

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="COMPANY DETAILS" Style="{StaticResource LabelSection}" />
                        <Entry Placeholder="Company / trading name *" Text="{Binding Contractor.Name, Mode=TwoWay}" Style="{StaticResource DarkEntry}" />
                        <Picker Title="Partner type" ItemsSource="{Binding PartnerKindLabels}"
                                SelectedItem="{Binding SelectedPartnerKindLabel, Mode=TwoWay}"
                                TitleColor="{StaticResource TextSecondary}" TextColor="{StaticResource TextPrimary}" />
                        <Entry Placeholder="Registration number" Text="{Binding Contractor.RegistrationNumber, Mode=TwoWay}" Style="{StaticResource DarkEntry}" />

                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding Contractor.HasContractorCode}">
                            <Label Text="{Binding Contractor.ContractorCode, StringFormat='Code: {0}'}"
                                   Style="{StaticResource BodyMedium}" VerticalOptions="Center"
                                   TextColor="{StaticResource Primary}" FontFamily="PoppinsSemiBold" />
                            <Label Grid.Column="1" Text="auto-generated" Style="{StaticResource Caption}" VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto">
                            <Label Text="Rating" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding ContractorRating, StringFormat='★ {0:F1}'}"
                                   Style="{StaticResource BodyMedium}" VerticalOptions="Center" Margin="0,0,8,0"
                                   TextColor="{StaticResource Primary}" />
                            <Stepper Grid.Column="2"
                                     Value="{Binding ContractorRating, Mode=TwoWay}"
                                     Minimum="0" Maximum="5" Increment="0.5"
                                     VerticalOptions="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Active" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding Contractor.IsActive, Mode=TwoWay}" OnColor="{StaticResource Primary}" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="TAX &amp; IDENTIFICATION" Style="{StaticResource LabelSection}" />
                        <Entry Placeholder="Tax number (SARS income tax ref.)"
                               Text="{Binding Contractor.TaxNumber, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="VAT Registered" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding IsVatRegistered, Mode=TwoWay}" OnColor="{StaticResource Primary}" />
                        </Grid>
                        <Entry Placeholder="VAT number"
                               Text="{Binding Contractor.VatNumber, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}"
                               IsEnabled="{Binding IsVatRegistered}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding ShowPortalCodeSection}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="CONTRACTOR PORTAL CODE" Style="{StaticResource LabelSection}" />
                        <Label Text="Share with the subcontractor team — one code for sign-in, site time, photos, and messages."
                               FontSize="11" TextColor="{StaticResource TextSecondary}" />
                        <Entry Placeholder="Auto-generated" Text="{Binding Contractor.ContractorCode, Mode=TwoWay}" Style="{StaticResource DarkEntry}" />
                        <Button Text="Generate code" Command="{Binding GenerateContractorCodeCommand}" Style="{StaticResource SecondaryButton}" FontSize="12" />
                        <Button Text="Rotate portal code"
                                Command="{Binding RotateContractorCodeCommand}"
                                IsVisible="{Binding Contractor.HasContractorCode}"
                                BackgroundColor="{StaticResource SurfaceDark}" TextColor="#F59E0B"
                                CornerRadius="8" HeightRequest="40" FontSize="12" />
                        <Label FontSize="11" TextColor="{StaticResource TextSecondary}"
                               IsVisible="{Binding Contractor.ContractorCodeExpiresAt, Converter={StaticResource IsNotNullConverter}}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Expires: " />
                                    <Span Text="{Binding Contractor.ContractorCodeExpiresAt, StringFormat='{0:dd MMM yyyy}'}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="CONTACT" Style="{StaticResource LabelSection}" />
                        <Entry Placeholder="Contact person" Text="{Binding Contractor.ContactPerson, Mode=TwoWay}" Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Phone" Text="{Binding Contractor.Phone, Mode=TwoWay}" Keyboard="Telephone" Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Email" Text="{Binding Contractor.Email, Mode=TwoWay}" Keyboard="Email" Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Address" Text="{Binding Contractor.Address, Mode=TwoWay}" Style="{StaticResource DarkEntry}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="NOTES" Style="{StaticResource LabelSection}" />
                        <Editor Placeholder="Internal notes about this contractor"
                                Text="{Binding Contractor.Notes, Mode=TwoWay}"
                                AutoSize="TextChanges" MinimumHeightRequest="72"
                                TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 2: COMPLIANCE                                                  -->
        <!-- Pack assignment · Checklist · Overview · Documents table          -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsComplianceTab}">
            <VerticalStackLayout Padding="16,0,16,24" Spacing="16">

                <!-- New-contractor guard -->
                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding IsNew}">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="18"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        <Label Text="Save the contractor on the Information tab first to access compliance documents."
                               FontFamily="PoppinsRegular" FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" LineBreakMode="WordWrap" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- ── Phase 2B.3b: Compliance Pack Assignment Card ── -->
                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding ShowDocumentsSection}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="COMPLIANCE PACK" Style="{StaticResource LabelSection}" />
                        <Picker Title="Select compliance pack"
                                ItemsSource="{Binding PackLabels}"
                                SelectedItem="{Binding SelectedPackLabel, Mode=TwoWay}"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}"
                                FontFamily="PoppinsRegular" FontSize="13" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" IsVisible="{Binding HasPackAssigned}">
                            <Frame Grid.Column="0" CornerRadius="8" Padding="0,10" HasShadow="False" BorderColor="Transparent" BackgroundColor="#1E293B">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PackRequiredCount}" FontFamily="PoppinsSemiBold" FontSize="20" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                                    <Label Text="Required" FontFamily="PoppinsRegular" FontSize="10" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="1" CornerRadius="8" Padding="0,10" HasShadow="False" BorderColor="Transparent" BackgroundColor="#14532D">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PackCompleteCount}" FontFamily="PoppinsSemiBold" FontSize="20" TextColor="#22C55E" HorizontalTextAlignment="Center" />
                                    <Label Text="Complete" FontFamily="PoppinsRegular" FontSize="10" TextColor="#4ADE80" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="2" CornerRadius="8" Padding="0,10" HasShadow="False" BorderColor="Transparent" BackgroundColor="#2D0A0A">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding PackMissingCount}" FontFamily="PoppinsSemiBold" FontSize="20" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                    <Label Text="Missing" FontFamily="PoppinsRegular" FontSize="10" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                        <Label Text="Assign a compliance pack to enable pack-based scoring and a required document checklist. Use Save to persist the selection."
                               FontFamily="PoppinsRegular" FontSize="12"
                               TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap"
                               IsVisible="{Binding HasPackAssigned, Converter={StaticResource InverseBoolConverter}}" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Phase 2B.3b: Required Documents Checklist ── -->
                <Frame Style="{StaticResource CardFrame}"
                       IsVisible="{Binding PackChecklistRows.Count, Converter={StaticResource IsNotZeroConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="REQUIRED DOCUMENTS CHECKLIST" Style="{StaticResource LabelSection}" />
                        <Label Text="Based on the assigned compliance pack. Required rows (Req.) count toward the compliance score."
                               FontFamily="PoppinsRegular" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" />
                        <CollectionView ItemsSource="{Binding PackChecklistRows}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:PackChecklistRow">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="4,8" ColumnSpacing="10">
                                            <Frame Grid.Column="0" CornerRadius="6" Padding="6,2" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding RequirementBg}" VerticalOptions="Center">
                                                <Label Text="{Binding RequirementLabel}" FontFamily="PoppinsMedium" FontSize="9" TextColor="{Binding RequirementFg}" />
                                            </Frame>
                                            <Label Grid.Column="1" Text="{Binding TypeLabel}" FontFamily="PoppinsRegular" FontSize="12"
                                                   TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="2" Text="{Binding ExpiryDisplay}" FontFamily="PoppinsRegular" FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" IsVisible="{Binding ShowExpiry}" />
                                            <Frame Grid.Column="3" CornerRadius="8" Padding="8,3" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="{Binding StatusBadgeBg}" VerticalOptions="Center">
                                                <Label Text="{Binding StatusLabel}" FontFamily="PoppinsMedium" FontSize="10" TextColor="{Binding StatusBadgeFg}" />
                                            </Frame>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Phase 2B.2: Compliance Overview Card ── -->
                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding ShowDocumentsSection}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="COMPLIANCE OVERVIEW" Style="{StaticResource LabelSection}" />
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding CompScorePercent, StringFormat='{0}%'}" FontFamily="PoppinsBold" FontSize="30" TextColor="{Binding CompScoreColor}" />
                                <Label Text="{Binding CompRequiredValidLabel, StringFormat='({0} required)'}" FontFamily="PoppinsRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <ProgressBar Progress="{Binding CompScoreProgress}"
                                             ProgressColor="{Binding CompScoreColor, Converter={StaticResource HexToColorConverter}}"
                                             BackgroundColor="#1E293B" HeightRequest="10" />
                                <Label Text="Required documents valid" FontFamily="PoppinsRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Frame Grid.Column="2" CornerRadius="8" Padding="10,6" HasShadow="False" BorderColor="Transparent"
                                   BackgroundColor="{Binding CompStatusBadgeBg}" VerticalOptions="Center">
                                <Label Text="{Binding CompStatusLabel}" FontFamily="PoppinsMedium" FontSize="12" TextColor="{Binding CompStatusBadgeFg}" />
                            </Frame>
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                            <Frame Grid.Column="0" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#0F2918">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding CompValidRequired}" FontFamily="PoppinsSemiBold" FontSize="18" TextColor="#22C55E" HorizontalTextAlignment="Center" />
                                    <Label Text="Valid" FontFamily="PoppinsRegular" FontSize="10" TextColor="#4ADE80" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="1" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#292012">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding CompExpiringRequired}" FontFamily="PoppinsSemiBold" FontSize="18" TextColor="#FCD34D" HorizontalTextAlignment="Center" />
                                    <Label Text="Expiring" FontFamily="PoppinsRegular" FontSize="10" TextColor="#FCD34D" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="2" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#2D0A0A">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding CompExpiredRequired}" FontFamily="PoppinsSemiBold" FontSize="18" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                    <Label Text="Expired" FontFamily="PoppinsRegular" FontSize="10" TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="3" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#1E293B">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding CompPendingRequired}" FontFamily="PoppinsSemiBold" FontSize="18" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                                    <Label Text="Pending" FontFamily="PoppinsRegular" FontSize="10" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="4" CornerRadius="8" Padding="0,8" HasShadow="False" BorderColor="Transparent" BackgroundColor="#2D0F0F">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding CompRejectedRequired}" FontFamily="PoppinsSemiBold" FontSize="18" TextColor="#F87171" HorizontalTextAlignment="Center" />
                                    <Label Text="Rejected" FontFamily="PoppinsRegular" FontSize="10" TextColor="#F87171" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                        <Frame CornerRadius="8" Padding="12,10" HasShadow="False" BorderColor="#334155" BackgroundColor="#0F172A"
                               IsVisible="{Binding CompHasRequiredDocs, Converter={StaticResource InverseBoolConverter}}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="16" TextColor="#64748B" VerticalOptions="Center" />
                                <Label Text="No required documents flagged. Upload documents and mark them 'Required' to enable compliance scoring."
                                       FontFamily="PoppinsRegular" FontSize="12" TextColor="#64748B" LineBreakMode="WordWrap" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                        <Frame CornerRadius="8" Padding="12,10" HasShadow="False" BorderColor="#7F1D1D" BackgroundColor="#2D0A0A"
                               IsVisible="{Binding CompExpiredRequired, Converter={StaticResource IsNotZeroConverter}}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xE002;" FontFamily="MaterialIcons" FontSize="16" TextColor="#FCA5A5" VerticalOptions="Center" />
                                <Label Text="{Binding CompExpiredRequired, StringFormat='{0} required document(s) have expired — consider enabling Compliance Hold.'}"
                                       FontFamily="PoppinsRegular" FontSize="12" TextColor="#FCA5A5" LineBreakMode="WordWrap" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                        <Frame CornerRadius="8" Padding="12,10" HasShadow="False" BorderColor="#78350F" BackgroundColor="#292012"
                               IsVisible="{Binding CompPendingRequired, Converter={StaticResource IsNotZeroConverter}}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="16" TextColor="#FCD34D" VerticalOptions="Center" />
                                <Label Text="{Binding CompPendingRequired, StringFormat='{0} required document(s) awaiting HR approval.'}"
                                       FontFamily="PoppinsRegular" FontSize="12" TextColor="#FCD34D" LineBreakMode="WordWrap" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                        <Frame CornerRadius="8" Padding="12,10" HasShadow="False" BorderColor="#7F1D1D" BackgroundColor="#2D0F0F"
                               IsVisible="{Binding CompRejectedRequired, Converter={StaticResource IsNotZeroConverter}}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xE897;" FontFamily="MaterialIcons" FontSize="16" TextColor="#F87171" VerticalOptions="Center" />
                                <Label Text="{Binding CompRejectedRequired, StringFormat='{0} required document(s) have been rejected and need to be re-uploaded.'}"
                                       FontFamily="PoppinsRegular" FontSize="12" TextColor="#F87171" LineBreakMode="WordWrap" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                        <VerticalStackLayout Spacing="6"
                            IsVisible="{Binding ExpiringDocuments.Count, Converter={StaticResource IsNotZeroConverter}}">
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" />
                            <Label Text="EXPIRING WITHIN 30 DAYS" Style="{StaticResource LabelSection}" />
                            <CollectionView ItemsSource="{Binding ExpiringDocuments}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorDocument">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="4,5" ColumnSpacing="8">
                                            <Frame Grid.Column="0" CornerRadius="4" Padding="4,2" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="#450A0A" VerticalOptions="Center" IsVisible="{Binding IsRequired}">
                                                <Label Text="Req." FontFamily="PoppinsMedium" FontSize="9" TextColor="#FCA5A5" />
                                            </Frame>
                                            <Label Grid.Column="1" Text="{Binding DocumentName}" FontFamily="PoppinsRegular" FontSize="12"
                                                   TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="2" Text="{Binding ExpiryDisplay}" FontFamily="PoppinsMedium" FontSize="11"
                                                   TextColor="{Binding ExpiryWarningFg}" VerticalOptions="Center" />
                                            <Label Grid.Column="3" Text="&#xE002;" FontFamily="MaterialIcons" FontSize="14"
                                                   TextColor="{Binding ExpiryWarningFg}" VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6"
                            IsVisible="{Binding ExpiredDocuments.Count, Converter={StaticResource IsNotZeroConverter}}">
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" />
                            <Label Text="EXPIRED DOCUMENTS" Style="{StaticResource LabelSection}" />
                            <CollectionView ItemsSource="{Binding ExpiredDocuments}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorDocument">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,5" ColumnSpacing="8">
                                            <Frame Grid.Column="0" CornerRadius="4" Padding="4,2" HasShadow="False" BorderColor="Transparent"
                                                   BackgroundColor="#450A0A" VerticalOptions="Center" IsVisible="{Binding IsRequired}">
                                                <Label Text="Req." FontFamily="PoppinsMedium" FontSize="9" TextColor="#FCA5A5" />
                                            </Frame>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="{Binding DocumentName}" FontFamily="PoppinsRegular" FontSize="12"
                                                       TextColor="#94A3B8" LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding TypeLabel}" FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="#475569" LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding ExpiryDisplay}" FontFamily="PoppinsMedium" FontSize="11"
                                                   TextColor="#FCA5A5" VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Phase 2B.1: Compliance Documents table ── -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowDocumentsSection}">
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Text="COMPLIANCE DOCUMENTS" Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+ Upload"
                                Command="{Binding UploadDocumentCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="12"
                                CornerRadius="8" Padding="14,0" HeightRequest="34" />
                    </Grid>

                    <HorizontalStackLayout Spacing="6" Margin="0,2,0,0">
                        <Grid>
                            <Frame CornerRadius="8" Padding="10,5" HasShadow="False" BorderColor="{Binding FilterBorderAll}" BackgroundColor="#1E293B" InputTransparent="True">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding TotalDocuments}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#CBD5E1" />
                                    <Label Text="Total" FontFamily="PoppinsRegular" FontSize="11" TextColor="#64748B" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Frame>
                            <Button BackgroundColor="Transparent" Text="" Command="{Binding SetDocFilterCommand}" CommandParameter="all"
                                    BorderWidth="0" Padding="0" CornerRadius="8" VerticalOptions="Fill" HorizontalOptions="Fill" />
                        </Grid>
                        <Grid>
                            <Frame CornerRadius="8" Padding="10,5" HasShadow="False" BorderColor="{Binding FilterBorderApproved}" BackgroundColor="#14532D" InputTransparent="True">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding ApprovedDocCount}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#22C55E" />
                                    <Label Text="Approved" FontFamily="PoppinsRegular" FontSize="11" TextColor="#22C55E" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Frame>
                            <Button BackgroundColor="Transparent" Text="" Command="{Binding SetDocFilterCommand}" CommandParameter="approved"
                                    BorderWidth="0" Padding="0" CornerRadius="8" VerticalOptions="Fill" HorizontalOptions="Fill" />
                        </Grid>
                        <Grid>
                            <Frame CornerRadius="8" Padding="10,5" HasShadow="False" BorderColor="{Binding FilterBorderPending}" BackgroundColor="#1E293B" InputTransparent="True">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding PendingDocCount}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#94A3B8" />
                                    <Label Text="Pending" FontFamily="PoppinsRegular" FontSize="11" TextColor="#64748B" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Frame>
                            <Button BackgroundColor="Transparent" Text="" Command="{Binding SetDocFilterCommand}" CommandParameter="pending"
                                    BorderWidth="0" Padding="0" CornerRadius="8" VerticalOptions="Fill" HorizontalOptions="Fill" />
                        </Grid>
                        <Grid>
                            <Frame CornerRadius="8" Padding="10,5" HasShadow="False" BorderColor="{Binding FilterBorderRejected}" BackgroundColor="#7F1D1D" InputTransparent="True">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding RejectedDocCount}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FCA5A5" />
                                    <Label Text="Rejected" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FCA5A5" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Frame>
                            <Button BackgroundColor="Transparent" Text="" Command="{Binding SetDocFilterCommand}" CommandParameter="rejected"
                                    BorderWidth="0" Padding="0" CornerRadius="8" VerticalOptions="Fill" HorizontalOptions="Fill" />
                        </Grid>
                        <Grid>
                            <Frame CornerRadius="8" Padding="10,5" HasShadow="False" BorderColor="{Binding FilterBorderExpired}" BackgroundColor="#450A0A" InputTransparent="True">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding ExpiredDocCount}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FCA5A5" />
                                    <Label Text="Expired" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FCA5A5" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Frame>
                            <Button BackgroundColor="Transparent" Text="" Command="{Binding SetDocFilterCommand}" CommandParameter="expired"
                                    BorderWidth="0" Padding="0" CornerRadius="8" VerticalOptions="Fill" HorizontalOptions="Fill" />
                        </Grid>
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,180" ColumnSpacing="8" Margin="0,4,0,0">
                        <Frame CornerRadius="8" Padding="6,0" HasShadow="False" BorderColor="{StaticResource Divider}" BackgroundColor="{StaticResource SurfaceCard}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Text="&#xE8B6;" FontFamily="MaterialIcons" FontSize="16" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" Margin="4,0,2,0" />
                                <Entry Grid.Column="1" Placeholder="Search documents…"
                                       Text="{Binding DocumentSearch, Mode=TwoWay}"
                                       PlaceholderColor="{StaticResource TextSecondary}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontFamily="PoppinsRegular" FontSize="13"
                                       BackgroundColor="Transparent" HeightRequest="38" />
                            </Grid>
                        </Frame>
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding DocSortOptions}"
                                SelectedItem="{Binding SelectedDocSortLabel, Mode=TwoWay}"
                                Title="Sort by"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}"
                                FontFamily="PoppinsRegular" FontSize="12" />
                    </Grid>

                    <Label Text="{Binding DocEmptyMessage}" Style="{StaticResource EmptyState}" Margin="0,8"
                           IsVisible="{Binding FilteredDocuments.Count, Converter={StaticResource IsZeroConverter}}" />

                    <ScrollView Orientation="Horizontal"
                                IsVisible="{Binding FilteredDocuments.Count, Converter={StaticResource IsNotZeroConverter}}">
                        <VerticalStackLayout WidthRequest="925" Spacing="0">
                            <Frame Style="{StaticResource DataTableFrame}">
                                <Grid ColumnDefinitions="160,175,120,115,65,90,185" Padding="14,9" BackgroundColor="{StaticResource SurfaceElevated}">
                                    <Label Grid.Column="0" Text="Type"          Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="1" Text="Document Name" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="2" Text="Status"        Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="3" Text="Expires"       Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="4" Text="Req."          Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="5" Text="Uploaded"      Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="6" Text="Actions"       Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                </Grid>
                            </Frame>
                            <CollectionView ItemsSource="{Binding FilteredDocuments}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorDocument">
                                        <VerticalStackLayout Spacing="0">
                                            <Grid ColumnDefinitions="160,175,120,115,65,90,185" Padding="14,10" BackgroundColor="{StaticResource SurfaceCard}">
                                                <Label Grid.Column="0" Text="{Binding TypeLabel}" Style="{StaticResource DataTableCellLabel}" FontSize="12" LineBreakMode="TailTruncation" />
                                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                    <Label Text="{Binding DocumentName}" Style="{StaticResource DataTableCellSecondary}" FontSize="12" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding RejectedReason, StringFormat='↳ {0}'}"
                                                           FontFamily="PoppinsRegular" FontSize="10" TextColor="#FCA5A5"
                                                           LineBreakMode="TailTruncation" MaxLines="1" IsVisible="{Binding IsRejected}" />
                                                </VerticalStackLayout>
                                                <Frame Grid.Column="2" CornerRadius="8" Padding="8,4" HasShadow="False" BorderColor="Transparent"
                                                       BackgroundColor="{Binding ApprovalBadgeBg}" HorizontalOptions="Start" VerticalOptions="Center">
                                                    <Label Text="{Binding StatusTableLabel}" FontFamily="PoppinsMedium" FontSize="11" TextColor="{Binding ApprovalBadgeFg}" />
                                                </Frame>
                                                <HorizontalStackLayout Grid.Column="3" Spacing="3" VerticalOptions="Center">
                                                    <Label Text="&#xE002;" FontFamily="MaterialIcons" FontSize="13"
                                                           TextColor="{Binding ExpiryWarningFg}" VerticalOptions="Center" IsVisible="{Binding ShowExpiryWarning}" />
                                                    <Label Text="{Binding ExpiryDisplay}" FontFamily="PoppinsRegular" FontSize="11"
                                                           TextColor="{Binding ExpiryDateColor}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                                <Grid Grid.Column="4" VerticalOptions="Center" HorizontalOptions="Center">
                                                    <Frame CornerRadius="6" Padding="6,3" HasShadow="False" BorderColor="Transparent" BackgroundColor="#450A0A"
                                                           IsVisible="{Binding IsRequired}" HorizontalOptions="Center">
                                                        <Label Text="Req." FontFamily="PoppinsMedium" FontSize="10" TextColor="#FCA5A5" />
                                                    </Frame>
                                                    <Frame CornerRadius="6" Padding="6,3" HasShadow="False" BorderColor="Transparent" BackgroundColor="#1E293B"
                                                           HorizontalOptions="Center"
                                                           IsVisible="{Binding IsRequired, Converter={StaticResource InverseBoolConverter}}">
                                                        <Label Text="Opt." FontFamily="PoppinsMedium" FontSize="10" TextColor="#64748B" />
                                                    </Frame>
                                                </Grid>
                                                <Label Grid.Column="5" Text="{Binding UploadedDateDisplay}"
                                                       Style="{StaticResource DataTableCellSecondary}"
                                                       FontSize="11" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                                <HorizontalStackLayout Grid.Column="6" Spacing="2" HorizontalOptions="End" VerticalOptions="Center">
                                                    <Button Text="View"
                                                            Command="{Binding Source={x:Reference Self}, Path=BindingContext.ViewDocumentCommand}"
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                                            FontFamily="PoppinsMedium" FontSize="11" BorderWidth="0" HeightRequest="30" Padding="5,0" />
                                                    <Button Text="Approve"
                                                            Command="{Binding Source={x:Reference Self}, Path=BindingContext.ApproveDocumentCommand}"
                                                            CommandParameter="{Binding .}"
                                                            IsVisible="{Binding IsApproved, Converter={StaticResource InverseBoolConverter}}"
                                                            BackgroundColor="Transparent" TextColor="#22C55E"
                                                            FontFamily="PoppinsMedium" FontSize="11" BorderWidth="0" HeightRequest="30" Padding="5,0" />
                                                    <Button Text="Reject"
                                                            Command="{Binding Source={x:Reference Self}, Path=BindingContext.RejectDocumentCommand}"
                                                            CommandParameter="{Binding .}"
                                                            IsVisible="{Binding IsRejected, Converter={StaticResource InverseBoolConverter}}"
                                                            BackgroundColor="Transparent" TextColor="#FCD34D"
                                                            FontFamily="PoppinsMedium" FontSize="11" BorderWidth="0" HeightRequest="30" Padding="5,0" />
                                                    <Button Text="Delete"
                                                            Command="{Binding Source={x:Reference Self}, Path=BindingContext.DeleteDocumentCommand}"
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="Transparent" TextColor="{StaticResource Error}"
                                                            FontFamily="PoppinsMedium" FontSize="11" BorderWidth="0" HeightRequest="30" Padding="5,0" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView Style="{StaticResource DataTableRowDivider}" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 3: PAYMENTS                                                    -->
        <!-- Banking details · Payment settings · Pending banking alert        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsPaymentsTab}">
            <VerticalStackLayout Padding="16,0,16,24" Spacing="16"
                                 IsVisible="{Binding Contractor, Converter={StaticResource IsNotNullConverter}}">

                <!-- Phase 2C.3: Pending banking update card (shown when contractor submitted via portal) -->
                <Frame CornerRadius="10" Padding="14" HasShadow="False"
                       BorderColor="#78350F" BackgroundColor="#1A1200"
                       IsVisible="{Binding HasPendingBankingUpdate}">
                    <VerticalStackLayout Spacing="10">
                        <!-- All text uses explicit light colours — dark bg #1A1200 requires high contrast. -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="18"
                                   TextColor="#FCD34D" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Pending Banking Update — Requires Review"
                                       FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#FCD34D" />
                                <Label Text="{Binding PendingBankingUpdate.SubmittedAtDisplay, StringFormat='Submitted by contractor: {0}'}"
                                       FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <!-- Submitted banking summary — explicit colours for readability on dark bg -->
                        <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" Margin="0,4,0,0">
                            <Label Grid.Row="0" Grid.Column="0" Text="Account Holder" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding PendingBankingUpdate.AccountHolderName, FallbackValue='—'}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FFFFFF" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Bank" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding PendingBankingUpdate.BankName, FallbackValue='—'}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FFFFFF" />
                            <Label Grid.Row="2" Grid.Column="0" Text="Account No." FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding PendingBankingUpdate.MaskedAccount}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FFFFFF" />
                            <Label Grid.Row="3" Grid.Column="0" Text="Account Type" FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A" />
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding PendingBankingUpdate.AccountTypeLabel}" FontFamily="PoppinsRegular" FontSize="12" TextColor="#FDE8A0" />
                        </Grid>
                        <!-- Phase 2C.4: Approve / Reject buttons -->
                        <BoxView HeightRequest="1" Color="#78350F" Margin="0,6,0,2" />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="Approving copies these details to the contractor record. Banking verification will be reset."
                                   FontFamily="PoppinsRegular" FontSize="11" TextColor="#FDE68A"
                                   LineBreakMode="WordWrap" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="Reject"
                                    Command="{Binding RejectContractorBankingCommand}"
                                    BackgroundColor="#450A0A" TextColor="#FCA5A5"
                                    FontFamily="PoppinsMedium" FontSize="12"
                                    CornerRadius="8" Padding="16,0" HeightRequest="36" BorderWidth="0"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            <Button Grid.Column="2" Text="Approve Banking"
                                    Command="{Binding ApproveContractorBankingCommand}"
                                    BackgroundColor="#14532D" TextColor="#22C55E"
                                    FontFamily="PoppinsSemiBold" FontSize="12"
                                    CornerRadius="8" Padding="16,0" HeightRequest="36" BorderWidth="0"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="BANKING DETAILS" Style="{StaticResource LabelSection}" />
                        <Entry Placeholder="Account holder name (legal name) *"
                               Text="{Binding Contractor.AccountHolderName, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Bank name"
                               Text="{Binding Contractor.BankName, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Account number"
                               Text="{Binding Contractor.BankAccount, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                        <Entry Placeholder="Branch code (6-digit)"
                               Text="{Binding Contractor.BankBranchCode, Mode=TwoWay}"
                               Keyboard="Numeric" Style="{StaticResource DarkEntry}" />
                        <Picker Title="Account type"
                                ItemsSource="{Binding AccountTypeItems}"
                                SelectedItem="{Binding SelectedAccountTypeLabel, Mode=TwoWay}"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}" />
                        <Entry Placeholder="SWIFT / BIC (international transfers)"
                               Text="{Binding Contractor.SwiftBic, Mode=TwoWay}"
                               Style="{StaticResource DarkEntry}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="PAYMENT SETTINGS" Style="{StaticResource LabelSection}" />
                        <Picker Title="Payment terms"
                                ItemsSource="{Binding PaymentTermsItems}"
                                SelectedItem="{Binding SelectedPaymentTermsLabel, Mode=TwoWay}"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}" />
                        <Picker Title="Preferred payment method"
                                ItemsSource="{Binding PaymentMethodItems}"
                                SelectedItem="{Binding SelectedPaymentMethodLabel, Mode=TwoWay}"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="Banking Verified" Style="{StaticResource BodyMedium}" />
                                <Label Text="Bank details confirmed against proof of banking."
                                       Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding BankingVerified, Mode=TwoWay}"
                                    OnColor="#16A34A" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="Payment Hold" Style="{StaticResource BodyMedium}"
                                       TextColor="{Binding PaymentHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F59E0B|{StaticResource TextPrimary}'}" />
                                <Label Text="Blocks all payouts to this contractor."
                                       Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding PaymentHold, Mode=TwoWay}"
                                    OnColor="#D97706" VerticalOptions="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="Compliance Hold" Style="{StaticResource BodyMedium}"
                                       TextColor="{Binding ComplianceHold, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|{StaticResource TextPrimary}'}" />
                                <Label Text="Compliance documents missing or expired — blocks payments."
                                       Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding ComplianceHold, Mode=TwoWay}"
                                    OnColor="#DC2626" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 4: TEAM                                                        -->
        <!-- Team members (contractor-type only)                               -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsTeamTab}">
            <VerticalStackLayout Padding="16,0,16,24" Spacing="16">

                <!-- New contractor guard -->
                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding IsNew}">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="&#xE88F;" FontFamily="MaterialIcons" FontSize="18"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                        <Label Text="Save the contractor on the Information tab first to manage team members."
                               FontFamily="PoppinsRegular" FontSize="13"
                               TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" LineBreakMode="WordWrap" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- Supplier notice (no team for suppliers) -->
                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding IsSupplierMode}">
                    <Label Text="Team member management is not applicable for supplier partners."
                           FontFamily="PoppinsRegular" FontSize="13"
                           TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                </Frame>

                <!-- Team members content -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowMembersSection}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Label Text="TEAM MEMBERS" Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Invite" Command="{Binding InviteMemberCommand}"
                                Style="{StaticResource TextButton}" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Text="+ Add" Command="{Binding AddMemberCommand}"
                                Style="{StaticResource OutlinedButton}" HeightRequest="36" FontSize="12" />
                    </Grid>
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="*,120,80" Padding="12,10" BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Text="Employee" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Role" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Primary" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                        </Grid>
                    </Frame>
                    <CollectionView ItemsSource="{Binding Members}">
                        <CollectionView.EmptyView>
                            <Label Text="No members linked." Style="{StaticResource EmptyState}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ContractorMemberDisplay">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="*,120,80" Padding="12,10" BackgroundColor="{StaticResource SurfaceCard}">
                                        <Label Text="{Binding EmployeeName}" Style="{StaticResource DataTableCellLabel}" />
                                        <Label Grid.Column="1" Text="{Binding Link.Role}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="2" Text="{Binding Link.IsPrimary, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Yes|—'}"
                                               Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 5: JOBS  (Phase 2D.5)                                         -->
        <!-- jobs WHERE contractor_id = Contractor.Id                          -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" IsVisible="{Binding IsJobsTab}">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,10,16,6">
                <Label Grid.Column="0" Text="JOBS"
                       Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding JobsLoading}"
                                   IsVisible="{Binding JobsLoading}"
                                   Color="{StaticResource Primary}"
                                   HeightRequest="18" WidthRequest="18" />
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16,0,16,24" Spacing="0">

                    <!-- Table header: Code / Title / Role / Status / Scheduled / Agreed / Project / [Open] -->
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="80,*,90,90,80,80,90,70" Padding="10,8"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Code"      Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Title"     Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Role"      Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Status"    Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="Scheduled" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="5" Text="Agreed"    Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="6" Text="Project"   Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="7" Text=""          Style="{StaticResource DataTableHeaderLabel}" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding ContractorJobs}">
                        <CollectionView.EmptyView>
                            <Label Text="No jobs linked to this contractor yet."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:JobContractor">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="80,*,90,90,80,80,90,50,70"
                                          Padding="10,9" BackgroundColor="{StaticResource SurfaceCard}">
                                        <Label Grid.Column="0"
                                               Text="{Binding JobCodeDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               FontFamily="PoppinsMedium" />
                                        <Label Grid.Column="1"
                                               Text="{Binding JobTitle}"
                                               Style="{StaticResource DataTableCellLabel}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2"
                                               Text="{Binding RoleDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               HorizontalTextAlignment="Center" />
                                        <Frame Grid.Column="3" CornerRadius="5" Padding="6,2"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding JobStatusBadgeBg}"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding JobStatusLabel}"
                                                   FontFamily="PoppinsMedium" FontSize="10"
                                                   TextColor="{Binding JobStatusBadgeFg}" />
                                        </Frame>
                                        <Label Grid.Column="4"
                                               Text="{Binding JobScheduledDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               HorizontalTextAlignment="End" />
                                        <Label Grid.Column="5"
                                               Text="{Binding AgreedAmountDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               HorizontalTextAlignment="End" />
                                        <Label Grid.Column="6"
                                               Text="{Binding JobProjectDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               LineBreakMode="TailTruncation" />
                                        <Button Grid.Column="7"
                                                Text="📄"
                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.OpenJobContractorDocsCommand}"
                                                CommandParameter="{Binding .}"
                                                FontSize="11"
                                                HeightRequest="32" WidthRequest="50"
                                                Padding="0"
                                                BackgroundColor="#1A2A1A"
                                                TextColor="#4ADE80"
                                                CornerRadius="4" />
                                        <Button Grid.Column="8" Text="Open →"
                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.OpenContractorJobCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Primary}"
                                                FontFamily="PoppinsMedium" FontSize="11"
                                                BorderWidth="0" HeightRequest="30" Padding="0" />
                                    </Grid>
                                    <!-- Phase G: financial sub-row -->
                                    <Grid ColumnDefinitions="80,*,*,*" ColumnSpacing="8" Padding="10,2,10,6"
                                          BackgroundColor="{StaticResource SurfaceCard}"
                                          IsVisible="{Binding HasFinancialSummary}">
                                        <Label Text="Finance:"
                                               FontSize="10" TextColor="{StaticResource TextSecondary}"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding PaidAmountDisplay, StringFormat='Paid {0}'}"
                                               FontSize="10" TextColor="#22C55E" />
                                        <Label Grid.Column="2"
                                               Text="{Binding ApprovedAmountDisplay, StringFormat='Approved {0}'}"
                                               FontSize="10" TextColor="#0EA5E9" />
                                        <Label Grid.Column="3"
                                               Text="{Binding VarianceSummary}"
                                               FontSize="10" TextColor="{Binding VarianceColor}" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 6: PROJECTS  (Phase A — project_contractors join table)        -->
        <!-- Source: project_contractors WHERE contractor_id = Contractor.Id    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" IsVisible="{Binding IsProjectsTab}">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,10,16,6">
                <Label Grid.Column="0" Text="PROJECTS"
                       Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding ProjectsLoading}"
                                   IsVisible="{Binding ProjectsLoading}"
                                   Color="{StaticResource Primary}"
                                   HeightRequest="18" WidthRequest="18" />
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16,0,16,24" Spacing="0">

                    <!-- Table header — Code / Title / Role / Status / [Open] -->
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="90,*,100,90,70" Padding="10,8"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Code"    Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Project" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Role"    Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Status"  Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text=""        Style="{StaticResource DataTableHeaderLabel}" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding ContractorProjects}">
                        <CollectionView.EmptyView>
                            <Label Text="No projects linked to this contractor yet."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectContractor">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="90,*,100,90,70"
                                          Padding="10,9" BackgroundColor="{StaticResource SurfaceCard}">
                                        <Label Grid.Column="0"
                                               Text="{Binding ProjectCodeDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               FontFamily="PoppinsMedium" />
                                        <Label Grid.Column="1"
                                               Text="{Binding ProjectTitle}"
                                               Style="{StaticResource DataTableCellLabel}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2"
                                               Text="{Binding RoleDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               HorizontalTextAlignment="Center" />
                                        <!-- Assignment status badge -->
                                        <Frame Grid.Column="3" CornerRadius="5" Padding="6,2"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding StatusBadgeBg}"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding StatusLabel}"
                                                   FontFamily="PoppinsMedium" FontSize="10"
                                                   TextColor="{Binding StatusBadgeFg}" />
                                        </Frame>
                                        <!-- WinUI-reliable: Button.Command -->
                                        <Button Grid.Column="4" Text="Open →"
                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.OpenContractorProjectCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Primary}"
                                                FontFamily="PoppinsMedium" FontSize="11"
                                                BorderWidth="0" HeightRequest="30" Padding="0" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 7: INCIDENTS  (Phase 2D.5)                                    -->
        <!-- incident_reports WHERE contractor_id = Contractor.Id              -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" IsVisible="{Binding IsIncidentsTab}">

            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,10,16,6">
                <Label Grid.Column="0" Text="INCIDENTS"
                       Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IncidentsLoading}"
                                   IsVisible="{Binding IncidentsLoading}"
                                   Color="{StaticResource Primary}"
                                   HeightRequest="18" WidthRequest="18" />
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16,0,16,24" Spacing="0">

                    <!-- Table header — Phase A: adds Project column via incident_reports.deal_id -->
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="90,*,90,90,40,40,70" Padding="10,8"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Date"      Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Incident"  Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Severity"  Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Status"    Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="Job"       Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="Proj"      Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text=""          Style="{StaticResource DataTableHeaderLabel}" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding ContractorIncidents}">
                        <CollectionView.EmptyView>
                            <Label Text="No incidents linked to this contractor."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:IncidentReport">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="90,*,90,90,40,40,70"
                                          Padding="10,9" BackgroundColor="{StaticResource SurfaceCard}">
                                        <Label Grid.Column="0"
                                               Text="{Binding OccurredAtDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding DisplayTitle}"
                                               Style="{StaticResource DataTableCellLabel}"
                                               LineBreakMode="TailTruncation" />
                                        <!-- Severity badge -->
                                        <Frame Grid.Column="2" CornerRadius="5" Padding="6,2"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding SeverityBadgeBg}"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding SeverityLabel}"
                                                   FontFamily="PoppinsMedium" FontSize="10"
                                                   TextColor="{Binding SeverityBadgeFg}" />
                                        </Frame>
                                        <!-- Status badge -->
                                        <Frame Grid.Column="3" CornerRadius="5" Padding="6,2"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding StatusBadgeBg}"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label Text="{Binding StatusLabel}"
                                                   FontFamily="PoppinsMedium" FontSize="10"
                                                   TextColor="{Binding StatusBadgeFg}" />
                                        </Frame>
                                        <Label Grid.Column="4"
                                               Text="{Binding JobLinkedDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               HorizontalTextAlignment="Center" />
                                        <!-- Phase A: project linkage via incident_reports.deal_id -->
                                        <Label Grid.Column="5"
                                               Text="{Binding ProjectLinkedDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               HorizontalTextAlignment="Center" />
                                        <!-- WinUI-reliable: Button.Command -->
                                        <Button Grid.Column="6" Text="Open →"
                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.OpenContractorIncidentCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Primary}"
                                                FontFamily="PoppinsMedium" FontSize="11"
                                                BorderWidth="0" HeightRequest="30" Padding="0" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 8 (was 5): ACTIVITY  (Phase 2C — contractor-specific event feed) -->
        <!-- Source: app_events WHERE meta->>'contractor_id' = Contractor.Id   -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" IsVisible="{Binding IsActivityTab}">

            <!-- Filter row: compact Picker replaces the 6 chip buttons -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,180" ColumnSpacing="8"
                  Padding="16,10,16,4">
                <Label Grid.Column="0" Text="Filter activity:"
                       FontFamily="PoppinsRegular" FontSize="12"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding ActivityFilterOptions}"
                        SelectedItem="{Binding ActivityFilter, Mode=TwoWay}"
                        TitleColor="{StaticResource TextSecondary}"
                        TextColor="{StaticResource TextPrimary}"
                        FontFamily="PoppinsRegular" FontSize="13" />
            </Grid>

            <!-- Feed content -->
            <ScrollView Grid.Row="1" Padding="16,10,16,24">
                <VerticalStackLayout Spacing="0">

                    <!-- Loading spinner (lazy load on first tab open) -->
                    <ActivityIndicator IsRunning="{Binding ActivityLoading}"
                                       IsVisible="{Binding ActivityLoading}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" Margin="0,24" />

                    <!-- "Not loaded yet" — guard for new contractors -->
                    <Label Text="Save the contractor first to view activity history."
                           Style="{StaticResource EmptyState}" Margin="0,24"
                           IsVisible="{Binding IsNew}" />

                    <!-- Empty state (loaded, no events) -->
                    <Label Text="No activity recorded yet. Activity will appear here as HR and contractors make changes."
                           Style="{StaticResource EmptyState}" Margin="0,24"
                           IsVisible="{Binding ActivityEvents.Count, Converter={StaticResource IsZeroConverter}}" />

                    <!-- Event rows (CollectionView inside ScrollView is safe here:
                         outer ScrollView is vertical; CollectionView uses VerticalList layout
                         and is given infinite height by the parent VerticalStackLayout.) -->
                    <CollectionView ItemsSource="{Binding ActivityEvents}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ContractorActivityEntry">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,10" ColumnSpacing="12">

                                        <!-- Left: event badge + time -->
                                        <VerticalStackLayout Grid.Column="0" Spacing="4"
                                                             WidthRequest="110" VerticalOptions="Start">
                                            <Frame CornerRadius="6" Padding="7,3" HasShadow="False"
                                                   BorderColor="Transparent"
                                                   BackgroundColor="{Binding BadgeBg}">
                                                <Label Text="{Binding EventLabel}"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{Binding BadgeFg}"
                                                       HorizontalTextAlignment="Center" />
                                            </Frame>
                                            <Label Text="{Binding DateTimeDisplay}"
                                                   FontFamily="PoppinsRegular" FontSize="10"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>

                                        <!-- Centre: description -->
                                        <Label Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontFamily="PoppinsRegular" FontSize="12"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center"
                                               LineBreakMode="TailTruncation"
                                               IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />

                                        <!-- Right: actor + source -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="3"
                                                             WidthRequest="80" VerticalOptions="Start"
                                                             HorizontalOptions="End">
                                            <Label Text="{Binding Actor}"
                                                   FontFamily="PoppinsMedium" FontSize="11"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   HorizontalTextAlignment="End" />
                                            <Label Text="{Binding Source}"
                                                   FontFamily="PoppinsRegular" FontSize="10"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>

                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 6: QUOTES  (Phase 2D.2 — view only; approve/reject in 2D.3)  -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="*" IsVisible="{Binding IsQuotesTab}">

            <!-- Quote list (shown when no quote is open) -->
            <ScrollView IsVisible="{Binding HrQuoteDetailVisible, Converter={StaticResource InverseBoolConverter}}">
                <VerticalStackLayout Padding="16,0,16,24" Spacing="14">

                    <Label Text="No quotes submitted yet."
                           Style="{StaticResource EmptyState}" Margin="0,24"
                           IsVisible="{Binding ContractorQuotes.Count, Converter={StaticResource IsZeroConverter}}" />

                    <!-- Quote summary table -->
                    <Frame Style="{StaticResource DataTableFrame}"
                           IsVisible="{Binding ContractorQuotes.Count, Converter={StaticResource IsNotZeroConverter}}">
                        <Grid ColumnDefinitions="120,*,100,95,90" Padding="12,9"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Status"      Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Title"       Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Type"        Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="3" Text="Total"       Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="4" Text="Submitted"   Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding ContractorQuotes}"
                                    IsVisible="{Binding ContractorQuotes.Count, Converter={StaticResource IsNotZeroConverter}}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ContractorQuote">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="120,*,100,95,90" Padding="12,9"
                                          BackgroundColor="{StaticResource SurfaceCard}">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference Self}, Path=BindingContext.OpenHrQuoteCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Frame Grid.Column="0" CornerRadius="6" Padding="7,3"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding StatusBadgeBg}"
                                               HorizontalOptions="Start" VerticalOptions="Center">
                                            <Label Text="{Binding StatusLabel}"
                                                   FontFamily="PoppinsMedium" FontSize="10"
                                                   TextColor="{Binding StatusBadgeFg}" />
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}"
                                                   Style="{StaticResource DataTableCellLabel}"
                                                   FontSize="12" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding QuoteNumberDisplay}"
                                                   Style="{StaticResource DataTableCellSecondary}"
                                                   FontSize="10" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding SourceLabel}"
                                               Style="{StaticResource DataTableCellSecondary}" FontSize="11"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="3" Text="{Binding TotalDisplay}"
                                               Style="{StaticResource DataTableCellLabel}"
                                               FontSize="12" HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="4" Text="{Binding SubmittedAtDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}"
                                               FontSize="11" HorizontalTextAlignment="End"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Quote detail view (when HrQuoteDetailVisible = true) -->
            <ScrollView IsVisible="{Binding HrQuoteDetailVisible}">
                <VerticalStackLayout Padding="16,0,16,24" Spacing="14">
                    <!-- Close + header -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Button Grid.Column="0" Text="← Quotes"
                                Command="{Binding CloseHrQuoteDetailCommand}"
                                BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                                FontFamily="PoppinsMedium" FontSize="13"
                                BorderWidth="0" Padding="0" HeightRequest="36" />
                        <Label Grid.Column="1" Text="{Binding SelectedHrQuote.Title}"
                               Style="{StaticResource HeadlineSmall}" VerticalOptions="Center" />
                    </Grid>

                    <!-- Status + meta card -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding SelectedHrQuote.QuoteNumberDisplay}"
                                       FontFamily="PoppinsMedium" FontSize="14"
                                       TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                <Frame Grid.Column="1" CornerRadius="6" Padding="9,4"
                                       HasShadow="False" BorderColor="Transparent"
                                       BackgroundColor="{Binding SelectedHrQuote.StatusBadgeBg}"
                                       VerticalOptions="Center">
                                    <Label Text="{Binding SelectedHrQuote.StatusLabel}"
                                           FontFamily="PoppinsMedium" FontSize="11"
                                           TextColor="{Binding SelectedHrQuote.StatusBadgeFg}" />
                                </Frame>
                            </Grid>
                            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                                <Label Grid.Row="0" Grid.Column="0" Text="Submitted"   Style="{StaticResource Caption}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedHrQuote.SubmittedAtDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="1" Grid.Column="0" Text="Valid Until" Style="{StaticResource Caption}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedHrQuote.ValidUntilDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Sender"      Style="{StaticResource Caption}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedHrQuote.SenderName, FallbackValue='—'}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="3" Grid.Column="0" Text="Source"      Style="{StaticResource Caption}" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedHrQuote.SourceLabel}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="4" Grid.Column="0" Text="VAT Mode"    Style="{StaticResource Caption}" />
                                <Label Grid.Row="4" Grid.Column="1" Text="{Binding SelectedHrQuote.VatModeLabel}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="5" Grid.Column="0" Text="VAT Rate"    Style="{StaticResource Caption}" />
                                <Label Grid.Row="5" Grid.Column="1" Text="{Binding SelectedHrQuote.VatRateDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- ── HR Review Actions (Phase 2D.3) ──────────────── -->
                    <!-- Approve / Request Revision / Reject — visible when reviewable -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14"
                           IsVisible="{Binding HrQuoteIsReviewable}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="REVIEW ACTIONS" Style="{StaticResource LabelSection}" />
                            <Label Text="Select an action. The contractor will be notified."
                                   FontFamily="PoppinsRegular" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Button Grid.Column="0" Text="✓ Approve"
                                        Command="{Binding ApproveContractorQuoteCommand}"
                                        BackgroundColor="#14532D" TextColor="#86EFAC"
                                        FontFamily="PoppinsSemiBold" FontSize="12"
                                        CornerRadius="8" HeightRequest="40" BorderWidth="0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                                <Button Grid.Column="1" Text="↩ Revise"
                                        Command="{Binding RequestQuoteRevisionCommand}"
                                        BackgroundColor="#3B2000" TextColor="#FDBA74"
                                        FontFamily="PoppinsSemiBold" FontSize="12"
                                        CornerRadius="8" HeightRequest="40" BorderWidth="0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                                <Button Grid.Column="2" Text="✕ Reject"
                                        Command="{Binding RejectContractorQuoteCommand}"
                                        BackgroundColor="#7F1D1D" TextColor="#FCA5A5"
                                        FontFamily="PoppinsSemiBold" FontSize="12"
                                        CornerRadius="8" HeightRequest="40" BorderWidth="0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Revision comments — shown when status is revision_requested -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#92400E" BackgroundColor="#1C0F00"
                           IsVisible="{Binding SelectedHrQuote.IsRevisionRequested}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Revision Comments Sent to Contractor"
                                   FontFamily="PoppinsMedium" FontSize="12" TextColor="#FDBA74" />
                            <Label Text="{Binding SelectedHrQuote.RevisionComments}"
                                   FontFamily="PoppinsRegular" FontSize="12"
                                   TextColor="#FEF3C7" LineBreakMode="WordWrap" />
                            <Label Text="{Binding SelectedHrQuote.ReviewedAtDisplay, StringFormat='Sent: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Rejection reason — shown when status is rejected -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#7F1D1D" BackgroundColor="#1A0707"
                           IsVisible="{Binding SelectedHrQuote.IsRejected}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Rejection Reason" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FCA5A5" />
                            <Label Text="{Binding SelectedHrQuote.RejectionReason}"
                                   FontFamily="PoppinsRegular" FontSize="12"
                                   TextColor="#FDE8E8" LineBreakMode="WordWrap" />
                            <Label Text="{Binding SelectedHrQuote.ReviewedAtDisplay, StringFormat='Rejected: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Approval confirmation + Convert to Job (Phase 2D.4) ── -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#14532D" BackgroundColor="#071A0F"
                           IsVisible="{Binding SelectedHrQuote.IsApproved}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="✓ Quote Approved" FontFamily="PoppinsMedium" FontSize="12" TextColor="#22C55E" />
                            <Label Text="{Binding SelectedHrQuote.ReviewedAtDisplay, StringFormat='Approved: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />

                            <!-- Phase 2D.4 / 2D.5: Job actions — only when quote can be converted -->
                            <HorizontalStackLayout Spacing="8"
                                                   IsVisible="{Binding HrQuoteCanConvert}">
                                <!-- Create a brand-new job from this quote -->
                                <Button Text="+ Create New Job"
                                        Command="{Binding CreateNewJobFromQuoteCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="12"
                                        CornerRadius="8" HeightRequest="36" BorderWidth="0"
                                        Padding="14,0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                                <!-- Assign to an existing job (Phase 2D.5) -->
                                <Button Text="⇄ Assign to Existing Job"
                                        Command="{Binding AssignToExistingJobCommand}"
                                        BackgroundColor="#1E3A5F" TextColor="#93C5FD"
                                        FontFamily="PoppinsSemiBold" FontSize="12"
                                        CornerRadius="8" HeightRequest="36" BorderWidth="0"
                                        Padding="14,0"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Linked to Job banner — shown when IsConverted (both paths) -->
                    <Frame CornerRadius="8" Padding="12,10" HasShadow="False"
                           BorderColor="#1E3A5F" BackgroundColor="#050F1E"
                           IsVisible="{Binding HrQuoteIsConverted}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="⚡ Linked to Job"
                                   FontFamily="PoppinsSemiBold" FontSize="12" TextColor="#60A5FA" />
                            <Label Text="{Binding SelectedHrQuote.ConvertedAtDisplay, StringFormat='Linked: {0}'}"
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="This quote has been linked to a job. Open the Jobs section to view it."
                                   FontFamily="PoppinsRegular" FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Line items (manual) -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14"
                           IsVisible="{Binding HrQuoteIsManual}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="LINE ITEMS" Style="{StaticResource LabelSection}" />
                            <CollectionView ItemsSource="{Binding HrQuoteItems}">
                                <CollectionView.EmptyView>
                                    <Label Text="No line items." Style="{StaticResource EmptyState}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorQuoteItem">
                                        <VerticalStackLayout Spacing="0">
                                            <Grid ColumnDefinitions="*,Auto" Padding="0,7">
                                                <VerticalStackLayout Grid.Column="0" Spacing="1">
                                                    <Label Text="{Binding Description}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                                    <Label Text="{Binding Quantity, StringFormat='Qty {0:F2}  ×  {1:N2}'}" FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1" Text="{Binding LineTotalDisplay}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                            </Grid>
                                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" Margin="0,4,0,0">
                                <Label Grid.Row="0" Grid.Column="0" Text="Subtotal"        Style="{StaticResource Caption}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedHrQuote.SubtotalDisplay}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="1" Grid.Column="0" Text="Discount"        Style="{StaticResource Caption}" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedHrQuote.DiscountDisplay}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Freight"         Style="{StaticResource Caption}" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedHrQuote.FreightDisplay}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="3" Grid.Column="0" Text="Duty"            Style="{StaticResource Caption}" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedHrQuote.DutyDisplay}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="4" Grid.Column="0" Text="Levies"          Style="{StaticResource Caption}" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="4" Grid.Column="1" Text="{Binding SelectedHrQuote.LeviesDisplay}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="5" Grid.Column="0" Text="Other Charges"   Style="{StaticResource Caption}" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="5" Grid.Column="1" Text="{Binding SelectedHrQuote.OtherChargesDisplay}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" IsVisible="{Binding SelectedHrQuote.HasChargesOrDiscount}" />
                                <Label Grid.Row="6" Grid.Column="0" Text="Taxable Amount"  Style="{StaticResource Caption}" />
                                <Label Grid.Row="6" Grid.Column="1" Text="{Binding SelectedHrQuote.TaxableDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="7" Grid.Column="0" Text="{Binding SelectedHrQuote.VatModeLabel}" Style="{StaticResource Caption}" />
                                <Label Grid.Row="7" Grid.Column="1" Text="{Binding SelectedHrQuote.VatDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="8" Grid.Column="0" Text="Total" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="8" Grid.Column="1" Text="{Binding SelectedHrQuote.TotalDisplay}" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource Primary}" HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Attachment (upload) -->
                    <Frame Style="{StaticResource CardFrame}" Padding="14"
                           IsVisible="{Binding HrQuoteIsUpload}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="UPLOADED DOCUMENT" Style="{StaticResource LabelSection}" />
                            <CollectionView ItemsSource="{Binding HrQuoteAttachments}">
                                <CollectionView.EmptyView>
                                    <Label Text="No attachments." Style="{StaticResource EmptyState}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContractorQuoteAttachment">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                            <Label Grid.Column="0" Text="{Binding FileName}"
                                                   FontFamily="PoppinsRegular" FontSize="12"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Button Grid.Column="1" Text="Open"
                                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.ViewHrQuoteDocumentCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                                    FontFamily="PoppinsMedium" FontSize="11"
                                                    CornerRadius="6" Padding="10,0" HeightRequest="30" BorderWidth="0" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                <Label Grid.Row="0" Grid.Column="0" Text="Subtotal" Style="{StaticResource Caption}" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedHrQuote.SubtotalDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="1" Grid.Column="0" Text="VAT" Style="{StaticResource Caption}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedHrQuote.VatDisplay}" FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="2" Grid.Column="0" Text="Total" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedHrQuote.TotalDisplay}" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource Primary}" HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TAB 7: INVOICES  (placeholder)                                    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsInvoicesTab}">
            <VerticalStackLayout Padding="16,0,16,24" Spacing="16">
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="INVOICES" Style="{StaticResource LabelSection}" />
                        <Label Text="Contractor invoices functionality coming soon."
                               FontFamily="PoppinsRegular" FontSize="13"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Busy overlay — rendered last so it appears above all tab panels -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           HorizontalOptions="Center" VerticalOptions="Start"
                           Margin="0,24" />

    </Grid>
</ContentPage>
