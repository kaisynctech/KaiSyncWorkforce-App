<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrInventoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:HrInventoryViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Suppliers" Command="{Binding GoToSuppliersCommand}" />
        <ToolbarItem Text="Export" Command="{Binding ExportCommand}" />
        <ToolbarItem Text="+ Add" Command="{Binding CreateItemCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <SearchBar Grid.Row="0" Text="{Binding SearchText}" Placeholder="Search name, SKU, supplier…"
                   BackgroundColor="{StaticResource SurfaceDark}"
                   TextColor="{StaticResource TextPrimary}"
                   PlaceholderColor="{StaticResource TextSecondary}" Margin="8,8,8,0" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="16,8,16,4">
            <Label Text="{Binding Items.Count, StringFormat='{0} items'}" Style="{StaticResource Caption}" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource TextButton}" FontSize="13" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="16,0,16,8">
            <Label Text="Low stock only" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
            <Switch Grid.Column="1" IsToggled="{Binding ShowLowStockOnly}" OnColor="{StaticResource Primary}" />
        </Grid>

        <RefreshView Grid.Row="3" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView Orientation="Horizontal">
                <VerticalStackLayout WidthRequest="1020" Spacing="0" Margin="16,0">
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="160,80,140,90,90,100,100,70" Padding="12,10"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Item" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="SKU" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Supplier" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="3" Text="On hand" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="4" Text="Unit" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="5" Text="Unit cost" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="6" Text="Stock value" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="7" Text="Alert" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding Items}">
                        <CollectionView.EmptyView>
                            <Label Text="No inventory items. Tap + Add to create one with supplier and cost."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:InventoryItem">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="160,80,140,90,90,100,100,70" Padding="12,10"
                                          BackgroundColor="{Binding NeedsReorder, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FEF2F2|#FFFFFF'}">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenItemCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource DataTableCellLabel}"
                                               TextColor="{StaticResource Primary}" />
                                        <Label Grid.Column="1" Text="{Binding Sku}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="2" Text="{Binding SupplierDisplay}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="3" Text="{Binding QuantityOnHand, StringFormat='{0:N1}'}"
                                               Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="4" Text="{Binding UnitOfMeasure}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="5" Text="{Binding UnitCostDisplay}" Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="6" Text="{Binding StockValueDisplay}" Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="7" Text="{Binding NeedsReorder, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Low|OK'}"
                                               Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="End"
                                               TextColor="{Binding NeedsReorder, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F87171|#9CA3AF'}" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
