<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="KaiFlow.Timesheets.Views.Hr.Controls.HrJobsListPanel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:shared="clr-namespace:KaiFlow.Timesheets.Views.Shared"
    x:DataType="vm:HrJobsViewModel"
    x:Name="JobsHost">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="24,8,24,0" ColumnSpacing="8">
            <Button Grid.Column="0" Text="{Binding ScopeAllLabel}"
                    Command="{Binding SetScopeCommand}" CommandParameter="all"
                    CornerRadius="10" HeightRequest="34" FontSize="12"
                    BackgroundColor="{Binding IsAllScope, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#FFFFFF'}"
                    TextColor="{Binding IsAllScope, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#6B7280'}" />
            <Button Grid.Column="1" Text="{Binding ScopeMineLabel}"
                    Command="{Binding SetScopeCommand}" CommandParameter="mine"
                    CornerRadius="10" HeightRequest="34" FontSize="12"
                    BackgroundColor="{Binding IsMyScope, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#FFFFFF'}"
                    TextColor="{Binding IsMyScope, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#6B7280'}" />
        </Grid>

        <Label Grid.Row="1" Text="{Binding ListSummary}" Style="{StaticResource Caption}"
               TextColor="{StaticResource TextSecondary}" Margin="24,6,24,0" />

        <SearchBar Grid.Row="2" Text="{Binding SearchText}"
                   Placeholder="Search code, title, client…"
                   BackgroundColor="{StaticResource SurfaceCard}"
                   TextColor="{StaticResource TextPrimary}"
                   PlaceholderColor="{StaticResource TextSecondary}" Margin="16,4,16,0" />

        <VerticalStackLayout Grid.Row="3" Margin="24,0,24,4" Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Date filter" Style="{StaticResource Caption}" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding UseDateFilter}" OnColor="{StaticResource Primary}" />
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding UseDateFilter}">
                <DatePicker Grid.Column="0" Date="{Binding DateFrom}" TextColor="{StaticResource TextPrimary}" />
                <DatePicker Grid.Column="1" Date="{Binding DateTo}" TextColor="{StaticResource TextPrimary}" />
            </Grid>
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Open" Command="{Binding SetFilterCommand}" CommandParameter="open"
                            CornerRadius="16" HeightRequest="30" FontSize="11"
                            BackgroundColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='open|#3B82F6,#E5E7EB'}"
                            TextColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='open|#FFFFFF,#374151'}" />
                    <Button Text="All" Command="{Binding SetFilterCommand}" CommandParameter="all"
                            CornerRadius="16" HeightRequest="30" FontSize="11"
                            BackgroundColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#3B82F6,#E5E7EB'}"
                            TextColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#FFFFFF,#374151'}" />
                    <Button Text="Scheduled" Command="{Binding SetFilterCommand}" CommandParameter="scheduled"
                            CornerRadius="16" HeightRequest="30" FontSize="11"
                            BackgroundColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='scheduled|#3B82F6,#E5E7EB'}"
                            TextColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='scheduled|#FFFFFF,#374151'}" />
                    <Button Text="In progress" Command="{Binding SetFilterCommand}" CommandParameter="inProgress"
                            CornerRadius="16" HeightRequest="30" FontSize="11"
                            BackgroundColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='inProgress|#3B82F6,#E5E7EB'}"
                            TextColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='inProgress|#FFFFFF,#374151'}" />
                    <Button Text="Completed" Command="{Binding SetFilterCommand}" CommandParameter="completed"
                            CornerRadius="16" HeightRequest="30" FontSize="11"
                            BackgroundColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='completed|#3B82F6,#E5E7EB'}"
                            TextColor="{Binding StatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='completed|#FFFFFF,#374151'}" />
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <RefreshView Grid.Row="4" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView Margin="24,4,24,16">
                <shared:HrJobsTableView Jobs="{Binding Jobs}"
                                        ViewJobCommand="{Binding ViewJobCommand}"
                                        ViewLinkedProjectCommand="{Binding ViewLinkedProjectCommand}" />
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentView>
