<?xml version="1.0" encoding="utf-8" ?>
<Border
    x:Class="KaiFlow.Timesheets.Views.Hr.Controls.ProjectKanbanColumnView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    xmlns:controls="clr-namespace:KaiFlow.Timesheets.Views.Hr.Controls"
    x:Name="Root"
    x:DataType="vm:ProjectKanbanColumn"
    WidthRequest="196"
    Padding="8"
    StrokeThickness="1"
    Stroke="{StaticResource Divider}"
    BackgroundColor="{StaticResource SurfaceCard}">

    <Border.StrokeShape>
        <RoundRectangle CornerRadius="10" />
    </Border.StrokeShape>

    <Border.GestureRecognizers>
        <DropGestureRecognizer AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop" DragLeave="OnDragLeave" />
    </Border.GestureRecognizers>

    <VerticalStackLayout Spacing="6">
        <Grid ColumnDefinitions="3,*" ColumnSpacing="6">
            <BoxView Grid.Column="0" WidthRequest="3" HeightRequest="28" VerticalOptions="Center"
                     Color="{Binding Source={x:Reference Root}, Path=AccentColor}" />
            <VerticalStackLayout Grid.Column="1" Spacing="1">
                <Label Text="{Binding Title}" FontFamily="PoppinsSemiBold" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                <Label Text="{Binding Count, StringFormat='{0} projects'}" FontSize="9" TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
        </Grid>

        <Border x:Name="DropZone" StrokeThickness="1" Stroke="{StaticResource Divider}"
                BackgroundColor="{StaticResource SurfaceElevated}" Padding="0" MinimumHeightRequest="320">
            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
            <Border.GestureRecognizers>
                <DropGestureRecognizer AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop" DragLeave="OnDragLeave" />
            </Border.GestureRecognizers>

            <ScrollView>
                <VerticalStackLayout x:Name="CardsHost" Spacing="6" Padding="6"
                                     BindableLayout.ItemsSource="{Binding Cards}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:ClientDeal">
                            <controls:ProjectKanbanCardView
                                OpenProjectCommand="{Binding Source={x:Reference Root}, Path=OpenProjectCommand}"
                                CreateJobCommand="{Binding Source={x:Reference Root}, Path=CreateJobCommand}"
                                AdvanceStageCommand="{Binding Source={x:Reference Root}, Path=AdvanceStageCommand}"
                                MoveStageCommand="{Binding Source={x:Reference Root}, Path=MoveToStageCommand}"
                                UploadDocumentCommand="{Binding Source={x:Reference Root}, Path=UploadDocumentCommand}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Label x:Name="DropHint" Text="Drop here" FontSize="9" TextColor="{StaticResource TextSecondary}"
               HorizontalTextAlignment="Center" IsVisible="False" />
    </VerticalStackLayout>
</Border>
