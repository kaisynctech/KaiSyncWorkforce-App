<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrClientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:HrClientsViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add Client" Command="{Binding AddClientCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">
        <SearchBar Grid.Row="0" Text="{Binding SearchText}" Placeholder="Search by name, code, email, phone…"
                   BackgroundColor="{StaticResource SurfaceDark}"
                   TextColor="{StaticResource TextPrimary}"
                   PlaceholderColor="{StaticResource TextSecondary}" Margin="8,8,8,0" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="16,8,16,4">
            <Label Text="{Binding Clients.Count, StringFormat='{0} clients'}"
                   Style="{StaticResource Caption}" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource TextButton}" FontSize="13" />
        </Grid>

        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView Orientation="Horizontal">
                <VerticalStackLayout WidthRequest="920" Spacing="0" Margin="16,0">
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="160,90,100,120,130,110" Padding="12,10"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Client" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Code" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Type" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="3" Text="Contact" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="4" Text="Email" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="5" Text="Phone" Style="{StaticResource DataTableHeaderLabel}" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding Clients}" SelectionMode="None"
                                      MinimumHeightRequest="120">
                        <CollectionView.EmptyView>
                            <Label Text="No clients yet. Tap + Add Client to create one."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Client">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="160,90,100,120,130,110" Padding="12,10"
                                          BackgroundColor="{StaticResource SurfaceCard}">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.OpenClientCommand, Source={x:Reference Self}}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource DataTableCellLabel}"
                                               TextColor="{StaticResource Primary}" />
                                        <Label Grid.Column="1" Text="{Binding ClientCodeDisplay}" Style="{StaticResource DataTableCellLabel}" />
                                        <Label Grid.Column="2" Text="{Binding TypeLabel}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="3" Text="{Binding ContactPerson}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="4" Text="{Binding Email}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="5" Text="{Binding Phone}" Style="{StaticResource DataTableCellSecondary}" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
