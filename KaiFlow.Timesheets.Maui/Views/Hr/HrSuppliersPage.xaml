<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrSuppliersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:HrSuppliersViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add" Command="{Binding CreateCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">
        <SearchBar Grid.Row="0" Text="{Binding SearchText}" Placeholder="Search suppliers…"
                   BackgroundColor="{StaticResource SurfaceDark}"
                   TextColor="{StaticResource TextPrimary}"
                   PlaceholderColor="{StaticResource TextSecondary}" Margin="8,8,8,0" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="16,8,16,4">
            <Label Text="{Binding Suppliers.Count, StringFormat='{0} suppliers'}" Style="{StaticResource Caption}" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource TextButton}" FontSize="13" />
        </Grid>

        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView Orientation="Horizontal">
                <VerticalStackLayout WidthRequest="900" Spacing="0" Margin="16,0">
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="200,140,160,140,120" Padding="12,10"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Supplier" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Contact" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Phone / Email" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="3" Text="Address" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="4" Text="Status" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                        </Grid>
                    </Frame>

                    <CollectionView ItemsSource="{Binding Suppliers}">
                        <CollectionView.EmptyView>
                            <Label Text="No suppliers yet. Add suppliers here or from an inventory item."
                                   Style="{StaticResource EmptyState}" Margin="0,24" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Contractor">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="200,140,160,140,120" Padding="12,10"
                                          BackgroundColor="{StaticResource SurfaceCard}">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource DataTableCellLabel}"
                                               TextColor="{StaticResource Primary}" />
                                        <Label Grid.Column="1" Text="{Binding ContactPerson}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="2" Text="{Binding ContactDisplay}" Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="3" Text="{Binding Address}" Style="{StaticResource DataTableCellSecondary}" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="4" Text="{Binding StatusLabel}" Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
