<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrEmployeesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    x:DataType="vm:HrEmployeesViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource BackgroundDark}"
    Title="Employees">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Shared header ───────────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0">

            <!-- Tab toggle: Employees | Teams | Leave | Pending -->
            <Frame Style="{StaticResource CardFrame}" Margin="16,12,16,0" Padding="3">
                <ScrollView Orientation="Horizontal">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="3" MinimumWidthRequest="320">
                    <Button Grid.Column="0" Text="Employees"
                            Command="{Binding SetTabCommand}" CommandParameter="employees"
                            BackgroundColor="{Binding IsEmployeesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#F3F4F6'}"
                            TextColor="{Binding IsEmployeesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                            FontFamily="PoppinsMedium" FontSize="12" HeightRequest="40" CornerRadius="6" />
                    <Button Grid.Column="1" Text="Teams"
                            Command="{Binding SetTabCommand}" CommandParameter="teams"
                            BackgroundColor="{Binding IsTeamsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#F3F4F6'}"
                            TextColor="{Binding IsTeamsTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                            FontFamily="PoppinsMedium" FontSize="12" HeightRequest="40" CornerRadius="6" />

                    <!-- Leave tab with pending badge (HR / leave.view_all only) -->
                    <Grid Grid.Column="2" ColumnDefinitions="*,Auto" MinimumWidthRequest="80"
                          IsVisible="{Binding CanSeeLeaveAdmin}">
                        <Button Grid.Column="0" Text="Leave"
                                Command="{Binding SetTabCommand}" CommandParameter="leave"
                                BackgroundColor="{Binding IsLeaveTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#F3F4F6'}"
                                TextColor="{Binding IsLeaveTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                                FontFamily="PoppinsMedium" FontSize="12" HeightRequest="40" CornerRadius="6" />
                        <Frame Grid.Column="1" BackgroundColor="#F59E0B" BorderColor="Transparent"
                               CornerRadius="10" Padding="5,1" HasShadow="False"
                               VerticalOptions="Start" Margin="-8,2,0,0"
                               IsVisible="{Binding PendingCount, Converter={StaticResource IsNotZeroConverter}}">
                            <Label Text="{Binding PendingCount}" TextColor="White"
                                   FontFamily="PoppinsBold" FontSize="10" />
                        </Frame>
                    </Grid>

                    <!-- Pending registrations tab with badge -->
                    <Grid Grid.Column="3" ColumnDefinitions="*,Auto" MinimumWidthRequest="80">
                        <Button Grid.Column="0" Text="Pending"
                                Command="{Binding SetTabCommand}" CommandParameter="pending"
                                BackgroundColor="{Binding IsPendingTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#F3F4F6'}"
                                TextColor="{Binding IsPendingTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#6B7280'}"
                                FontFamily="PoppinsMedium" FontSize="12" HeightRequest="40" CornerRadius="6" />
                        <Frame Grid.Column="1" BackgroundColor="#EF4444" BorderColor="Transparent"
                               CornerRadius="10" Padding="5,1" HasShadow="False"
                               VerticalOptions="Start" Margin="-8,2,0,0"
                               IsVisible="{Binding HasPending}">
                            <Label Text="{Binding PendingRegistrationCount}" TextColor="White"
                                   FontFamily="PoppinsBold" FontSize="10" />
                        </Frame>
                    </Grid>
                    </Grid>
                </ScrollView>
            </Frame>

            <!-- Branch filter (hidden on leave tab) -->
            <Frame Style="{StaticResource CardFrame}" Margin="16,8,16,0" Padding="4,0"
                   IsVisible="{Binding IsNotLeaveTab}">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="Branch:" Style="{StaticResource Caption}"
                           TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" Margin="8,0,0,0" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding BranchFilters}"
                            SelectedItem="{Binding BranchFilter}"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="Transparent" />
                </Grid>
            </Frame>

            <!-- Search — employees -->
            <SearchBar Margin="16,4,16,0" Text="{Binding SearchText}"
                       IsVisible="{Binding IsEmployeesTab}"
                       Placeholder="Search employees…"
                       BackgroundColor="{StaticResource SurfaceDark}"
                       TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource TextSecondary}" />

            <!-- Search — teams -->
            <SearchBar Margin="16,4,16,0" Text="{Binding TeamSearchText}"
                       IsVisible="{Binding IsTeamsTab}"
                       Placeholder="Search teams…"
                       BackgroundColor="{StaticResource SurfaceDark}"
                       TextColor="{StaticResource TextPrimary}"
                       PlaceholderColor="{StaticResource TextSecondary}" />

            <!-- Employment type pills + action buttons (employees only) -->
            <VerticalStackLayout Spacing="8" Margin="16,4,16,0"
                                 IsVisible="{Binding IsEmployeesTab}">
                <ScrollView Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="All types" Command="{Binding SetTypeFilterCommand}" CommandParameter="all"
                                CornerRadius="16" HeightRequest="36" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#3B82F6,#E5E7EB'}"
                                TextColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#FFFFFF,#374151'}" />
                        <Button Text="Permanent" Command="{Binding SetTypeFilterCommand}" CommandParameter="permanent"
                                CornerRadius="16" HeightRequest="36" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='permanent|#3B82F6,#E5E7EB'}"
                                TextColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='permanent|#FFFFFF,#374151'}" />
                        <Button Text="Contract" Command="{Binding SetTypeFilterCommand}" CommandParameter="contract"
                                CornerRadius="16" HeightRequest="36" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='contract|#3B82F6,#E5E7EB'}"
                                TextColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='contract|#FFFFFF,#374151'}" />
                        <Button Text="Part-Time" Command="{Binding SetTypeFilterCommand}" CommandParameter="part-time"
                                CornerRadius="16" HeightRequest="36" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='part-time|#3B82F6,#E5E7EB'}"
                                TextColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='part-time|#FFFFFF,#374151'}" />
                        <Button Text="Student" Command="{Binding SetTypeFilterCommand}" CommandParameter="student"
                                CornerRadius="16" HeightRequest="36" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='student|#3B82F6,#E5E7EB'}"
                                TextColor="{Binding TypeFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='student|#FFFFFF,#374151'}" />
                    </HorizontalStackLayout>
                </ScrollView>
                <FlexLayout Wrap="Wrap" JustifyContent="End" AlignItems="Center" Direction="Row">
                    <Button Text="Import" Command="{Binding GoToImportCommand}"
                            BackgroundColor="{StaticResource SurfaceElevated}"
                            TextColor="{StaticResource TextPrimary}"
                            BorderColor="{StaticResource Divider}" BorderWidth="1"
                            FontFamily="PoppinsMedium" FontSize="12"
                            CornerRadius="10" HeightRequest="36" Padding="10,0"
                            Margin="0,0,8,0" />
                    <Button Text="+ Add" Command="{Binding CreateCommand}"
                            Style="{StaticResource PrimaryButton}"
                            FontSize="12" HeightRequest="36" Padding="10,0" CornerRadius="10" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Leave: search + status filter pills -->
            <VerticalStackLayout IsVisible="{Binding IsLeaveTab}" Spacing="0">
                <SearchBar Margin="16,4,16,0" Text="{Binding LeaveSearchText}"
                           Placeholder="Search by employee or leave type…"
                           BackgroundColor="{StaticResource SurfaceDark}"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource TextSecondary}" />
                <ScrollView Orientation="Horizontal" Margin="16,4,16,0">
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Pending" Command="{Binding SetLeaveFilterCommand}" CommandParameter="pending"
                                CornerRadius="16" HeightRequest="30" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='pending|#F59E0B,#E5E7EB'}"
                                TextColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='pending|#FFFFFF,#374151'}" />
                        <Button Text="Approved" Command="{Binding SetLeaveFilterCommand}" CommandParameter="approved"
                                CornerRadius="16" HeightRequest="30" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='approved|#22C55E,#E5E7EB'}"
                                TextColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='approved|#FFFFFF,#374151'}" />
                        <Button Text="Declined" Command="{Binding SetLeaveFilterCommand}" CommandParameter="declined"
                                CornerRadius="16" HeightRequest="30" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='declined|#EF4444,#E5E7EB'}"
                                TextColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='declined|#FFFFFF,#374151'}" />
                        <Button Text="All" Command="{Binding SetLeaveFilterCommand}" CommandParameter="all"
                                CornerRadius="16" HeightRequest="30" FontSize="11" Padding="12,0"
                                BackgroundColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#3B82F6,#E5E7EB'}"
                                TextColor="{Binding LeaveStatusFilter, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#FFFFFF,#374151'}" />
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ── Employees table ─────────────────────────────────────────── -->
        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding IsEmployeesTab}">
            <CollectionView ItemsSource="{Binding Employees}" Margin="16,4">
                <CollectionView.EmptyView>
                    <Label Text="No employees found." Style="{StaticResource EmptyState}" Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.Header>
                    <Frame Style="{StaticResource DataTableFrame}" Margin="0,0,0,0">
                        <Grid ColumnDefinitions="2*,*,*,100,88" Padding="12,10"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Name" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Position" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Branch" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="3" Text="Role" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="4" Text="Type" Style="{StaticResource DataTableHeaderLabel}" />
                        </Grid>
                    </Frame>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Employee">
                        <SwipeView>
                            <SwipeView.LeftItems>
                                <SwipeItems>
                                    <SwipeItem Text="Invite" BackgroundColor="{StaticResource Accent}"
                                               Command="{Binding BindingContext.SendInviteCommand, Source={x:Reference Self}}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.LeftItems>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Edit" BackgroundColor="{StaticResource Primary}"
                                               Command="{Binding BindingContext.EditCommand, Source={x:Reference Self}}"
                                               CommandParameter="{Binding .}" />
                                    <SwipeItem Text="Delete" BackgroundColor="{StaticResource Error}"
                                               Command="{Binding BindingContext.DeleteCommand, Source={x:Reference Self}}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <VerticalStackLayout Spacing="0">
                                <Grid ColumnDefinitions="2*,*,*,100,88" Padding="12,10"
                                      BackgroundColor="{StaticResource SurfaceCard}">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.ViewDashboardCommand, Source={x:Reference Self}}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                        <Frame CornerRadius="14" WidthRequest="28" HeightRequest="28"
                                               BackgroundColor="{StaticResource Primary}" Padding="0" HasShadow="False">
                                            <Label Text="{Binding Initials}" FontFamily="PoppinsSemiBold" FontSize="10"
                                                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Frame>
                                        <Label Text="{Binding FullName}" Style="{StaticResource DataTableCellLabel}"
                                               TextColor="{StaticResource Primary}" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding Position, FallbackValue='—', TargetNullValue='—'}"
                                           Style="{StaticResource DataTableCellSecondary}" />
                                    <Label Grid.Column="2" Text="{Binding Branch, FallbackValue='—', TargetNullValue='—'}"
                                           Style="{StaticResource DataTableCellSecondary}" />
                                    <Label Grid.Column="3" Text="{Binding AccessLevelDisplay}"
                                           Style="{StaticResource DataTableCellLabel}" />
                                    <Label Grid.Column="4" Text="{Binding EmploymentTypeDisplay}"
                                           Style="{StaticResource DataTableCellSecondary}" />
                                </Grid>
                                <BoxView Style="{StaticResource DataTableRowDivider}" />
                            </VerticalStackLayout>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- ── Teams list ──────────────────────────────────────────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" IsVisible="{Binding IsTeamsTab}">
            <Button Grid.Row="0" Text="+ Create Team" Command="{Binding CreateTeamCommand}"
                    Style="{StaticResource PrimaryButton}" Margin="16,8,16,4" />
            <CollectionView Grid.Row="1" ItemsSource="{Binding Teams}" Margin="16,4">
                <CollectionView.EmptyView>
                    <Label Text="No teams yet. Create your first team." Style="{StaticResource EmptyState}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkTeam">
                        <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.ViewTeamCommand, Source={x:Reference Self}}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="48,*,Auto">
                                <Frame Grid.Column="0" CornerRadius="24" WidthRequest="48" HeightRequest="48"
                                       BackgroundColor="{StaticResource Accent}" Padding="0">
                                    <Label Text="T" FontFamily="PoppinsSemiBold" FontSize="18" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="12,0">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyLarge}" />
                                    <Label Text="{Binding Description}" Style="{StaticResource Caption}"
                                           TextColor="{StaticResource TextSecondary}"
                                           IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding MemberCount, StringFormat='{0} members'}"
                                       Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- ── Leave tab ───────────────────────────────────────────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" IsVisible="{Binding IsLeaveTab}">

            <!-- Who's on leave today banner -->
            <Frame Grid.Row="0" BackgroundColor="#DCFCE7" BorderColor="#86EFAC" CornerRadius="10"
                   Margin="16,6,16,0" Padding="12,10" HasShadow="False"
                   IsVisible="{Binding HasOnLeaveToday}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="ON LEAVE TODAY" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="#166534" />
                    <VerticalStackLayout Spacing="2" BindableLayout.ItemsSource="{Binding OnLeaveToday}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:LeaveRequestDisplay">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="•" FontSize="12" TextColor="#16A34A" VerticalOptions="Center" />
                                    <Label FontFamily="PoppinsMedium" FontSize="12" TextColor="#15803D" VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding EmployeeName}" FontFamily="PoppinsSemiBold" />
                                                <Span Text=" · " />
                                                <Span Text="{Binding Request.LeaveType}" />
                                                <Span Text=" until " />
                                                <Span Text="{Binding Request.EndDate, StringFormat='{0:dd MMM}'}" FontFamily="PoppinsSemiBold" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Compact leave request list -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding LeaveRequests}" Margin="16,6,16,0">
                <CollectionView.EmptyView>
                    <Label Text="No leave requests." Style="{StaticResource EmptyState}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LeaveRequestDisplay">
                        <!-- Compact row: ~68px pending, ~52px otherwise -->
                        <Grid ColumnDefinitions="32,*,Auto" RowDefinitions="Auto,Auto"
                              Padding="0,6" ColumnSpacing="10" RowSpacing="4"
                              Margin="0,2">

                            <!-- Initials circle -->
                            <Frame Grid.Column="0" Grid.RowSpan="2"
                                   CornerRadius="16" WidthRequest="32" HeightRequest="32"
                                   BackgroundColor="{Binding TypeColor, Converter={StaticResource HexToColorConverter}}"
                                   Padding="0" HasShadow="False" VerticalOptions="Center">
                                <Label Text="{Binding EmployeeInitials}" TextColor="White"
                                       FontFamily="PoppinsBold" FontSize="11"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>

                            <!-- Name + dates -->
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding EmployeeName}"
                                       FontFamily="PoppinsSemiBold" FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding PeriodText}"
                                       FontFamily="Poppins" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <!-- Right: type badge + days / status -->
                            <VerticalStackLayout Grid.Column="2" Grid.Row="0" Spacing="3"
                                                 HorizontalOptions="End" VerticalOptions="Center">
                                <Frame BackgroundColor="{Binding TypeColor, Converter={StaticResource HexToColorConverter}}"
                                       BorderColor="Transparent" CornerRadius="8" Padding="6,2"
                                       HasShadow="False" HorizontalOptions="End">
                                    <Label Text="{Binding Request.LeaveType}" TextColor="White"
                                           FontFamily="PoppinsSemiBold" FontSize="10" />
                                </Frame>
                                <Label Text="{Binding RequestedDaysText}"
                                       FontFamily="PoppinsBold" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <!-- Pending: approve + reject buttons -->
                            <HorizontalStackLayout Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                   Spacing="8"
                                                   IsVisible="{Binding Request.IsPending}">
                                <Button Text="✓ Approve"
                                        Command="{Binding BindingContext.ApproveLeaveCommand, Source={x:Reference Self}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#22C55E" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="11"
                                        CornerRadius="6" HeightRequest="28" Padding="10,0" />
                                <Button Text="✕ Reject"
                                        Command="{Binding BindingContext.RejectLeaveCommand, Source={x:Reference Self}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#EF4444" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="11"
                                        CornerRadius="6" HeightRequest="28" Padding="10,0" />
                            </HorizontalStackLayout>

                            <!-- Non-pending: status label -->
                            <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                   Text="{Binding Request.StatusRaw}"
                                   FontFamily="PoppinsMedium" FontSize="11"
                                   IsVisible="{Binding Request.IsNotPending}"
                                   TextColor="{Binding Request.StatusRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='approved|#16A34A,declined|#DC2626,#9CA3AF'}" />

                            <!-- Separator -->
                            <BoxView Grid.ColumnSpan="3" Grid.Row="1" Color="{StaticResource Divider}"
                                     HeightRequest="1" VerticalOptions="End" Margin="0,6,0,0" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- ── Pending registrations tab ─────────────────────────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" IsVisible="{Binding IsPendingTab}">

            <!-- Approve All banner -->
            <Frame Grid.Row="0" BackgroundColor="#FEF3C7" BorderColor="#FCD34D" CornerRadius="10"
                   Margin="16,8,16,0" Padding="12,10" HasShadow="False"
                   IsVisible="{Binding HasPending}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Pending Employee Requests"
                               FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#92400E" />
                        <Label Text="Review and approve or reject self-registration requests."
                               FontFamily="PoppinsRegular" FontSize="11" TextColor="#B45309" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Approve All"
                            Command="{Binding ApproveAllPendingCommand}"
                            BackgroundColor="#D97706" TextColor="White"
                            FontFamily="PoppinsSemiBold" FontSize="11"
                            CornerRadius="8" HeightRequest="36" Padding="10,0" />
                </Grid>
            </Frame>

            <CollectionView Grid.Row="1" ItemsSource="{Binding PendingEmployees}" Margin="16,8,16,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,40">
                        <Label Text="✓" FontSize="40" HorizontalOptions="Center" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="No pending registration requests." Style="{StaticResource EmptyState}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.Header>
                    <Frame Style="{StaticResource DataTableFrame}">
                        <Grid ColumnDefinitions="2*,*,110,Auto" Padding="12,10"
                              BackgroundColor="{StaticResource SurfaceElevated}">
                            <Label Grid.Column="0" Text="Name" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="1" Text="Email" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="2" Text="Requested" Style="{StaticResource DataTableHeaderLabel}" />
                            <Label Grid.Column="3" Text="Actions" Style="{StaticResource DataTableHeaderLabel}" />
                        </Grid>
                    </Frame>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Employee">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="2*,*,110,Auto" Padding="12,10"
                                  BackgroundColor="{StaticResource SurfaceCard}">
                                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                    <Frame CornerRadius="14" WidthRequest="28" HeightRequest="28"
                                           BackgroundColor="#F59E0B" Padding="0" HasShadow="False">
                                        <Label Text="{Binding Initials}" FontFamily="PoppinsSemiBold" FontSize="10"
                                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Frame>
                                    <Label Text="{Binding FullName}" Style="{StaticResource DataTableCellLabel}" />
                                </HorizontalStackLayout>
                                <Label Grid.Column="1" Text="{Binding Email, FallbackValue='—', TargetNullValue='—'}"
                                       Style="{StaticResource DataTableCellSecondary}" />
                                <Label Grid.Column="2" Text="{Binding RequestedDateDisplay}"
                                       Style="{StaticResource DataTableCellSecondary}" />
                                <HorizontalStackLayout Grid.Column="3" Spacing="6" VerticalOptions="Center">
                                    <Button Text="Approve"
                                            Command="{Binding BindingContext.ApprovePendingCommand, Source={x:Reference Self}}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#22C55E" TextColor="White"
                                            FontFamily="PoppinsSemiBold" FontSize="10"
                                            CornerRadius="6" HeightRequest="30" Padding="8,0" />
                                    <Button Text="Reject"
                                            Command="{Binding BindingContext.RejectPendingCommand, Source={x:Reference Self}}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#EF4444" TextColor="White"
                                            FontFamily="PoppinsSemiBold" FontSize="10"
                                            CornerRadius="6" HeightRequest="30" Padding="8,0" />
                                </HorizontalStackLayout>
                            </Grid>
                            <BoxView Style="{StaticResource DataTableRowDivider}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </Grid>
</ContentPage>
