<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KaiFlow.Timesheets.Views.Hr.HrDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KaiFlow.Timesheets.ViewModels.Hr"
    xmlns:models="clr-namespace:KaiFlow.Timesheets.Models"
    xmlns:shared="clr-namespace:KaiFlow.Timesheets.Views.Shared"
    xmlns:hr="clr-namespace:KaiFlow.Timesheets.Views.Hr"
    xmlns:hrcontrols="clr-namespace:KaiFlow.Timesheets.Views.Hr.Controls"
    x:DataType="vm:HrDashboardViewModel"
    x:Name="Self"
    BackgroundColor="{StaticResource SidebarBackground}"
    Shell.NavBarIsVisible="False"
    Title="HR Dashboard">

    <Grid ColumnDefinitions="Auto,*">


        <!-- ════════════════════ LEFT SIDEBAR — shared SidebarView (Phase 4) ════════════════════ -->
        <shared:SidebarView Grid.Column="0" />

        <!-- ════════════════════ CONTENT AREA ════════════════════ -->
        <Grid Grid.Column="1" BackgroundColor="{StaticResource BackgroundDark}" RowDefinitions="56,*">

            <!-- Top Header Bar — leftmost column is the sidebar toggle (always visible in all sidebar states) -->
            <Grid Grid.Row="0" BackgroundColor="{StaticResource SurfaceCard}" Padding="0,0,24,0" ColumnDefinitions="56,*,Auto">
                <BoxView Grid.ColumnSpan="3" HeightRequest="1" VerticalOptions="End" Color="{StaticResource Divider}" />
                <!-- Sidebar toggle button: cycles Expanded → Collapsed → Hidden → Expanded -->
                <Button Grid.Column="0"
                        Command="{Binding CycleSidebarModeCommand}"
                        Text="{Binding SidebarToggleIcon}"
                        FontFamily="MaterialIcons" FontSize="20"
                        BackgroundColor="Transparent" TextColor="{StaticResource TextSecondary}"
                        BorderWidth="0" VerticalOptions="Center" HorizontalOptions="Center"
                        ToolTipProperties.Text="{Binding SidebarToggleTooltip}" />
                <Label Grid.Column="1" Text="{Binding ActiveTabTitle}" Style="{StaticResource HeadlineSmall}" VerticalOptions="Center" Margin="4,0,0,0" />
                <Frame Grid.Column="2" CornerRadius="8" Padding="8,4"
                       BackgroundColor="{StaticResource SurfaceElevated}"
                       BorderColor="{StaticResource Divider}" HasShadow="False"
                       IsVisible="{Binding CurrentEmployee, Converter={StaticResource IsNotNullConverter}}">
                    <Label Text="{Binding CurrentEmployee.FullName}"
                           FontFamily="PoppinsMedium" FontSize="12" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                </Frame>
            </Grid>

            <!-- All Tab Content Panels -->
            <Grid Grid.Row="1">

                <!-- ── Tab 0: Overview ── -->
                <ScrollView IsVisible="{Binding IsOverviewTab}">
                    <VerticalStackLayout Padding="24" Spacing="18">

                        <!-- Subscription / trial banner -->
                        <Border StrokeThickness="0" Padding="14,12" IsVisible="{Binding ShowSubscriptionBanner}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.BackgroundColor>#422006</Border.BackgroundColor>
                            <Label Text="{Binding SubscriptionBannerText}" FontFamily="PoppinsMedium" FontSize="12" TextColor="#FCD34D" />
                        </Border>

                        <!-- Onboarding prompt -->
                        <Border StrokeThickness="0" Padding="14,12" IsVisible="{Binding ShowOnboardingPrompt}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.BackgroundColor>#1E3A5F</Border.BackgroundColor>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Complete your company setup wizard to unlock all features."
                                       FontFamily="PoppinsMedium" FontSize="12" TextColor="#93C5FD" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Start setup" Command="{Binding GoToOnboardingCommand}"
                                        BackgroundColor="#3B82F6" TextColor="White" FontSize="11" HeightRequest="32" Padding="12,0" CornerRadius="8" />
                            </Grid>
                        </Border>

                        <!-- Welcome Banner -->
                        <Border StrokeThickness="0" Padding="20,18">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E3A5F" Offset="0.0"/>
                                    <GradientStop Color="#0F172A" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding TimeGreeting}" FontFamily="PoppinsRegular" FontSize="13" TextColor="#94A3B8" />
                                    <Label Text="{Binding CurrentEmployee.FullName, FallbackValue='Administrator'}"
                                           FontFamily="PoppinsBold" FontSize="22" TextColor="White" />
                                    <Label Text="{Binding CurrentCompany.Name, FallbackValue=''}"
                                           FontFamily="PoppinsMedium" FontSize="13" TextColor="#60A5FA" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding TodayDate}"
                                       FontFamily="PoppinsRegular" FontSize="12" TextColor="#94A3B8"
                                       HorizontalTextAlignment="End" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- ── Self-Punch Card ── -->
                        <Border StrokeThickness="0" Padding="18,14">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0F172A" Offset="0.0"/>
                                    <GradientStop Color="#1E3A5F" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <!-- Status -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Frame CornerRadius="5" WidthRequest="10" HeightRequest="10" Padding="0"
                                               HasShadow="False" BorderColor="Transparent"
                                               BackgroundColor="{Binding AmIClockedIn, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#22C55E|#64748B'}"
                                               VerticalOptions="Center" />
                                        <Label Text="{Binding AmIClockedIn, Converter={StaticResource BoolToStringConverter}, ConverterParameter='You are Clocked In|You are Clocked Out'}"
                                               FontFamily="PoppinsSemiBold" FontSize="14" TextColor="White"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <!-- Today hours -->
                                    <Label Text="{Binding MyTodayHoursDisplay, StringFormat='Today: {0}'}"
                                           FontFamily="PoppinsRegular" FontSize="12" TextColor="#94A3B8" />
                                    <!-- Location -->
                                    <Label Text="{Binding MyPunchAddress}"
                                           FontFamily="PoppinsRegular" FontSize="11" TextColor="#64748B"
                                           IsVisible="{Binding MyPunchAddress, Converter={StaticResource IsNotNullConverter}}"
                                           LineBreakMode="TailTruncation" MaxLines="1" />
                                    <!-- Team punch link -->
                                    <Button Text="Clock in/out for my team →"
                                            Command="{Binding GoToTeamPunchCommand}"
                                            BackgroundColor="Transparent" TextColor="#60A5FA"
                                            FontFamily="PoppinsMedium" FontSize="12" Padding="0"
                                            HorizontalOptions="Start" Margin="0,2,0,0" />
                                </VerticalStackLayout>
                                <!-- Clock In/Out button -->
                                <Button Grid.Column="1"
                                        Text="{Binding MyClockButtonLabel}"
                                        Command="{Binding ClockSelfCommand}"
                                        BackgroundColor="{Binding AmIClockedIn, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#EF4444|#22C55E'}"
                                        TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="13"
                                        CornerRadius="10" HeightRequest="44" Padding="18,0"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- KPI Row 1 -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <Border Grid.Column="0" StrokeThickness="0" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F172A" Offset="0.0"/><GradientStop Color="#1E3A5F" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44" BackgroundColor="#3B82F630" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE7EF;" FontFamily="MaterialIcons" FontSize="22" TextColor="#60A5FA" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding EmployeeCount}" FontFamily="PoppinsBold" FontSize="24" TextColor="White" />
                                        <Label Text="Employees" FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" StrokeThickness="0" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F172A" Offset="0.0"/><GradientStop Color="#1E3A5F" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44" BackgroundColor="#22C55E30" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE8B5;" FontFamily="MaterialIcons" FontSize="22" TextColor="#4ADE80" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding ClockedInCount}" FontFamily="PoppinsBold" FontSize="24" TextColor="White" />
                                        <Label Text="Clocked In" FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" StrokeThickness="0" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F172A" Offset="0.0"/><GradientStop Color="#1E3A5F" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44" BackgroundColor="#F59E0B30" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE8F9;" FontFamily="MaterialIcons" FontSize="22" TextColor="#FCD34D" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding ActiveJobCount}" FontFamily="PoppinsBold" FontSize="24" TextColor="White" />
                                        <Label Text="Active Jobs" FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- KPI Row 2 -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <Border Grid.Column="0" StrokeThickness="0" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F172A" Offset="0.0"/><GradientStop Color="#1E3A5F" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44" BackgroundColor="#A855F730" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE040;" FontFamily="MaterialIcons" FontSize="22" TextColor="#C084FC" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding PendingLeaveCount}" FontFamily="PoppinsBold" FontSize="24" TextColor="White" />
                                        <Label Text="Pending Leave" FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" StrokeThickness="0" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F172A" Offset="0.0"/><GradientStop Color="#1E3A5F" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44" BackgroundColor="#EF444430" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE7F4;" FontFamily="MaterialIcons" FontSize="22" TextColor="#FCA5A5" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding OpenIncidentCount}" FontFamily="PoppinsBold" FontSize="24" TextColor="White" />
                                        <Label Text="Open Incidents" FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" StrokeThickness="0" Padding="16,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0F172A" Offset="0.0"/><GradientStop Color="#1E3A5F" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ColumnDefinitions="44,*" ColumnSpacing="12">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44" BackgroundColor="#3B82F630" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE8A1;" FontFamily="MaterialIcons" FontSize="22" TextColor="#60A5FA" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding PendingPaymentCount}" FontFamily="PoppinsBold" FontSize="24" TextColor="White" />
                                        <Label Text="Pending Pay" FontFamily="PoppinsRegular" FontSize="11" TextColor="#94A3B8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Today's Attendance -->
                        <Frame Style="{StaticResource CardFrame}" Padding="20">
                            <VerticalStackLayout Spacing="10">

                                <!-- Clocked in row -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="TODAY'S ATTENDANCE" Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" VerticalOptions="Center" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="{StaticResource TextPrimary}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding ClockedInCount}" FontFamily="PoppinsBold" TextColor="#3B82F6" />
                                                <Span Text=" / " TextColor="{StaticResource TextSecondary}" />
                                                <Span Text="{Binding EmployeeCount}" FontFamily="PoppinsSemiBold" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                                <ProgressBar Progress="{Binding AttendancePercent}" ProgressColor="#3B82F6" HeightRequest="6" />
                                <Label Text="employees currently clocked in" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />

                                <!-- On Leave Today -->
                                <BoxView Color="{StaticResource Divider}" HeightRequest="1"
                                         IsVisible="{Binding HasOnLeaveToday}" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"
                                      IsVisible="{Binding HasOnLeaveToday}">
                                    <Frame Grid.Column="0" BackgroundColor="#DCFCE7" BorderColor="Transparent"
                                           CornerRadius="6" Padding="8,3" HasShadow="False">
                                        <Label FontFamily="PoppinsSemiBold" FontSize="11" TextColor="#166534">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="🏖 " />
                                                    <Span Text="{Binding OnLeaveTodayCount}" FontFamily="PoppinsBold" />
                                                    <Span Text=" on leave" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center"
                                                         BindableLayout.ItemsSource="{Binding OnLeaveTodayNames}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Label Text="{Binding .}" FontFamily="Poppins" FontSize="12"
                                                       TextColor="#166534" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Reported Absent Today -->
                                <BoxView Color="{StaticResource Divider}" HeightRequest="1"
                                         IsVisible="{Binding HasAbsentToday}" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"
                                      IsVisible="{Binding HasAbsentToday}">
                                    <Frame Grid.Column="0" BackgroundColor="#FEF3C7" BorderColor="Transparent"
                                           CornerRadius="6" Padding="8,3" HasShadow="False">
                                        <Label FontFamily="PoppinsSemiBold" FontSize="11" TextColor="#92400E">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="🤒 " />
                                                    <Span Text="{Binding AbsentTodayCount}" FontFamily="PoppinsBold" />
                                                    <Span Text=" absent" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center"
                                                         BindableLayout.ItemsSource="{Binding AbsentTodayNames}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Label Text="{Binding .}" FontFamily="Poppins" FontSize="12"
                                                       TextColor="#92400E" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Not Yet Clocked In -->
                                <BoxView Color="{StaticResource Divider}" HeightRequest="1"
                                         IsVisible="{Binding HasNotClockedInToday}" />
                                <VerticalStackLayout Spacing="6"
                                                     IsVisible="{Binding HasNotClockedInToday}">
                                    <Label Text="NOT SIGNED IN TODAY" Style="{StaticResource LabelSection}" />
                                    <VerticalStackLayout Spacing="4"
                                                         BindableLayout.ItemsSource="{Binding NotClockedInToday}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:Employee">
                                                <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                                    <Label Grid.Column="0" Text="{Binding FullName}"
                                                           FontFamily="Poppins" FontSize="12"
                                                           TextColor="{StaticResource TextPrimary}"
                                                           VerticalOptions="Center" />
                                                    <Button Grid.Column="1" Text="Mark Absent"
                                                            Command="{Binding BindingContext.MarkAbsentCommand, Source={x:Reference Self}}"
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="#FEF3C7"
                                                            TextColor="#92400E"
                                                            BorderColor="#F59E0B" BorderWidth="1"
                                                            CornerRadius="6"
                                                            FontFamily="PoppinsMedium" FontSize="11"
                                                            Padding="10,0" HeightRequest="30" />
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Frame>

                        <!-- Quick Actions -->
                        <Frame Style="{StaticResource CardFrame}" Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="QUICK ACTIONS" Style="{StaticResource LabelSection}" />
                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="+ Add Employee" Command="{Binding GoToCreateEmployeeCommand}"
                                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                                            FontFamily="PoppinsSemiBold" FontSize="13"
                                            CornerRadius="8" Padding="16,0" HeightRequest="40" />
                                    <Button Text="+ New Job" Command="{Binding GoToCreateJobCommand}"
                                            BackgroundColor="#1E293B" TextColor="White"
                                            FontFamily="PoppinsSemiBold" FontSize="13"
                                            CornerRadius="8" Padding="16,0" HeightRequest="40" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- ── Tab 1: My Profile ── -->
                <ScrollView IsVisible="{Binding IsMyProfileTab}">
                    <VerticalStackLayout Padding="24" Spacing="16">

                        <Frame Style="{StaticResource CardFrame}" Padding="20">
                            <VerticalStackLayout Spacing="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <Frame CornerRadius="28" WidthRequest="56" HeightRequest="56"
                                           BackgroundColor="#3B82F620" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE853;" FontFamily="MaterialIcons" FontSize="28"
                                               TextColor="{StaticResource Primary}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding MyFullName}" Style="{StaticResource BodyLarge}" />
                                        <Label Text="{Binding MyEmail}" Style="{StaticResource Caption}"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding CurrentCompany.Name, FallbackValue=''}"
                                               FontFamily="PoppinsMedium" FontSize="12"
                                               TextColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>
                                </Grid>
                                <Button Text="Edit Profile"
                                        Command="{Binding GoToMyProfileCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HeightRequest="44" />
                            </VerticalStackLayout>
                        </Frame>

                        <Label Text="MY RECORD" Style="{StaticResource LabelSection}" />

                        <Frame Style="{StaticResource CardFrame}" Padding="0">
                            <VerticalStackLayout Spacing="0">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToMyPayslipsCommand}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="💰" FontSize="22" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="My Payslips" FontFamily="PoppinsMedium" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{StaticResource TextDisabled}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0" />
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToMyLeaveCommand}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="🏖" FontSize="22" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="My Leave" FontFamily="PoppinsMedium" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{StaticResource TextDisabled}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0" />
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14" ColumnSpacing="14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToMyDocumentsCommand}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="📁" FontSize="22" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="My Documents" FontFamily="PoppinsMedium" FontSize="14"
                                           TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{StaticResource TextDisabled}" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- ── Tab 2: Employees ── -->
                <Grid IsVisible="{Binding IsEmployeesTab}" RowDefinitions="Auto,*">

                    <!-- Controls: sub-tab toggle + branch picker + action button + search -->
                    <VerticalStackLayout Grid.Row="0" Spacing="8" Padding="24,12,24,8">

                        <ScrollView Orientation="Horizontal">
                            <Frame BackgroundColor="{StaticResource SurfaceCard}"
                                   CornerRadius="10" Padding="3" BorderColor="Transparent" HasShadow="False">
                                <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="2">
                                    <Button Grid.Column="0" Text="Employees"
                                            Command="{Binding SetEmployeesSubTabCommand}" CommandParameter="employees"
                                            HeightRequest="36" CornerRadius="8" FontFamily="PoppinsSemiBold" FontSize="12" Padding="12,0"
                                            BackgroundColor="{Binding EmployeesSubTab, Converter={StaticResource EqToStyleConverter}, ConverterParameter='employees|#3B82F6,Transparent'}"
                                            TextColor="{Binding EmployeesSubTab, Converter={StaticResource EqToStyleConverter}, ConverterParameter='employees|#FFFFFF,#6B7280'}" />
                                    <Button Grid.Column="1" Text="Teams"
                                            Command="{Binding SetEmployeesSubTabCommand}" CommandParameter="teams"
                                            HeightRequest="36" CornerRadius="8" FontFamily="PoppinsSemiBold" FontSize="12" Padding="12,0"
                                            BackgroundColor="{Binding EmployeesSubTab, Converter={StaticResource EqToStyleConverter}, ConverterParameter='teams|#3B82F6,Transparent'}"
                                            TextColor="{Binding EmployeesSubTab, Converter={StaticResource EqToStyleConverter}, ConverterParameter='teams|#FFFFFF,#6B7280'}" />
                                    <Button Grid.Column="2" Text="Time Templates"
                                            Command="{Binding SetEmployeesSubTabCommand}" CommandParameter="templates"
                                            HeightRequest="36" CornerRadius="8" FontFamily="PoppinsSemiBold" FontSize="12" Padding="12,0"
                                            BackgroundColor="{Binding EmployeesSubTab, Converter={StaticResource EqToStyleConverter}, ConverterParameter='templates|#3B82F6,Transparent'}"
                                            TextColor="{Binding EmployeesSubTab, Converter={StaticResource EqToStyleConverter}, ConverterParameter='templates|#FFFFFF,#6B7280'}" />
                                </Grid>
                            </Frame>
                        </ScrollView>

                        <Picker Title="All Branches"
                                ItemsSource="{Binding DashboardBranchFilters}"
                                SelectedItem="{Binding DashboardBranchFilter}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="{StaticResource SurfaceCard}"
                                HeightRequest="44" />

                        <FlexLayout Wrap="Wrap" JustifyContent="End" AlignItems="Center" Direction="Row">

                            <Button Text="Import"
                                    IsVisible="{Binding IsEmployeesSubTab}"
                                    Command="{Binding GoToImportEmployeesCommand}"
                                    BackgroundColor="{StaticResource SurfaceElevated}"
                                    TextColor="{StaticResource TextPrimary}"
                                    BorderColor="{StaticResource Divider}" BorderWidth="1"
                                    FontFamily="PoppinsSemiBold" FontSize="13"
                                    CornerRadius="8" Padding="14,0" HeightRequest="44"
                                    Margin="0,0,8,8" />

                            <Button Text="+ Add Employee"
                                    IsVisible="{Binding IsEmployeesSubTab}"
                                    Command="{Binding GoToCreateEmployeeCommand}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                    FontFamily="PoppinsSemiBold" FontSize="13"
                                    CornerRadius="8" Padding="16,0" HeightRequest="44"
                                    Margin="0,0,8,8" />

                            <Button Text="+ Create Team"
                                    IsVisible="{Binding IsTeamsSubTab}"
                                    Command="{Binding CreateTeamCommand}"
                                    BackgroundColor="{StaticResource SurfaceElevated}" TextColor="{StaticResource TextPrimary}"
                                    FontFamily="PoppinsSemiBold" FontSize="13"
                                    CornerRadius="8" Padding="14,0" HeightRequest="44"
                                    Margin="0,0,8,8" />

                            <Button Text="+ Add Template"
                                    IsVisible="{Binding IsTemplatesSubTab}"
                                    Command="{Binding AddDashboardTemplateCommand}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                    FontFamily="PoppinsSemiBold" FontSize="13"
                                    CornerRadius="8" Padding="14,0" HeightRequest="44"
                                    Margin="0,0,8,8" />

                        </FlexLayout>

                        <!-- Employee search (employees sub-tab only) -->
                        <SearchBar IsVisible="{Binding IsEmployeesSubTab}"
                                   Text="{Binding EmployeeSearch}"
                                   Placeholder="Search employees…"
                                   Margin="24,0,24,8"
                                   BackgroundColor="{StaticResource SurfaceCard}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextSecondary}" />

                        <!-- Team search (teams sub-tab only) -->
                        <SearchBar IsVisible="{Binding IsTeamsSubTab}"
                                   Text="{Binding DashboardTeamSearch}"
                                   Placeholder="Search teams…"
                                   Margin="24,0,24,8"
                                   BackgroundColor="{StaticResource SurfaceCard}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextSecondary}" />

                    </VerticalStackLayout>

                    <!-- Employees table -->
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Employees}" Margin="24,0,24,24"
                                    IsVisible="{Binding IsEmployeesSubTab}">
                        <CollectionView.EmptyView>
                            <Label Text="No employees found." Style="{StaticResource EmptyState}" Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.Header>
                            <Frame Style="{StaticResource DataTableFrame}">
                                <Grid ColumnDefinitions="2*,*,*,120,100" Padding="14,10"
                                      BackgroundColor="{StaticResource SurfaceElevated}">
                                    <Label Grid.Column="0" Text="Name" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="1" Text="Position" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="2" Text="Branch" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="3" Text="Role" Style="{StaticResource DataTableHeaderLabel}" />
                                    <Label Grid.Column="4" Text="Type" Style="{StaticResource DataTableHeaderLabel}" />
                                </Grid>
                            </Frame>
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Employee">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="2*,*,*,120,100" Padding="14,10"
                                          BackgroundColor="{StaticResource SurfaceCard}">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.ViewEmployeeDashboardCommand, Source={x:Reference Self}}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                            <Frame CornerRadius="16" WidthRequest="32" HeightRequest="32"
                                                   BackgroundColor="{StaticResource SidebarActive}" Padding="0"
                                                   BorderColor="Transparent" HasShadow="False">
                                                <Label Text="{Binding Initials}" FontFamily="PoppinsBold" FontSize="11"
                                                       TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Frame>
                                            <Label Text="{Binding FullName}" Style="{StaticResource DataTableCellLabel}"
                                                   TextColor="{StaticResource Primary}" />
                                        </HorizontalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding Position, FallbackValue='—', TargetNullValue='—'}"
                                               Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="2" Text="{Binding Branch, FallbackValue='—', TargetNullValue='—'}"
                                               Style="{StaticResource DataTableCellSecondary}" />
                                        <Label Grid.Column="3" Text="{Binding AccessLevelDisplay}"
                                               Style="{StaticResource DataTableCellLabel}" />
                                        <Label Grid.Column="4" Text="{Binding EmploymentTypeDisplay}"
                                               Style="{StaticResource DataTableCellSecondary}" />
                                    </Grid>
                                    <BoxView Style="{StaticResource DataTableRowDivider}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Teams list -->
                    <CollectionView Grid.Row="1" ItemsSource="{Binding DashboardTeams}" Margin="24,0,24,24"
                                    IsVisible="{Binding IsTeamsSubTab}">
                        <CollectionView.EmptyView>
                            <Label Text="No teams found." Style="{StaticResource EmptyState}" Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkTeam">
                                <Frame Style="{StaticResource CardFrame}" Margin="0,4" Padding="16,12">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.ViewTeamCommand, Source={x:Reference Self}}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" Style="{StaticResource BodyLarge}" />
                                            <Label Text="{Binding Description}" Style="{StaticResource Caption}"
                                                   IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />
                                        </VerticalStackLayout>
                                        <Frame Grid.Column="1" CornerRadius="6" Padding="8,4"
                                               BackgroundColor="{StaticResource SidebarActive}" BorderColor="Transparent" HasShadow="False" VerticalOptions="Center">
                                            <Label FontFamily="PoppinsMedium" FontSize="11" TextColor="{StaticResource Primary}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding MemberCount}" />
                                                        <Span Text=" members" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Frame>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Time Templates list -->
                    <ScrollView Grid.Row="1" Margin="24,0,24,24"
                                IsVisible="{Binding IsTemplatesSubTab}">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="No time templates yet. Tap '+ Add Template' to create your first one."
                                   Style="{StaticResource EmptyState}" Margin="0,40,0,0"
                                   IsVisible="{Binding DashboardTemplates.Count, Converter={StaticResource IsZeroConverter}}" />

                            <CollectionView ItemsSource="{Binding DashboardTemplates}" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:EmployeeShiftTemplate">
                                        <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">

                                                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                                    <Label Text="{Binding Name}"
                                                           Style="{StaticResource BodyLarge}"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center" />
                                                    <Frame BackgroundColor="#DCFCE7" BorderColor="Transparent"
                                                           CornerRadius="6" Padding="6,2" HasShadow="False"
                                                           VerticalOptions="Center"
                                                           IsVisible="{Binding IsDefault}">
                                                        <Label Text="Default" FontFamily="PoppinsSemiBold" FontSize="10" TextColor="#166534" />
                                                    </Frame>
                                                </HorizontalStackLayout>

                                                <Button Grid.Row="0" Grid.Column="1"
                                                        Text="Default"
                                                        IsVisible="{Binding IsDefault, Converter={StaticResource InverseBoolConverter}}"
                                                        Command="{Binding BindingContext.SetDefaultDashboardTemplateCommand, Source={x:Reference Self}}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="{StaticResource SurfaceDark}"
                                                        TextColor="{StaticResource TextSecondary}"
                                                        CornerRadius="6" FontSize="11"
                                                        Padding="8,4" HeightRequest="30" Margin="4,0" />

                                                <Button Grid.Row="0" Grid.Column="2"
                                                        Text="Edit"
                                                        Command="{Binding BindingContext.EditDashboardTemplateCommand, Source={x:Reference Self}}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="{StaticResource SurfaceDark}"
                                                        TextColor="{StaticResource Primary}"
                                                        CornerRadius="6" FontSize="12"
                                                        Padding="10,4" HeightRequest="30" Margin="4,0" />

                                                <Button Grid.Row="0" Grid.Column="3"
                                                        Text="Delete"
                                                        Command="{Binding BindingContext.DeleteDashboardTemplateCommand, Source={x:Reference Self}}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="#FEE2E2" TextColor="#DC2626"
                                                        CornerRadius="6" FontSize="12"
                                                        Padding="10,4" HeightRequest="30" />

                                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                                       Text="{Binding Summary}"
                                                       Style="{StaticResource BodySmall}"
                                                       TextColor="{StaticResource TextSecondary}" />
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>

                <!-- ── Tab 20: Leave ── -->
                <Grid IsVisible="{Binding IsLeaveTab}" RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="24,12,24,8">
                        <Label Grid.Column="0" Text="Leave requests and approvals" Style="{StaticResource Caption}" VerticalOptions="Center" />
                        <Frame Grid.Column="1" BackgroundColor="#FEF3C7" BorderColor="#F59E0B" CornerRadius="8"
                               Padding="12,0" HeightRequest="40" HasShadow="False" VerticalOptions="Center">
                            <Label VerticalOptions="Center" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="#92400E">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding PendingLeaveCount}" FontFamily="PoppinsBold" />
                                        <Span Text=" pending" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Frame>
                    </Grid>
                    <SearchBar Grid.Row="1"
                               Text="{Binding DashboardLeaveSearch}"
                               Placeholder="Search by employee or leave type…"
                               Margin="24,0,24,8"
                               BackgroundColor="{StaticResource SurfaceCard}"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource TextSecondary}" />
                    <CollectionView Grid.Row="2" ItemsSource="{Binding DashboardLeaveRequests}" Margin="24,4,24,24">
                        <CollectionView.EmptyView>
                            <Label Text="No pending leave requests." Style="{StaticResource EmptyState}" Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:LeaveRequestDisplay">
                                <Grid ColumnDefinitions="32,*,Auto" RowDefinitions="Auto,Auto"
                                      Padding="0,6" ColumnSpacing="10" RowSpacing="4" Margin="0,2">
                                    <Frame Grid.Column="0" Grid.RowSpan="2"
                                           CornerRadius="16" WidthRequest="32" HeightRequest="32"
                                           BackgroundColor="{Binding TypeColor, Converter={StaticResource HexToColorConverter}}"
                                           Padding="0" HasShadow="False" VerticalOptions="Center">
                                        <Label Text="{Binding EmployeeInitials}" TextColor="White"
                                               FontFamily="PoppinsBold" FontSize="11"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding EmployeeName}"
                                               FontFamily="PoppinsSemiBold" FontSize="13"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding PeriodText}"
                                               FontFamily="Poppins" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Grid.Row="0" Spacing="3"
                                                         HorizontalOptions="End" VerticalOptions="Center">
                                        <Frame BackgroundColor="{Binding TypeColor, Converter={StaticResource HexToColorConverter}}"
                                               BorderColor="Transparent" CornerRadius="8" Padding="6,2"
                                               HasShadow="False" HorizontalOptions="End">
                                            <Label Text="{Binding Request.LeaveType}" TextColor="White"
                                                   FontFamily="PoppinsSemiBold" FontSize="10" />
                                        </Frame>
                                        <Label Text="{Binding RequestedDaysText}"
                                               FontFamily="PoppinsBold" FontSize="11"
                                               TextColor="{StaticResource TextSecondary}"
                                               HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                           Spacing="8" IsVisible="{Binding Request.IsPending}">
                                        <Button Text="✓ Approve"
                                                Command="{Binding BindingContext.ApproveLeaveCommand, Source={x:Reference Self}}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#22C55E" TextColor="White"
                                                FontFamily="PoppinsSemiBold" FontSize="11"
                                                CornerRadius="6" HeightRequest="28" Padding="10,0" />
                                        <Button Text="✕ Reject"
                                                Command="{Binding BindingContext.RejectLeaveCommand, Source={x:Reference Self}}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#EF4444" TextColor="White"
                                                FontFamily="PoppinsSemiBold" FontSize="11"
                                                CornerRadius="6" HeightRequest="28" Padding="10,0" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                           Text="{Binding Request.StatusRaw}"
                                           FontFamily="PoppinsMedium" FontSize="11"
                                           IsVisible="{Binding Request.IsNotPending}"
                                           TextColor="{Binding Request.StatusRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='approved|#16A34A,declined|#DC2626,#9CA3AF'}" />
                                    <BoxView Grid.ColumnSpan="3" Grid.Row="1" Color="{StaticResource Divider}"
                                             HeightRequest="1" VerticalOptions="End" Margin="0,6,0,0" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- ── Tab 2: Attendance ── -->
                <Grid IsVisible="{Binding IsAttendanceTab}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

                    <!-- Period filter tabs -->
                    <ScrollView Grid.Row="0" Orientation="Horizontal" Margin="24,12,24,4">
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Today" Command="{Binding SetAttendancePeriodCommand}" CommandParameter="today"
                                    CornerRadius="20" HeightRequest="34" FontFamily="PoppinsMedium" FontSize="12" Padding="16,0"
                                    BackgroundColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='today|#3B82F6,#FFFFFF'}"
                                    TextColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='today|#FFFFFF,#6B7280'}" />
                            <Button Text="Past Week" Command="{Binding SetAttendancePeriodCommand}" CommandParameter="week"
                                    CornerRadius="20" HeightRequest="34" FontFamily="PoppinsMedium" FontSize="12" Padding="16,0"
                                    BackgroundColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='week|#3B82F6,#FFFFFF'}"
                                    TextColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='week|#FFFFFF,#6B7280'}" />
                            <Button Text="Past Month" Command="{Binding SetAttendancePeriodCommand}" CommandParameter="month"
                                    CornerRadius="20" HeightRequest="34" FontFamily="PoppinsMedium" FontSize="12" Padding="16,0"
                                    BackgroundColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='month|#3B82F6,#FFFFFF'}"
                                    TextColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='month|#FFFFFF,#6B7280'}" />
                            <Button Text="All" Command="{Binding SetAttendancePeriodCommand}" CommandParameter="all"
                                    CornerRadius="20" HeightRequest="34" FontFamily="PoppinsMedium" FontSize="12" Padding="16,0"
                                    BackgroundColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#3B82F6,#FFFFFF'}"
                                    TextColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#FFFFFF,#6B7280'}" />
                            <Button Text="Custom" Command="{Binding SetAttendancePeriodCommand}" CommandParameter="custom"
                                    CornerRadius="20" HeightRequest="34" FontFamily="PoppinsMedium" FontSize="12" Padding="16,0"
                                    BackgroundColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='custom|#8B5CF6,#FFFFFF'}"
                                    TextColor="{Binding AttendancePeriod, Converter={StaticResource EqToStyleConverter}, ConverterParameter='custom|#FFFFFF,#6B7280'}" />
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Custom date range pickers (shown only when period = custom) -->
                    <Grid Grid.Row="1" IsVisible="{Binding IsCustomPeriod}"
                          ColumnDefinitions="*,*,Auto" ColumnSpacing="8"
                          Padding="24,4,24,4">
                        <Frame Grid.Column="0" Padding="10,4" CornerRadius="8"
                               BackgroundColor="{StaticResource SurfaceCard}" BorderColor="{StaticResource Divider}" HasShadow="False">
                            <DatePicker Date="{Binding CustomAttendanceFrom}"
                                        Format="dd MMM yyyy" FontFamily="Poppins" FontSize="13"
                                        TextColor="{StaticResource TextPrimary}" />
                        </Frame>
                        <Frame Grid.Column="1" Padding="10,4" CornerRadius="8"
                               BackgroundColor="{StaticResource SurfaceCard}" BorderColor="{StaticResource Divider}" HasShadow="False">
                            <DatePicker Date="{Binding CustomAttendanceTo}"
                                        Format="dd MMM yyyy" FontFamily="Poppins" FontSize="13"
                                        TextColor="{StaticResource TextPrimary}" />
                        </Frame>
                        <Button Grid.Column="2" Text="Apply" Command="{Binding ApplyCustomRangeCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsMedium" FontSize="13"
                                CornerRadius="8" Padding="16,0" HeightRequest="44" />
                    </Grid>

                    <!-- Employee search + export buttons -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" Padding="24,4,24,4" ColumnSpacing="8">
                        <SearchBar Grid.Column="0" Text="{Binding AttendanceEmployeeSearch}"
                                   Placeholder="Search by employee…"
                                   BackgroundColor="{StaticResource SurfaceCard}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextSecondary}" />
                        <Button Grid.Column="1" Text="Excel" Command="{Binding ExportAttendanceExcelCommand}"
                                BackgroundColor="#16A34A" TextColor="White"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="44" />
                        <Button Grid.Column="2" Text="PDF" Command="{Binding ExportAttendancePdfCommand}"
                                BackgroundColor="#DC2626" TextColor="White"
                                FontFamily="PoppinsMedium" FontSize="12"
                                CornerRadius="8" Padding="12,0" HeightRequest="44" />
                    </Grid>

                    <!-- KPI summary row -->
                    <Grid Grid.Row="3" ColumnDefinitions="*,*" Margin="24,4,24,4" ColumnSpacing="12">
                        <Frame Grid.Column="0" Style="{StaticResource KpiCard}">
                            <VerticalStackLayout>
                                <Label Text="{Binding AttendanceTotalHours, StringFormat='{0:F1}h'}" Style="{StaticResource KpiNumber}" />
                                <Label Text="Total Hours" Style="{StaticResource KpiLabel}" />
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" Style="{StaticResource KpiCard}">
                            <VerticalStackLayout>
                                <Label Text="{Binding AttendanceSessionCount}" Style="{StaticResource KpiNumber}" />
                                <Label Text="Sessions" Style="{StaticResource KpiLabel}" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Full view link -->
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Padding="24,0,24,4">
                        <Label Grid.Column="0" Style="{StaticResource Caption}" VerticalOptions="Center"
                               Text="Tap a session for details" />
                        <Button Grid.Column="1" Text="Full Attendance View" Command="{Binding GoToAttendanceCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="12"
                                CornerRadius="8" Padding="14,0" HeightRequest="36" />
                    </Grid>

                    <!-- Attendance Table -->
                    <ScrollView Grid.Row="5" Margin="24,4,24,24">
                        <shared:AttendanceSessionTableView Sessions="{Binding AttendanceSessions}"
                                                             ShowEmployeeColumn="True"
                                                             EmptyMessage="No sessions in this period." />
                    </ScrollView>
                </Grid>

                <!-- ── Tab 4: Jobs ── -->
                <Grid IsVisible="{Binding IsJobsTab}" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Padding="24,12,24,4">
                        <Label Grid.Column="0" Text="Jobs" FontFamily="PoppinsSemiBold" FontSize="16"
                               TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Export" Command="{Binding WorkList.ExportCommand}"
                                BackgroundColor="{StaticResource SurfaceCard}" TextColor="{StaticResource TextPrimary}"
                                FontFamily="PoppinsMedium" FontSize="12" CornerRadius="8" Padding="14,0" HeightRequest="40" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Text="+ New Job" Command="{Binding WorkList.CreateJobCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" Padding="16,0" HeightRequest="40" />
                    </Grid>
                    <hrcontrols:HrJobsListPanel Grid.Row="1" BindingContext="{Binding WorkList}" />
                </Grid>

                <!-- ── Tab 19: Projects ── -->
                <Grid IsVisible="{Binding IsProjectsTab}" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Padding="24,12,24,4">
                        <Label Grid.Column="0" Text="Projects" FontFamily="PoppinsSemiBold" FontSize="16"
                               TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Export" Command="{Binding WorkList.ExportCommand}"
                                BackgroundColor="{StaticResource SurfaceCard}" TextColor="{StaticResource TextPrimary}"
                                FontFamily="PoppinsMedium" FontSize="12" CornerRadius="8" Padding="14,0" HeightRequest="40" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Text="+ New Project" Command="{Binding WorkList.CreateProjectCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" Padding="16,0" HeightRequest="40" />
                    </Grid>
                    <hrcontrols:HrProjectsListPanel Grid.Row="1" BindingContext="{Binding WorkList}" />
                </Grid>

                <!-- ── Tab 4: Payroll (managers cannot access) ── -->
                <Grid IsVisible="{Binding IsPayrollTab}" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="24,12,24,8">
                        <Label Grid.Column="0" Text="Payment approvals" Style="{StaticResource Caption}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Full Payroll View" Command="{Binding GoToPaymentsCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" Padding="16,0" HeightRequest="40" />
                    </Grid>
                    <ScrollView Grid.Row="1" Margin="24,4,24,24">
                        <ScrollView Orientation="Horizontal">
                            <VerticalStackLayout WidthRequest="720" Spacing="0">
                                <Frame Style="{StaticResource DataTableFrame}">
                                    <Grid ColumnDefinitions="150,120,85,85,85,80" Padding="12,10"
                                          BackgroundColor="{StaticResource SurfaceElevated}">
                                        <Label Grid.Column="0" Text="Employee" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="1" Text="Period" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="2" Text="Gross" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="3" Text="Deduct." Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="4" Text="Net" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                        <Label Grid.Column="5" Text="Status" Style="{StaticResource DataTableHeaderLabel}" />
                                    </Grid>
                                </Frame>

                                <Label Text="No payment records found."
                                       Style="{StaticResource EmptyState}"
                                       Margin="0,24"
                                       IsVisible="{Binding Payments.Count, Converter={StaticResource IsZeroConverter}}" />

                                <VerticalStackLayout Spacing="0"
                                                     BindableLayout.ItemsSource="{Binding Payments}"
                                                     IsVisible="{Binding Payments.Count, Converter={StaticResource IsNotZeroConverter}}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PaymentDisplay">
                                            <VerticalStackLayout Spacing="0">
                                                <Grid ColumnDefinitions="150,120,85,85,85,80" Padding="12,10"
                                                      BackgroundColor="{StaticResource SurfaceCard}">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding BindingContext.GoToPaymentsCommand, Source={x:Reference Self}}" />
                                                    </Grid.GestureRecognizers>
                                                    <Label Grid.Column="0" Text="{Binding EmployeeName}"
                                                           Style="{StaticResource DataTableCellLabel}"
                                                           TextColor="{StaticResource Primary}" />
                                                    <Label Grid.Column="1" Text="{Binding Payment.PeriodLabel}"
                                                           Style="{StaticResource DataTableCellSecondary}" />
                                                    <Label Grid.Column="2" Text="{Binding GrossDisplay}"
                                                           Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                                    <Label Grid.Column="3" Text="{Binding DeductionsDisplay}"
                                                           Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="End" />
                                                    <Label Grid.Column="4" Text="{Binding NetDisplay}"
                                                           Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End"
                                                           TextColor="{StaticResource Primary}" />
                                                    <Label Grid.Column="5" Text="{Binding Payment.StatusRaw}"
                                                           Style="{StaticResource DataTableCellLabel}" />
                                                </Grid>
                                                <BoxView Style="{StaticResource DataTableRowDivider}" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </ScrollView>
                    </ScrollView>
                </Grid>

                <!-- ── Tab 7: Clients ── -->
                <Grid IsVisible="{Binding IsClientsTab}" RowDefinitions="Auto,Auto,*" x:Name="ClientsTabRoot">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="24,12,24,4">
                        <SearchBar Text="{Binding ClientSearchText}" Placeholder="Search clients…"
                                   BackgroundColor="{StaticResource SurfaceDark}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextSecondary}" />
                        <Button Grid.Column="1" Text="+ Add Client" Command="{Binding AddClientCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" Padding="14,0" HeightRequest="40" Margin="8,0,0,0" />
                    </Grid>
                    <Label Grid.Row="1" Text="{Binding Clients.Count, StringFormat='{0} clients'}"
                           Style="{StaticResource Caption}" Margin="24,0,24,4" />
                    <RefreshView Grid.Row="2" Command="{Binding RefreshClientsCommand}" IsRefreshing="{Binding IsBusy}">
                        <ScrollView Orientation="Horizontal">
                            <VerticalStackLayout WidthRequest="920" Spacing="0" Margin="24,0,24,16">
                                <Frame Style="{StaticResource DataTableFrame}">
                                    <Grid ColumnDefinitions="160,90,100,120,130,110" Padding="12,10"
                                          BackgroundColor="{StaticResource SurfaceElevated}">
                                        <Label Grid.Column="0" Text="Client" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="1" Text="Code" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="2" Text="Type" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="3" Text="Contact" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="4" Text="Email" Style="{StaticResource DataTableHeaderLabel}" />
                                        <Label Grid.Column="5" Text="Phone" Style="{StaticResource DataTableHeaderLabel}" />
                                    </Grid>
                                </Frame>
                                <CollectionView ItemsSource="{Binding Clients}" SelectionMode="None"
                                                  MinimumHeightRequest="120">
                                    <CollectionView.EmptyView>
                                        <Label Text="No clients yet. Tap + Add Client."
                                               Style="{StaticResource EmptyState}" Margin="0,24" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Client">
                                            <VerticalStackLayout Spacing="0">
                                                <Grid ColumnDefinitions="160,90,100,120,130,110" Padding="12,10"
                                                      BackgroundColor="{StaticResource SurfaceCard}">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenClientCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Grid.GestureRecognizers>
                                                    <Label Grid.Column="0" Text="{Binding Name}" Style="{StaticResource DataTableCellLabel}"
                                                           TextColor="{StaticResource Primary}" />
                                                    <Label Grid.Column="1" Text="{Binding ClientCodeDisplay}" Style="{StaticResource DataTableCellLabel}" />
                                                    <Label Grid.Column="2" Text="{Binding TypeLabel}" Style="{StaticResource DataTableCellSecondary}" />
                                                    <Label Grid.Column="3" Text="{Binding ContactPerson}" Style="{StaticResource DataTableCellSecondary}" />
                                                    <Label Grid.Column="4" Text="{Binding Email}" Style="{StaticResource DataTableCellSecondary}" />
                                                    <Label Grid.Column="5" Text="{Binding Phone}" Style="{StaticResource DataTableCellSecondary}" />
                                                </Grid>
                                                <BoxView Style="{StaticResource DataTableRowDivider}" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </ScrollView>
                    </RefreshView>
                </Grid>

                <!-- ── Tab 22: My PA ── -->
                <Grid IsVisible="{Binding IsMyPaTab}">
                    <shared:MyPaSectionView BindingContext="{Binding MyPa}" />
                </Grid>

                <!-- ── Tab 16: Messages ── -->
                <Grid IsVisible="{Binding IsMessagesTab}" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="24,12">
                        <Label Text="Messages" Style="{StaticResource HeadlineSmall}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+ New Thread" Command="{Binding NewThreadCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" Padding="16,0" HeightRequest="44" />
                    </Grid>
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Threads}" Margin="24,0,24,24">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Margin="0,40,0,0">
                                <Label Text="No conversations yet." Style="{StaticResource EmptyState}" />
                                <Label Text="Tap '+ New Thread' to message an employee."
                                       Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MessageThread">
                                <Frame Style="{StaticResource CardFrame}" Margin="0,4" Padding="16,12">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.OpenThreadCommand, Source={x:Reference Self}}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding ListTitle}"
                                               Style="{StaticResource BodyLarge}" />
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding LastMessageAtDisplay}"
                                               Style="{StaticResource Caption}"
                                               IsVisible="{Binding LastMessageAt, Converter={StaticResource IsNotNullConverter}}" />
                                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding LastMessagePreview, FallbackValue='No messages yet'}"
                                               Style="{StaticResource Caption}" MaxLines="1" LineBreakMode="TailTruncation" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- ══════════════════ WORKSPACE PANELS (tabs 6,8,9,10,11,12,13,14,15,16,18,21) ══════════════════ -->
                <!-- Each panel uses a ContentView to switch BindingContext to its sub-ViewModel.                     -->
                <!-- x:DataType="{x:Null}" on the inner Grid disables compiled bindings for the sub-VM scope.        -->
                <!-- Row taps use {Binding BindingContext.Cmd, Source={x:Reference XxxPanel}} for reliability.       -->

                <!-- ══════════════════════════════════════════════════════════════ -->
                <!-- Tab 6: Contractors workspace (tabbed: Contractors | Activity) -->
                <!-- ══════════════════════════════════════════════════════════════ -->
                <Grid IsVisible="{Binding IsContractorsTab}">
                    <ContentView x:Name="ContractorsPanel" BindingContext="{Binding ContractorsVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,*">

                            <!-- ── Sub-tab bar ─────────────────────────────────────── -->
                            <HorizontalStackLayout Grid.Row="0" Spacing="6" Padding="16,8,16,4">
                                <Button Text="Contractors"
                                        Command="{Binding ShowContractorsSubTabCommand}"
                                        BackgroundColor="{Binding IsContractorsSubTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                                        TextColor="{Binding IsContractorsSubTab,       Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                                <Button Text="Activity / Actions"
                                        Command="{Binding ShowActivitySubTabCommand}"
                                        BackgroundColor="{Binding IsActivitySubTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#1E293B'}"
                                        TextColor="{Binding IsActivitySubTab,       Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#94A3B8'}"
                                        FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                        Padding="12,0" HeightRequest="34" BorderWidth="0" />
                            </HorizontalStackLayout>

                            <!-- ── Contractors panel ──────────────────────────────── -->
                            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*"
                                  IsVisible="{Binding IsContractorsSubTab}">
                                <SearchBar Grid.Row="0" Text="{Binding SearchText}" Placeholder="Search contractors…"
                                           BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource TextPrimary}"
                                           PlaceholderColor="{StaticResource TextSecondary}" Margin="8,4,8,0" />
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="16,6,16,4" ColumnSpacing="6">
                                    <Button Text="Active"   Command="{Binding ShowActiveCommand}"
                                            BackgroundColor="{Binding IsActiveFilter,   Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                                            TextColor="{Binding IsActiveFilter,         Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                                            FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14" Padding="12,0" HeightRequest="32" BorderWidth="0" />
                                    <Button Grid.Column="1" Text="Inactive" Command="{Binding ShowInactiveCommand}"
                                            BackgroundColor="{Binding IsInactiveFilter, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                                            TextColor="{Binding IsInactiveFilter,       Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                                            FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14" Padding="12,0" HeightRequest="32" BorderWidth="0" />
                                    <Button Grid.Column="2" Text="All"      Command="{Binding ShowAllCommand}"
                                            BackgroundColor="{Binding IsAllFilter,      Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1E3A5F|#1E293B'}"
                                            TextColor="{Binding IsAllFilter,            Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFFFFF|#64748B'}"
                                            FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14" Padding="12,0" HeightRequest="32" BorderWidth="0" />
                                    <Label Grid.Column="3" Text="{Binding Contractors.Count, StringFormat='{0} contractors'}"
                                           Style="{StaticResource Caption}" VerticalOptions="Center" Margin="8,0,0,0" />
                                    <Button Grid.Column="4" Text="⚙ Packs"
                                            Command="{Binding OpenCompliancePacksCommand}"
                                            BackgroundColor="#1E293B" TextColor="#94A3B8"
                                            FontFamily="PoppinsMedium" FontSize="12" CornerRadius="14"
                                            Padding="12,0" HeightRequest="32" BorderWidth="0" />
                                    <Button Grid.Column="5" Text="+ Add" Command="{Binding CreateCommand}"
                                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                                            FontFamily="PoppinsSemiBold" FontSize="13" CornerRadius="8" Padding="16,0" HeightRequest="40" />
                                </Grid>
                                <!-- 10-column contractors table (Company185|Code90|Contact130|Phone120|Email160|Rating70|Banking85|Payment80|Compliance100|Status80) -->
                                <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
                                    <ScrollView Orientation="Horizontal">
                                        <VerticalStackLayout WidthRequest="1100" Spacing="0" Margin="16,0">
                                            <Frame Style="{StaticResource DataTableFrame}">
                                                <Grid ColumnDefinitions="185,90,130,120,160,70,85,80,100,80" Padding="12,10" BackgroundColor="{StaticResource SurfaceElevated}">
                                                    <Label Grid.Column="0" Text="Company"    Style="{StaticResource DataTableHeaderLabel}" />
                                                    <Label Grid.Column="1" Text="Code"       Style="{StaticResource DataTableHeaderLabel}" />
                                                    <Label Grid.Column="2" Text="Contact"    Style="{StaticResource DataTableHeaderLabel}" />
                                                    <Label Grid.Column="3" Text="Phone"      Style="{StaticResource DataTableHeaderLabel}" />
                                                    <Label Grid.Column="4" Text="Email"      Style="{StaticResource DataTableHeaderLabel}" />
                                                    <Label Grid.Column="5" Text="Rating"     Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="6" Text="Banking"    Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="7" Text="Payment"    Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="8" Text="Compliance" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="9" Text="Status"     Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                                </Grid>
                                            </Frame>
                                            <CollectionView ItemsSource="{Binding Contractors}">
                                                <CollectionView.EmptyView>
                                                    <Label Text="No contractors yet. Tap + Add to register one." Style="{StaticResource EmptyState}" Margin="0,24" />
                                                </CollectionView.EmptyView>
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:Contractor">
                                                        <VerticalStackLayout Spacing="0">
                                                            <Grid ColumnDefinitions="185,90,130,120,160,70,85,80,100,80" Padding="12,10" BackgroundColor="{StaticResource SurfaceCard}">
                                                                <Grid.GestureRecognizers>
                                                                    <TapGestureRecognizer
                                                                        Command="{Binding BindingContext.OpenCommand, Source={x:Reference ContractorsPanel}}"
                                                                        CommandParameter="{Binding .}" />
                                                                </Grid.GestureRecognizers>
                                                                <Label Grid.Column="0" Text="{Binding Name}"                  Style="{StaticResource DataTableCellLabel}" TextColor="{StaticResource Primary}" />
                                                                <Label Grid.Column="1" Text="{Binding ContractorCodeDisplay}" Style="{StaticResource DataTableCellSecondary}" FontFamily="PoppinsMedium" />
                                                                <Label Grid.Column="2" Text="{Binding ContactPerson}"         Style="{StaticResource DataTableCellSecondary}" LineBreakMode="TailTruncation" />
                                                                <Label Grid.Column="3" Text="{Binding Phone, FallbackValue='—'}"  Style="{StaticResource DataTableCellSecondary}" />
                                                                <Label Grid.Column="4" Text="{Binding Email, FallbackValue='—'}"  Style="{StaticResource DataTableCellSecondary}" LineBreakMode="TailTruncation" />
                                                                <Label Grid.Column="5" Text="{Binding RatingDisplay}"         Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="Center" />
                                                                <Frame Grid.Column="6" CornerRadius="8" Padding="8,3" HasShadow="False" BorderColor="Transparent"
                                                                       BackgroundColor="{Binding BankingStatusBg}" HorizontalOptions="Center" VerticalOptions="Center">
                                                                    <Label Text="{Binding BankingStatusText}" FontFamily="PoppinsMedium" FontSize="10" TextColor="{Binding BankingStatusFg}" />
                                                                </Frame>
                                                                <Frame Grid.Column="7" CornerRadius="8" Padding="8,3" HasShadow="False" BorderColor="Transparent"
                                                                       BackgroundColor="{Binding PaymentStatusBg}" HorizontalOptions="Center" VerticalOptions="Center">
                                                                    <Label Text="{Binding PaymentStatusText}" FontFamily="PoppinsMedium" FontSize="10" TextColor="{Binding PaymentStatusFg}" />
                                                                </Frame>
                                                                <Frame Grid.Column="8" CornerRadius="8" Padding="8,3" HasShadow="False" BorderColor="Transparent"
                                                                       BackgroundColor="{Binding ComplianceStatusBg}" HorizontalOptions="Center" VerticalOptions="Center">
                                                                    <Label Text="{Binding ComplianceStatusText}" FontFamily="PoppinsMedium" FontSize="10" TextColor="{Binding ComplianceStatusFg}" />
                                                                </Frame>
                                                                <Frame Grid.Column="9" CornerRadius="10" Padding="8,3" HasShadow="False" BorderColor="Transparent"
                                                                       BackgroundColor="{Binding StatusBadgeBackground}" HorizontalOptions="End" VerticalOptions="Center">
                                                                    <Label Text="{Binding StatusLabel}" FontFamily="PoppinsMedium" FontSize="11" TextColor="{Binding StatusBadgeTextColor}" />
                                                                </Frame>
                                                            </Grid>
                                                            <BoxView Style="{StaticResource DataTableRowDivider}" />
                                                        </VerticalStackLayout>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </ScrollView>
                                </RefreshView>
                            </Grid>

                            <!-- ── Activity / Actions panel ───────────────────────── -->
                            <ScrollView Grid.Row="1" IsVisible="{Binding IsActivitySubTab}">
                                <VerticalStackLayout Padding="16,4,16,24" Spacing="12">

                                    <!-- ── Summary counters (Polish item 2) ──────────── -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Frame CornerRadius="8" Padding="10,6" HasShadow="False"
                                               BackgroundColor="#1E3A5F" BorderColor="Transparent">
                                            <VerticalStackLayout Spacing="1">
                                                <Label Text="{Binding PendingQuotesCount}"
                                                       FontFamily="PoppinsBold" FontSize="18"
                                                       TextColor="#60A5FA" HorizontalTextAlignment="Center" />
                                                <Label Text="Pending Quotes"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="#93C5FD" HorizontalTextAlignment="Center" />
                                            </VerticalStackLayout>
                                        </Frame>
                                        <Frame CornerRadius="8" Padding="10,6" HasShadow="False"
                                               BackgroundColor="#29200E" BorderColor="Transparent">
                                            <VerticalStackLayout Spacing="1">
                                                <Label Text="{Binding PendingBankingCount}"
                                                       FontFamily="PoppinsBold" FontSize="18"
                                                       TextColor="#FCD34D" HorizontalTextAlignment="Center" />
                                                <Label Text="Banking Reviews"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="#FDE68A" HorizontalTextAlignment="Center" />
                                            </VerticalStackLayout>
                                        </Frame>
                                        <Frame CornerRadius="8" Padding="10,6" HasShadow="False"
                                               BackgroundColor="#3B0E0E" BorderColor="Transparent">
                                            <VerticalStackLayout Spacing="1">
                                                <Label Text="{Binding PendingDocumentsCount}"
                                                       FontFamily="PoppinsBold" FontSize="18"
                                                       TextColor="#FCA5A5" HorizontalTextAlignment="Center" />
                                                <Label Text="Pending Docs"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="#FECACA" HorizontalTextAlignment="Center" />
                                            </VerticalStackLayout>
                                        </Frame>
                                        <Frame CornerRadius="8" Padding="10,6" HasShadow="False"
                                               BackgroundColor="#3B1700" BorderColor="Transparent">
                                            <VerticalStackLayout Spacing="1">
                                                <Label Text="{Binding ExpiringDocumentsCount}"
                                                       FontFamily="PoppinsBold" FontSize="18"
                                                       TextColor="#FB923C" HorizontalTextAlignment="Center" />
                                                <Label Text="Expiring Docs"
                                                       FontFamily="PoppinsRegular" FontSize="10"
                                                       TextColor="#FDBA74" HorizontalTextAlignment="Center" />
                                            </VerticalStackLayout>
                                        </Frame>
                                    </HorizontalStackLayout>

                                    <!-- ── A. Needs Approval / Action (collapsible — Polish items 3 + 5) ── -->
                                    <Frame Style="{StaticResource CardFrame}" Padding="0">
                                        <VerticalStackLayout>
                                            <!-- Section header — tap to collapse/expand (item 3) -->
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="14,11,8,11">
                                                <Label Grid.Column="0"
                                                       Text="{Binding NeedsApprovalHeader}"
                                                       FontFamily="PoppinsSemiBold" FontSize="11"
                                                       TextColor="{StaticResource Primary}"
                                                       VerticalOptions="Center" />
                                                <Button Grid.Column="1"
                                                        Text="{Binding NeedsApprovalChevron}"
                                                        Command="{Binding ToggleNeedsApprovalCommand}"
                                                        BackgroundColor="Transparent"
                                                        TextColor="{StaticResource TextSecondary}"
                                                        FontFamily="PoppinsRegular" FontSize="13"
                                                        BorderWidth="0" HeightRequest="30" Padding="6,0" />
                                                <Button Grid.Column="2" Text="↻"
                                                        Command="{Binding RefreshActivityCommand}"
                                                        BackgroundColor="Transparent"
                                                        TextColor="{StaticResource TextSecondary}"
                                                        FontFamily="PoppinsRegular" FontSize="13"
                                                        BorderWidth="0" HeightRequest="30" Padding="6,0" />
                                            </Grid>

                                            <!-- Collapsible body (item 3) -->
                                            <VerticalStackLayout IsVisible="{Binding IsNeedsApprovalExpanded}">
                                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />

                                                <!-- Table column header -->
                                                <Grid ColumnDefinitions="108,*,48,80,70" ColumnSpacing="8"
                                                      Padding="14,6" BackgroundColor="{StaticResource SurfaceDark}">
                                                    <Label Grid.Column="0" Text="Type"
                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                           TextColor="{StaticResource TextSecondary}" />
                                                    <Label Grid.Column="1" Text="Contractor  ·  Summary"
                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                           TextColor="{StaticResource TextSecondary}" />
                                                    <Label Grid.Column="2" Text="Wait"
                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                           TextColor="{StaticResource TextSecondary}"
                                                           HorizontalTextAlignment="End" />
                                                    <Label Grid.Column="3" Text="Submitted"
                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                           TextColor="{StaticResource TextSecondary}"
                                                           HorizontalTextAlignment="End" />
                                                    <Label Grid.Column="4" Text=""
                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                           TextColor="{StaticResource TextSecondary}" />
                                                </Grid>

                                                <!-- Action items list -->
                                                <CollectionView ItemsSource="{Binding ActionItems}" Margin="0,0,0,4">
                                                    <CollectionView.EmptyView>
                                                        <Label Text="✓  No pending contractor actions"
                                                               FontFamily="PoppinsRegular" FontSize="12"
                                                               TextColor="{StaticResource TextSecondary}"
                                                               Margin="14,12,14,12" />
                                                    </CollectionView.EmptyView>
                                                    <CollectionView.ItemTemplate>
                                                        <DataTemplate x:DataType="models:ContractorActionItem">
                                                            <VerticalStackLayout>
                                                                <!-- 5 columns: Badge | Contractor+Summary | Waiting | Date | Open -->
                                                                <Grid ColumnDefinitions="108,*,48,80,70"
                                                                      ColumnSpacing="8" Padding="14,9">
                                                                    <!-- Type badge (item 4 — severity colours) -->
                                                                    <Frame Grid.Column="0" CornerRadius="5" Padding="6,3"
                                                                           HasShadow="False" BorderColor="Transparent"
                                                                           BackgroundColor="{Binding ActionTypeBadgeBg}"
                                                                           VerticalOptions="Center">
                                                                        <Label Text="{Binding ActionTypeLabel}"
                                                                               FontFamily="PoppinsMedium" FontSize="10"
                                                                               TextColor="{Binding ActionTypeBadgeFg}"
                                                                               LineBreakMode="NoWrap" />
                                                                    </Frame>
                                                                    <!-- Contractor name + summary (item 1 — no "Unknown") -->
                                                                    <VerticalStackLayout Grid.Column="1" Spacing="1"
                                                                                         VerticalOptions="Center">
                                                                        <Label Text="{Binding ContractorDisplay}"
                                                                               FontFamily="PoppinsMedium" FontSize="12"
                                                                               TextColor="{StaticResource TextPrimary}"
                                                                               LineBreakMode="TailTruncation" />
                                                                        <Label Text="{Binding Summary}"
                                                                               FontFamily="PoppinsRegular" FontSize="11"
                                                                               TextColor="{StaticResource TextSecondary}"
                                                                               LineBreakMode="TailTruncation" />
                                                                    </VerticalStackLayout>
                                                                    <!-- Waiting time (item 5) -->
                                                                    <Label Grid.Column="2"
                                                                           Text="{Binding WaitingDisplay}"
                                                                           FontFamily="PoppinsMedium" FontSize="11"
                                                                           TextColor="#FDBA74"
                                                                           VerticalOptions="Center"
                                                                           HorizontalTextAlignment="End" />
                                                                    <!-- Submitted date -->
                                                                    <Label Grid.Column="3"
                                                                           Text="{Binding CreatedAtDisplay}"
                                                                           FontFamily="PoppinsRegular" FontSize="11"
                                                                           TextColor="{StaticResource TextSecondary}"
                                                                           VerticalOptions="Center"
                                                                           HorizontalTextAlignment="End" />
                                                                    <!-- Open button (WinUI-reliable: Button.Command) -->
                                                                    <Button Grid.Column="4" Text="Open →"
                                                                            Command="{Binding BindingContext.OpenActionItemCommand, Source={x:Reference ContractorsPanel}}"
                                                                            CommandParameter="{Binding .}"
                                                                            BackgroundColor="Transparent"
                                                                            TextColor="{StaticResource Primary}"
                                                                            FontFamily="PoppinsMedium" FontSize="11"
                                                                            BorderWidth="0" HeightRequest="30" Padding="0" />
                                                                </Grid>
                                                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.25" />
                                                            </VerticalStackLayout>
                                                        </DataTemplate>
                                                    </CollectionView.ItemTemplate>
                                                </CollectionView>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Frame>

                                    <!-- ── B. Recent Contractor Activity ──────────── -->
                                    <Frame Style="{StaticResource CardFrame}" Padding="0">
                                        <VerticalStackLayout>
                                            <!-- Section header + filter -->
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="14,10,10,8" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="RECENT CONTRACTOR ACTIVITY"
                                                       FontFamily="PoppinsSemiBold" FontSize="11"
                                                       TextColor="{StaticResource Primary}"
                                                       VerticalOptions="Center" />
                                                <Picker Grid.Column="1"
                                                        ItemsSource="{Binding ActivityFilterOptions}"
                                                        SelectedItem="{Binding ActivityFilter, Mode=TwoWay}"
                                                        TitleColor="{StaticResource TextSecondary}"
                                                        TextColor="{StaticResource TextPrimary}"
                                                        FontFamily="PoppinsRegular" FontSize="11"
                                                        WidthRequest="130" />
                                                <ActivityIndicator Grid.Column="2"
                                                                   IsRunning="{Binding ActivityLoading}"
                                                                   IsVisible="{Binding ActivityLoading}"
                                                                   Color="{StaticResource Primary}"
                                                                   HeightRequest="18" WidthRequest="18" />
                                            </Grid>
                                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.4" />

                                            <!-- Table header -->
                                            <Grid ColumnDefinitions="80,100,*,80,70" ColumnSpacing="8"
                                                  Padding="14,7,14,7" BackgroundColor="{StaticResource SurfaceDark}">
                                                <Label Grid.Column="0" Text="Date"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" />
                                                <Label Grid.Column="1" Text="Event"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" />
                                                <Label Grid.Column="2" Text="Contractor  ·  Summary"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}" />
                                                <Label Grid.Column="3" Text="Source"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       HorizontalTextAlignment="End" />
                                                <Label Grid.Column="4" Text="Open"
                                                       FontFamily="PoppinsMedium" FontSize="10"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       HorizontalTextAlignment="End" />
                                            </Grid>

                                            <!-- Activity rows -->
                                            <CollectionView ItemsSource="{Binding FilteredActivityItems}"
                                                            Margin="0,0,0,4">
                                                <CollectionView.EmptyView>
                                                    <Label Text="No recent contractor activity."
                                                           FontFamily="PoppinsRegular" FontSize="12"
                                                           TextColor="{StaticResource TextSecondary}"
                                                           Margin="14,12,14,12" />
                                                </CollectionView.EmptyView>
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ContractorActivityEvent">
                                                        <VerticalStackLayout>
                                                            <Grid ColumnDefinitions="80,100,*,80,70"
                                                                  ColumnSpacing="8" Padding="14,8">
                                                                <!-- Date -->
                                                                <Label Grid.Column="0"
                                                                       Text="{Binding CreatedAtDisplay}"
                                                                       FontFamily="PoppinsRegular" FontSize="11"
                                                                       TextColor="{StaticResource TextSecondary}"
                                                                       VerticalOptions="Center" />
                                                                <!-- Event badge -->
                                                                <Frame Grid.Column="1" CornerRadius="5" Padding="6,3"
                                                                       HasShadow="False" BorderColor="Transparent"
                                                                       BackgroundColor="{Binding EventTypeBadgeBg}"
                                                                       VerticalOptions="Center">
                                                                    <Label Text="{Binding EventLabel}"
                                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                                           TextColor="{Binding EventLabelColor}"
                                                                           LineBreakMode="NoWrap" />
                                                                </Frame>
                                                                <!-- Contractor + summary -->
                                                                <VerticalStackLayout Grid.Column="2" Spacing="1"
                                                                                     VerticalOptions="Center">
                                                                    <Label Text="{Binding ContractorDisplay}"
                                                                           FontFamily="PoppinsMedium" FontSize="12"
                                                                           TextColor="{StaticResource TextPrimary}"
                                                                           LineBreakMode="TailTruncation" />
                                                                    <Label Text="{Binding Summary}"
                                                                           FontFamily="PoppinsRegular" FontSize="11"
                                                                           TextColor="{StaticResource TextSecondary}"
                                                                           LineBreakMode="TailTruncation" />
                                                                </VerticalStackLayout>
                                                                <!-- Source badge (HR / Portal) -->
                                                                <Frame Grid.Column="3" CornerRadius="5" Padding="6,3"
                                                                       HasShadow="False" BorderColor="Transparent"
                                                                       BackgroundColor="{Binding SourceBadgeBg}"
                                                                       VerticalOptions="Center"
                                                                       HorizontalOptions="End">
                                                                    <Label Text="{Binding Source}"
                                                                           FontFamily="PoppinsMedium" FontSize="10"
                                                                           TextColor="{Binding SourceBadgeFg}" />
                                                                </Frame>
                                                                <!-- Open button navigates to contractor + tab -->
                                                                <Button Grid.Column="4" Text="Open →"
                                                                        Command="{Binding BindingContext.OpenActivityEventCommand, Source={x:Reference ContractorsPanel}}"
                                                                        CommandParameter="{Binding .}"
                                                                        BackgroundColor="Transparent"
                                                                        TextColor="{StaticResource Primary}"
                                                                        FontFamily="PoppinsMedium" FontSize="11"
                                                                        BorderWidth="0" HeightRequest="30"
                                                                        HorizontalOptions="End" Padding="0" />
                                                            </Grid>
                                                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Opacity="0.2" />
                                                        </VerticalStackLayout>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </Frame>

                                </VerticalStackLayout>
                            </ScrollView>

                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 8: Inventory workspace ── -->
                <Grid IsVisible="{Binding IsInventoryTab}">
                    <ContentView x:Name="InventoryPanel" BindingContext="{Binding InventoryVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Padding="16,8,16,4">
                                <Label Text="Inventory" Style="{StaticResource HeadlineSmall}" VerticalOptions="Center" />
                                <!-- Suppliers button restored from HrInventoryPage ToolbarItem -->
                                <Button Grid.Column="1" Text="Suppliers" Command="{Binding GoToSuppliersCommand}"
                                        Style="{StaticResource TextButton}" FontSize="13" />
                                <Button Grid.Column="2" Text="Export" Command="{Binding ExportCommand}"
                                        Style="{StaticResource TextButton}" FontSize="13" />
                                <Button Grid.Column="3" Text="+ Add" Command="{Binding CreateItemCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="13" CornerRadius="8" Padding="16,0" HeightRequest="40" />
                            </Grid>
                            <SearchBar Grid.Row="1" Text="{Binding SearchText}" Placeholder="Search name, SKU, supplier…"
                                       BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource TextPrimary}"
                                       PlaceholderColor="{StaticResource TextSecondary}" Margin="8,4,8,0" />
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="16,4,16,4">
                                <Label Text="{Binding Items.Count, StringFormat='{0} items'}" Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource TextButton}" FontSize="13" />
                            </Grid>
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="16,0,16,4">
                                <Label Text="Low stock only" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                                <Switch Grid.Column="1" IsToggled="{Binding ShowLowStockOnly}" OnColor="{StaticResource Primary}" />
                            </Grid>
                            <RefreshView Grid.Row="4" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
                                <ScrollView Orientation="Horizontal">
                                    <VerticalStackLayout WidthRequest="1020" Spacing="0" Margin="16,0">
                                        <Frame Style="{StaticResource DataTableFrame}">
                                            <Grid ColumnDefinitions="160,80,140,90,90,100,100,70" Padding="12,10" BackgroundColor="{StaticResource SurfaceElevated}">
                                                <Label Grid.Column="0" Text="Item"        Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="1" Text="SKU"         Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="2" Text="Supplier"    Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="3" Text="On hand"     Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="4" Text="Unit"        Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="5" Text="Unit cost"   Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="6" Text="Stock value" Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                                <Label Grid.Column="7" Text="Alert"       Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                            </Grid>
                                        </Frame>
                                        <CollectionView ItemsSource="{Binding Items}">
                                            <CollectionView.EmptyView>
                                                <Label Text="No inventory items. Tap + Add to create one." Style="{StaticResource EmptyState}" Margin="0,24" />
                                            </CollectionView.EmptyView>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="models:InventoryItem">
                                                    <VerticalStackLayout Spacing="0">
                                                        <Grid ColumnDefinitions="160,80,140,90,90,100,100,70" Padding="12,10"
                                                              BackgroundColor="{Binding NeedsReorder, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FEF2F2|#FFFFFF'}">
                                                            <Grid.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding BindingContext.OpenItemCommand, Source={x:Reference InventoryPanel}}"
                                                                    CommandParameter="{Binding .}" />
                                                            </Grid.GestureRecognizers>
                                                            <Label Grid.Column="0" Text="{Binding Name}"           Style="{StaticResource DataTableCellLabel}" TextColor="{StaticResource Primary}" />
                                                            <Label Grid.Column="1" Text="{Binding Sku}"            Style="{StaticResource DataTableCellSecondary}" />
                                                            <Label Grid.Column="2" Text="{Binding SupplierDisplay}" Style="{StaticResource DataTableCellSecondary}" />
                                                            <Label Grid.Column="3" Text="{Binding QuantityOnHand, StringFormat='{0:N1}'}" Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="4" Text="{Binding UnitOfMeasure}"  Style="{StaticResource DataTableCellSecondary}" />
                                                            <Label Grid.Column="5" Text="{Binding UnitCostDisplay}" Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="6" Text="{Binding StockValueDisplay}" Style="{StaticResource DataTableCellLabel}" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="7" Text="{Binding NeedsReorder, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Low|OK'}"
                                                                   Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="End"
                                                                   TextColor="{Binding NeedsReorder, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F87171|#9CA3AF'}" />
                                                        </Grid>
                                                        <BoxView Style="{StaticResource DataTableRowDivider}" />
                                                    </VerticalStackLayout>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </ScrollView>
                            </RefreshView>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 21: Suppliers workspace ── -->
                <Grid IsVisible="{Binding IsSuppliersTab}">
                    <ContentView x:Name="SuppliersPanel" BindingContext="{Binding SuppliersVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,Auto,*">
                            <SearchBar Grid.Row="0" Text="{Binding SearchText}" Placeholder="Search suppliers…"
                                       BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource TextPrimary}"
                                       PlaceholderColor="{StaticResource TextSecondary}" Margin="8,8,8,0" />
                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="16,8,16,4">
                                <Label Text="{Binding Suppliers.Count, StringFormat='{0} suppliers'}" Style="{StaticResource Caption}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource TextButton}" FontSize="13" />
                                <Button Grid.Column="2" Text="+ Add" Command="{Binding CreateCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="13" CornerRadius="8" Padding="16,0" HeightRequest="40" />
                            </Grid>
                            <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
                                <ScrollView Orientation="Horizontal">
                                    <VerticalStackLayout WidthRequest="900" Spacing="0" Margin="16,0">
                                        <Frame Style="{StaticResource DataTableFrame}">
                                            <Grid ColumnDefinitions="200,140,160,140,120" Padding="12,10" BackgroundColor="{StaticResource SurfaceElevated}">
                                                <Label Grid.Column="0" Text="Supplier"      Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="1" Text="Contact"       Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="2" Text="Phone / Email" Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="3" Text="Address"       Style="{StaticResource DataTableHeaderLabel}" />
                                                <Label Grid.Column="4" Text="Status"        Style="{StaticResource DataTableHeaderLabel}" HorizontalTextAlignment="End" />
                                            </Grid>
                                        </Frame>
                                        <CollectionView ItemsSource="{Binding Suppliers}">
                                            <CollectionView.EmptyView>
                                                <Label Text="No suppliers yet. Add suppliers here or from an inventory item." Style="{StaticResource EmptyState}" Margin="0,24" />
                                            </CollectionView.EmptyView>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="models:Contractor">
                                                    <VerticalStackLayout Spacing="0">
                                                        <Grid ColumnDefinitions="200,140,160,140,120" Padding="12,10" BackgroundColor="{StaticResource SurfaceCard}">
                                                            <Grid.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding BindingContext.OpenCommand, Source={x:Reference SuppliersPanel}}"
                                                                    CommandParameter="{Binding .}" />
                                                            </Grid.GestureRecognizers>
                                                            <Label Grid.Column="0" Text="{Binding Name}"         Style="{StaticResource DataTableCellLabel}" TextColor="{StaticResource Primary}" />
                                                            <Label Grid.Column="1" Text="{Binding ContactPerson}" Style="{StaticResource DataTableCellSecondary}" />
                                                            <Label Grid.Column="2" Text="{Binding ContactDisplay}" Style="{StaticResource DataTableCellSecondary}" />
                                                            <Label Grid.Column="3" Text="{Binding Address}"      Style="{StaticResource DataTableCellSecondary}" LineBreakMode="TailTruncation" />
                                                            <Label Grid.Column="4" Text="{Binding StatusLabel}"  Style="{StaticResource DataTableCellSecondary}" HorizontalTextAlignment="End" />
                                                        </Grid>
                                                        <BoxView Style="{StaticResource DataTableRowDivider}" />
                                                    </VerticalStackLayout>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </ScrollView>
                            </RefreshView>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 9: Assets workspace ── -->
                <Grid IsVisible="{Binding IsAssetsTab}">
                    <ContentView x:Name="AssetsPanel" BindingContext="{Binding AssetsVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,8,16,4">
                                <Frame Style="{StaticResource KpiCard}" Grid.Column="0">
                                    <Label Text="{Binding WarrantyExpiringSoon, StringFormat='{0} warranties expiring in 30 days'}"
                                           Style="{StaticResource BodyMedium}" TextColor="{StaticResource Accent}" />
                                </Frame>
                                <Button Grid.Column="1" Text="+ Asset" Command="{Binding CreateAssetCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="13" CornerRadius="8" Padding="16,0" HeightRequest="40" Margin="8,0,0,0" />
                            </Grid>
                            <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
                                <CollectionView ItemsSource="{Binding Assets}" Margin="16,0">
                                    <CollectionView.EmptyView>
                                        <Label Text="No assets registered." Style="{StaticResource EmptyState}" />
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Asset">
                                            <SwipeView Margin="0,4">
                                                <SwipeView.RightItems>
                                                    <SwipeItems>
                                                        <SwipeItem Text="Delete" BackgroundColor="{StaticResource Error}"
                                                                   Command="{Binding BindingContext.DeleteAssetCommand, Source={x:Reference AssetsPanel}}"
                                                                   CommandParameter="{Binding .}" />
                                                    </SwipeItems>
                                                </SwipeView.RightItems>
                                                <Frame Style="{StaticResource CardFrame}">
                                                    <Frame.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding BindingContext.EditAssetCommand, Source={x:Reference AssetsPanel}}"
                                                            CommandParameter="{Binding .}" />
                                                    </Frame.GestureRecognizers>
                                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding DisplayName}" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                                        <Frame Grid.Row="0" Grid.Column="1" BorderColor="Transparent" CornerRadius="8" Padding="8,2" HasShadow="False" HorizontalOptions="End"
                                                               BackgroundColor="{Binding StatusRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='active|#DCFCE7,retired|#F3F4F6,#FEF3C7'}">
                                                            <Label Text="{Binding StatusRaw}" Style="{StaticResource Caption}" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding AssetType}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding SerialNumber, StringFormat='S/N: {0}'}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" HorizontalOptions="End"
                                                               IsVisible="{Binding SerialNumber, Converter={StaticResource IsNotNullConverter}}" />
                                                        <Label Grid.Row="2" Grid.Column="0" Text="{Binding Manufacturer}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}"
                                                               IsVisible="{Binding Manufacturer, Converter={StaticResource IsNotNullConverter}}" />
                                                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding WarrantyExpires, StringFormat='Warranty: {0:dd MMM yyyy}'}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}"
                                                               IsVisible="{Binding WarrantyExpires, Converter={StaticResource IsNotNullConverter}}" />
                                                    </Grid>
                                                </Frame>
                                            </SwipeView>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </RefreshView>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 10: Properties workspace ── -->
                <Grid IsVisible="{Binding IsPropertiesTab}">
                    <ContentView x:Name="PropertiesPanel" BindingContext="{Binding PropertiesVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,Auto,*">
                            <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceDark}">
                                <Label Grid.Column="0" Text="Properties &amp; Sites" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="+" WidthRequest="40" HeightRequest="40" CornerRadius="20"
                                        Command="{Binding CreateSiteCommand}" BackgroundColor="{StaticResource Primary}" TextColor="White" FontSize="20" Padding="0" />
                            </Grid>
                            <Frame Grid.Row="1" BackgroundColor="#FEE2E2" BorderColor="{StaticResource Error}" CornerRadius="0" Padding="12,8"
                                   IsVisible="{Binding ExpiringCompliance.Count, Converter={StaticResource IsNotZeroConverter}}">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="⚠" TextColor="{StaticResource Error}" FontSize="16" VerticalOptions="Center" />
                                    <Label TextColor="{StaticResource Error}" VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding ExpiringCompliance.Count}" FontAttributes="Bold" />
                                                <Span Text=" compliance item(s) expiring soon or overdue" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>
                            </Frame>
                            <RefreshView Grid.Row="2" IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshCommand}">
                                <CollectionView ItemsSource="{Binding Sites}" Margin="16,8">
                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="12" Padding="32">
                                            <Label Text="🏢" FontSize="48" HorizontalOptions="Center" />
                                            <Label Text="No properties yet" Style="{StaticResource EmptyState}" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Site">
                                            <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding BindingContext.ViewSiteCommand, Source={x:Reference PropertiesPanel}}"
                                                        CommandParameter="{Binding .}" />
                                                </Frame.GestureRecognizers>
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Frame Grid.Column="0" BackgroundColor="{StaticResource Primary}" CornerRadius="8" Padding="10" WidthRequest="44" HeightRequest="44">
                                                        <Label Text="🏢" FontSize="18" VerticalOptions="Center" HorizontalOptions="Center" />
                                                    </Frame>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                        <Label Text="{Binding Name}" Style="{StaticResource BodyLarge}" />
                                                        <Label Text="{Binding Address}" Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}"
                                                               IsVisible="{Binding Address, Converter={StaticResource IsNotNullConverter}}" />
                                                    </VerticalStackLayout>
                                                    <Frame Grid.Column="2" CornerRadius="12" Padding="8,4" VerticalOptions="Center"
                                                           BackgroundColor="{Binding HasCoordinates, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#DCFCE7|#F3F4F6'}">
                                                        <Label Text="{Binding HasCoordinates, Converter={StaticResource BoolToStringConverter}, ConverterParameter='GPS|No GPS'}"
                                                               TextColor="{Binding HasCoordinates, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#166534|#6B7280'}"
                                                               FontSize="11" FontAttributes="Bold" />
                                                    </Frame>
                                                </Grid>
                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </RefreshView>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 11: Incidents workspace ── -->
                <Grid IsVisible="{Binding IsIncidentsTab}">
                    <ContentView x:Name="IncidentsPanel" BindingContext="{Binding IncidentsVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceDark}">
                                <Label Grid.Column="0" Text="Incident Reports" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="New" Command="{Binding NewIncidentCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="13" CornerRadius="8" Padding="16,0" HeightRequest="40" />
                            </Grid>
                            <ScrollView Grid.Row="1" Orientation="Horizontal" Margin="8,4">
                                <HorizontalStackLayout Padding="8,0" Spacing="8">
                                    <Button Text="All"        Command="{Binding SetScopeCommand}" CommandParameter="all"
                                            CornerRadius="16" HeightRequest="32" FontSize="12"
                                            BackgroundColor="{Binding Scope, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#3B82F6,#FFFFFF'}"
                                            TextColor="{Binding Scope, Converter={StaticResource EqToStyleConverter}, ConverterParameter='all|#FFFFFF,#6B7280'}" />
                                    <Button Text="Standalone" Command="{Binding SetScopeCommand}" CommandParameter="standalone"
                                            CornerRadius="16" HeightRequest="32" FontSize="12"
                                            BackgroundColor="{Binding Scope, Converter={StaticResource EqToStyleConverter}, ConverterParameter='standalone|#3B82F6,#FFFFFF'}"
                                            TextColor="{Binding Scope, Converter={StaticResource EqToStyleConverter}, ConverterParameter='standalone|#FFFFFF,#6B7280'}" />
                                    <Button Text="Job-linked" Command="{Binding SetScopeCommand}" CommandParameter="job"
                                            CornerRadius="16" HeightRequest="32" FontSize="12"
                                            BackgroundColor="{Binding Scope, Converter={StaticResource EqToStyleConverter}, ConverterParameter='job|#3B82F6,#FFFFFF'}"
                                            TextColor="{Binding Scope, Converter={StaticResource EqToStyleConverter}, ConverterParameter='job|#FFFFFF,#6B7280'}" />
                                </HorizontalStackLayout>
                            </ScrollView>
                            <!-- Open/All filter chips — use commands instead of code-behind events -->
                            <HorizontalStackLayout Grid.Row="2" Spacing="8" Padding="16,8" BackgroundColor="{StaticResource SurfaceDark}">
                                <Frame Padding="12,6" CornerRadius="16" BorderColor="Transparent"
                                       BackgroundColor="{Binding ShowOpenOnly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3B82F6|#E5E7EB'}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetShowOpenOnlyCommand}" />
                                    </Frame.GestureRecognizers>
                                    <Label Text="Open" FontSize="13" TextColor="{Binding ShowOpenOnly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#6B7280'}" />
                                </Frame>
                                <Frame Padding="12,6" CornerRadius="16" BorderColor="Transparent"
                                       BackgroundColor="{Binding ShowOpenOnly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#E5E7EB|#3B82F6'}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetShowAllCommand}" />
                                    </Frame.GestureRecognizers>
                                    <Label Text="All" FontSize="13" TextColor="{Binding ShowOpenOnly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#6B7280|White'}" />
                                </Frame>
                            </HorizontalStackLayout>
                            <SearchBar Grid.Row="3" Margin="16,0" Text="{Binding SearchText}" Placeholder="Search incidents..." />
                            <RefreshView Grid.Row="4" IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshCommand}">
                                <CollectionView ItemsSource="{Binding Incidents}" Margin="16,8">
                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="12" Padding="32">
                                            <Label Text="✅" FontSize="48" HorizontalOptions="Center" />
                                            <Label Text="No incidents found" Style="{StaticResource EmptyState}" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:IncidentDisplay">
                                            <SwipeView Margin="0,4">
                                                <SwipeView.RightItems>
                                                    <SwipeItems>
                                                        <SwipeItem Text="Close" BackgroundColor="{StaticResource Primary}"
                                                                   Command="{Binding BindingContext.CloseIncidentCommand, Source={x:Reference IncidentsPanel}}"
                                                                   CommandParameter="{Binding .}" />
                                                    </SwipeItems>
                                                </SwipeView.RightItems>
                                                <Frame Style="{StaticResource CardFrame}">
                                                    <Frame.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding BindingContext.ViewIncidentCommand, Source={x:Reference IncidentsPanel}}"
                                                            CommandParameter="{Binding .}" />
                                                    </Frame.GestureRecognizers>
                                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
                                                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                                            <Label Grid.Column="0" Text="{Binding Report.DisplayTitle}" Style="{StaticResource BodyLarge}" LineBreakMode="TailTruncation" MaxLines="2" />
                                                            <Frame Grid.Column="1" CornerRadius="10" Padding="8,3" VerticalOptions="Start"
                                                                   BackgroundColor="{Binding Report.SeverityRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='critical|#7F1D1D,high|#7C2D12,medium|#78350F,#14532D'}">
                                                                <Label Text="{Binding Report.SeverityRaw}" TextColor="White" FontSize="11" FontAttributes="Bold" />
                                                            </Frame>
                                                        </Grid>
                                                        <Label Grid.Row="1" Text="{Binding ReporterName}"  Style="{StaticResource Caption}" TextColor="{StaticResource Primary}" />
                                                        <Label Grid.Row="2" Text="{Binding Report.CreatedAt, StringFormat='{0:dd MMM yyyy, HH:mm}'}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                        <Label Grid.Row="3" Text="{Binding Report.ResolutionNotes, StringFormat='Resolution: {0}'}" Style="{StaticResource BodySmall}"
                                                               TextColor="{StaticResource Accent}" IsVisible="{Binding Report.IsClosed}" />
                                                    </Grid>
                                                </Frame>
                                            </SwipeView>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </RefreshView>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 12: Reports workspace ── -->
                <Grid IsVisible="{Binding IsReportsTab}">
                    <ContentView BindingContext="{Binding ReportsVm}">
                        <hr:HrReportsView x:DataType="{x:Null}" />
                    </ContentView>
                </Grid>

                <!-- ── Tab 13: Scheduling workspace ── -->
                <Grid IsVisible="{Binding IsSchedulingTab}">
                    <ContentView x:Name="SchedulingPanel" BindingContext="{Binding SchedulingVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,Auto,*">
                            <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto,Auto" BackgroundColor="{StaticResource SurfaceDark}">
                                <Label Grid.Column="0" Text="Scheduling" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <!-- Export button restored from HrSchedulingPage ToolbarItem -->
                                <Button Grid.Column="1" Text="Export" Command="{Binding ExportCommand}"
                                        Style="{StaticResource TextButton}" Margin="0,0,8,0" />
                                <Button Grid.Column="2" Text="+ Shift" Padding="12,8" Command="{Binding CreateEventCommand}" Style="{StaticResource PrimaryButton}" />
                            </Grid>
                            <Frame Grid.Row="1" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Divider}" CornerRadius="0" Padding="16,10">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" Text="Date:" Style="{StaticResource LabelField}" VerticalOptions="Center" Margin="0,0,12,0" />
                                    <DatePicker Grid.Column="1" Date="{Binding SelectedDate}" TextColor="{StaticResource TextPrimary}" BackgroundColor="Transparent" Format="dddd, d MMMM yyyy" />
                                </Grid>
                            </Frame>
                            <Grid Grid.Row="2">
                                <CollectionView ItemsSource="{Binding Events}" Margin="16,8">
                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="16" Padding="32">
                                            <Label Text="📅" FontSize="56" HorizontalOptions="Center" />
                                            <Label Text="No events scheduled" Style="{StaticResource EmptyState}" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:CalendarEvent">
                                            <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                                                <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                                                    <BoxView Grid.Column="0" BackgroundColor="{StaticResource Primary}" CornerRadius="2" />
                                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                        <Label Text="{Binding Title}" Style="{StaticResource BodyLarge}" />
                                                        <HorizontalStackLayout Spacing="8">
                                                            <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}" Style="{StaticResource Caption}" TextColor="{StaticResource Primary}" />
                                                            <Label Text="–" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                            <Label Text="{Binding EndTime, StringFormat='{0:HH:mm}'}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                        </HorizontalStackLayout>
                                                        <Label Text="{Binding Description}" Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}"
                                                               IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Grid>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 14: Work Teams workspace ── -->
                <Grid IsVisible="{Binding IsWorkTeamsTab}">
                    <ContentView x:Name="WorkTeamsPanel" BindingContext="{Binding WorkTeamsVm}">
                        <Grid x:DataType="{x:Null}" RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto" BackgroundColor="{StaticResource SurfaceDark}">
                                <Label Grid.Column="0" Text="Work Teams" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="+ Team" Padding="12,8" Command="{Binding CreateTeamCommand}" Style="{StaticResource PrimaryButton}" />
                            </Grid>
                            <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshCommand}">
                                <CollectionView ItemsSource="{Binding Teams}" Margin="16,8">
                                    <CollectionView.EmptyView>
                                        <VerticalStackLayout VerticalOptions="Center" Spacing="12" Padding="32">
                                            <Label Text="👥" FontSize="48" HorizontalOptions="Center" />
                                            <Label Text="No work teams yet" Style="{StaticResource EmptyState}" />
                                        </VerticalStackLayout>
                                    </CollectionView.EmptyView>
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:WorkTeam">
                                            <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding BindingContext.ViewTeamCommand, Source={x:Reference WorkTeamsPanel}}"
                                                        CommandParameter="{Binding .}" />
                                                </Frame.GestureRecognizers>
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Frame Grid.Column="0" CornerRadius="22" Padding="0" WidthRequest="44" HeightRequest="44"
                                                           BackgroundColor="{Binding IsActive, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1D4ED8|#374151'}">
                                                        <Label Text="👥" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center" />
                                                    </Frame>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                        <Label Text="{Binding Name}" Style="{StaticResource BodyLarge}" />
                                                        <Label Text="{Binding Description}" Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}" LineBreakMode="TailTruncation"
                                                               IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />
                                                    </VerticalStackLayout>
                                                    <Frame Grid.Column="2" CornerRadius="12" Padding="8,4" VerticalOptions="Center"
                                                           BackgroundColor="{Binding IsActive, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#DCFCE7|#F3F4F6'}">
                                                        <Label Text="{Binding IsActive, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Active|Inactive'}"
                                                               TextColor="{Binding IsActive, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#166534|#6B7280'}"
                                                               FontSize="11" FontAttributes="Bold" />
                                                    </Frame>
                                                </Grid>
                                            </Frame>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </RefreshView>
                        </Grid>
                    </ContentView>
                </Grid>

                <!-- ── Tab 15: Notifications workspace ── -->
                <Grid IsVisible="{Binding IsNotificationsTab}">
                    <ContentView x:Name="NotificationsPanel" BindingContext="{Binding NotificationsVm}">
                        <RefreshView x:DataType="{x:Null}" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
                            <ScrollView>
                                <VerticalStackLayout Padding="16" Spacing="20">
                                    <Label Text="IN-APP ALERTS" Style="{StaticResource LabelSection}" />
                                    <Label Text="Client messages and system alerts appear here instantly (not SMS)." FontSize="11" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                                    <Label Text="No new in-app alerts." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding HasAppNotifications, Converter={StaticResource InverseBoolConverter}}" />
                                    <CollectionView ItemsSource="{Binding AppNotifications}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:HrNotificationItem">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,8" Padding="12">
                                                    <Frame.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding BindingContext.OpenAppNotificationCommand, Source={x:Reference NotificationsPanel}}"
                                                            CommandParameter="{Binding .}" />
                                                    </Frame.GestureRecognizers>
                                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="10">
                                                        <BoxView Grid.Column="0" WidthRequest="4" Color="{Binding Color}" VerticalOptions="Fill" />
                                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                            <Label Text="{Binding Title}" FontFamily="PoppinsSemiBold" FontSize="14" />
                                                            <Label Text="{Binding Body}" FontSize="12" TextColor="{StaticResource TextSecondary}" LineBreakMode="WordWrap" />
                                                            <Label Text="{Binding When}" FontSize="10" TextColor="{StaticResource Primary}" />
                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                    <Label Text="PENDING LEAVE REQUESTS" Style="{StaticResource LabelSection}" />
                                    <Label Text="No pending leave requests." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding PendingLeave.Count, Converter={StaticResource IsZeroConverter}}" />
                                    <CollectionView ItemsSource="{Binding PendingLeave}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:LeaveRequest">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                                                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding LeaveType}" FontFamily="PoppinsSemiBold" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                                        <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="#FEF3C7" BorderColor="Transparent" CornerRadius="10" Padding="8,3" HasShadow="False" VerticalOptions="Center">
                                                            <Label Text="Pending" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                        <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding StartDate, StringFormat='{0:dd MMM yyyy}'}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <!-- Open Incidents — restored from HrNotificationsPage.xaml -->
                                    <Label Text="OPEN INCIDENTS" Style="{StaticResource LabelSection}" />
                                    <Label Text="No open incidents." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding OpenIncidents.Count, Converter={StaticResource IsZeroConverter}}" />
                                    <CollectionView ItemsSource="{Binding OpenIncidents}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:IncidentReport">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                            <Label Text="{Binding Description}" FontFamily="PoppinsMedium" FontSize="13"
                                                                   TextColor="{StaticResource TextPrimary}" MaxLines="2" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding CreatedAt, StringFormat='{0:dd MMM yyyy}'}"
                                                                   FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                                        </VerticalStackLayout>
                                                        <Frame Grid.Column="1"
                                                               BackgroundColor="{Binding SeverityRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='critical|#FEE2E2,high|#FEF3C7,medium|#DBEAFE,#DCFCE7'}"
                                                               BorderColor="Transparent" CornerRadius="10" Padding="8,3" HasShadow="False" VerticalOptions="Start">
                                                            <Label Text="{Binding SeverityRaw}" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <!-- Pending Payment Approvals — restored from HrNotificationsPage.xaml -->
                                    <Label Text="PENDING PAYMENT APPROVALS" Style="{StaticResource LabelSection}" />
                                    <Label Text="No pending payment approvals." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding PendingPayments.Count, Converter={StaticResource IsZeroConverter}}" />
                                    <CollectionView ItemsSource="{Binding PendingPayments}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:PaymentApproval">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                            <Label Text="{Binding PeriodLabel}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                                            <Label Text="{Binding GrossPay, StringFormat='R {0:N2}'}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                                        </VerticalStackLayout>
                                                        <Frame Grid.Column="1" BackgroundColor="#FEF3C7" BorderColor="Transparent"
                                                               CornerRadius="10" Padding="8,3" HasShadow="False" VerticalOptions="Center">
                                                            <Label Text="Pending" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                </VerticalStackLayout>
                            </ScrollView>
                        </RefreshView>
                    </ContentView>
                </Grid>

                <!-- ── Tab 16: Activity Log workspace ── -->
                <Grid IsVisible="{Binding IsActivityLogTab}">
                    <ContentView x:Name="ActivityLogPanel" BindingContext="{Binding ActivityLogVm}">
                        <RefreshView x:DataType="{x:Null}" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
                            <ScrollView>
                                <VerticalStackLayout Padding="16" Spacing="20">
                                    <Label Text="RECENT CLOCK INS/OUTS" Style="{StaticResource LabelSection}" />
                                    <Label Text="No recent punches." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding RecentPunches.Count, Converter={StaticResource IsZeroConverter}}" />
                                    <CollectionView ItemsSource="{Binding RecentPunches}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PunchActivity">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                            <Label Text="{Binding EmployeeName}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                                            <Label Text="{Binding DateTime, StringFormat='{0:ddd dd MMM, HH:mm}'}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                                            <Label Text="{Binding Address}" FontFamily="PoppinsRegular" FontSize="11" TextColor="{StaticResource TextSecondary}"
                                                                   IsVisible="{Binding Address, Converter={StaticResource IsNotNullConverter}}" LineBreakMode="TailTruncation" />
                                                        </VerticalStackLayout>
                                                        <Frame Grid.Column="1" BorderColor="Transparent" CornerRadius="10" Padding="8,3" HasShadow="False" VerticalOptions="Center"
                                                               BackgroundColor="{Binding TypeLabel, Converter={StaticResource EqToStyleConverter}, ConverterParameter='Clock In|#DCFCE7,#FEE2E2'}">
                                                            <Label Text="{Binding TypeLabel}" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                    <Label Text="RECENT INCIDENTS" Style="{StaticResource LabelSection}" />
                                    <Label Text="No recent incidents." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding RecentIncidents.Count, Converter={StaticResource IsZeroConverter}}" />
                                    <CollectionView ItemsSource="{Binding RecentIncidents}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:IncidentReport">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                            <Label Text="{Binding Description}" FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" MaxLines="2" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding CreatedAt, StringFormat='{0:dd MMM yyyy}'}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                                        </VerticalStackLayout>
                                                        <Frame Grid.Column="1" BorderColor="Transparent" CornerRadius="10" Padding="8,3" HasShadow="False" VerticalOptions="Start"
                                                               BackgroundColor="{Binding SeverityRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='critical|#FEE2E2,high|#FEF3C7,medium|#DBEAFE,#DCFCE7'}">
                                                            <Label Text="{Binding SeverityRaw}" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <!-- Recent Leave Requests — restored from HrActivityLogPage.xaml -->
                                    <Label Text="RECENT LEAVE REQUESTS" Style="{StaticResource LabelSection}" />
                                    <Label Text="No recent leave requests." Style="{StaticResource EmptyState}"
                                           IsVisible="{Binding RecentLeave.Count, Converter={StaticResource IsZeroConverter}}" />
                                    <CollectionView ItemsSource="{Binding RecentLeave}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:LeaveRequest">
                                                <Frame Style="{StaticResource CardFrame}" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                            <Label Text="{Binding LeaveType}" FontFamily="PoppinsSemiBold" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                                                            <Label Text="{Binding StartDate, StringFormat='{0:dd MMM} – '}" FontFamily="PoppinsRegular" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                                        </VerticalStackLayout>
                                                        <Frame Grid.Column="1"
                                                               BackgroundColor="{Binding StatusRaw, Converter={StaticResource EqToStyleConverter}, ConverterParameter='approved|#DCFCE7,declined|#FEE2E2,#FEF3C7'}"
                                                               BorderColor="Transparent" CornerRadius="10" Padding="8,3" HasShadow="False" VerticalOptions="Center">
                                                            <Label Text="{Binding StatusRaw}" FontFamily="PoppinsSemiBold" FontSize="11" TextColor="{StaticResource TextPrimary}" />
                                                        </Frame>
                                                    </Grid>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                </VerticalStackLayout>
                            </ScrollView>
                        </RefreshView>
                    </ContentView>
                </Grid>

                <!-- ── Tab 18: Settings workspace ── -->
                <!-- Full parity with HrSettingsPage.xaml.                                          -->
                <!-- Only adaptation: x:Reference settingsPage → x:Reference SettingsPanel         -->
                <!-- so Branch Edit/Delete commands resolve to the ContentView's BindingContext.     -->
                <Grid IsVisible="{Binding IsSettingsTab}">
                    <ContentView x:Name="SettingsPanel" BindingContext="{Binding SettingsVm}">
                        <ScrollView x:DataType="{x:Null}">
                            <VerticalStackLayout Spacing="16" Padding="16">

                                <!-- Company Info Header -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding Company.Name, FallbackValue='Company'}" Style="{StaticResource HeadlineMedium}" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Company.Code, StringFormat='Company Code: {0}', FallbackValue=''}"
                                                   Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                            <Button Grid.Column="1" Text="Copy" Command="{Binding CopyCodeCommand}"
                                                    FontSize="12" BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource Primary}"
                                                    CornerRadius="8" Padding="12,4" HeightRequest="32" />
                                        </Grid>
                                        <Label Text="{Binding Company.PlanCode, StringFormat='Plan: {0}', FallbackValue=''}"
                                               Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Feature Modules -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="FEATURE MODULES" Style="{StaticResource LabelSection}" />
                                        <Label Text="Turn features on or off for this company. Disabling a module hides it from navigation — your data is kept."
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                            <Button Text="Enable all"  Command="{Binding EnableAllModulesCommand}"
                                                    FontSize="12" CornerRadius="8" HeightRequest="34" Padding="12,0"
                                                    BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource Primary}" />
                                            <Button Text="Disable all" Command="{Binding DisableAllModulesCommand}"
                                                    FontSize="12" CornerRadius="8" HeightRequest="34" Padding="12,0"
                                                    BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource TextSecondary}" />
                                        </HorizontalStackLayout>
                                        <BoxView Style="{StaticResource DividerLine}" />
                                        <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding ModuleToggles}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:ModuleToggleItem">
                                                    <VerticalStackLayout Spacing="0">
                                                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                                <Label Text="{Binding Title}"       Style="{StaticResource BodyLarge}" />
                                                                <Label Text="{Binding Description}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                            </VerticalStackLayout>
                                                            <Switch Grid.Column="1" IsToggled="{Binding IsEnabled}" IsEnabled="{Binding IsPlanEntitled}"
                                                                    ThumbColor="{StaticResource Primary}" OnColor="{StaticResource Primary}" VerticalOptions="Center" />
                                                        </Grid>
                                                        <BoxView Style="{StaticResource DividerLine}" />
                                                    </VerticalStackLayout>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                        <Button Text="Open Payroll Settings" Command="{Binding GoToPayrollSettingsCommand}"
                                                IsVisible="{Binding IsPayrollModuleEnabled}"
                                                BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource Primary}"
                                                CornerRadius="8" FontSize="13" Padding="14,8" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Error + Save -->
                                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" HorizontalOptions="Center" />
                                <Button Text="Save Module Settings" Command="{Binding SaveModulesCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                                <!-- Company Details -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="COMPANY DETAILS" Style="{StaticResource LabelSection}" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Company.Name, FallbackValue='—'}" Style="{StaticResource BodyLarge}" />
                                                <Label Text="{Binding Company.ContactEmail, FallbackValue=''}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                <Label Text="{Binding Company.ContactPhone, FallbackValue=''}" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                <Label Text="{Binding Company.Address, FallbackValue=''}"     Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                            </VerticalStackLayout>
                                            <Button Grid.Column="1" Text="Edit" Command="{Binding EditCompanyDetailsCommand}"
                                                    Style="{StaticResource TextButton}" VerticalOptions="Start" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Location Rules (owner/admin only) -->
                                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding IsOwnerOrAdmin}">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="LOCATION RULES" Style="{StaticResource LabelSection}" />
                                        <Label Text="Optional. When enabled, employees with an assigned branch must be near that branch to clock in."
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <Label Grid.Column="0" Text="Enforce branch sign-in radius"
                                                   Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                                            <Switch Grid.Column="1" IsToggled="{Binding EnforceBranchSignInRadius}"
                                                    OnColor="{StaticResource Primary}" />
                                        </Grid>
                                        <Label Text="Allowed distance from branch" Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                            <Button Grid.Column="0" Text="200 m" Command="{Binding SetBranchSignInRadiusCommand}" CommandParameter="200"
                                                    FontSize="12" CornerRadius="8" HeightRequest="36" />
                                            <Button Grid.Column="1" Text="500 m" Command="{Binding SetBranchSignInRadiusCommand}" CommandParameter="500"
                                                    FontSize="12" CornerRadius="8" HeightRequest="36" />
                                            <Button Grid.Column="2" Text="1 km"  Command="{Binding SetBranchSignInRadiusCommand}" CommandParameter="1000"
                                                    FontSize="12" CornerRadius="8" HeightRequest="36" />
                                        </Grid>
                                        <Label Text="{Binding BranchSignInRadiusMeters, StringFormat='Selected: {0:F0} metres'}"
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Button Text="Save Location Rules" Command="{Binding SaveLocationRulesCommand}"
                                                Style="{StaticResource PrimaryButton}" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Branches (owner/admin only) -->
                                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding IsOwnerOrAdmin}">
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="BRANCHES" Style="{StaticResource LabelSection}" VerticalOptions="Center" />
                                            <Button Grid.Column="1" Text="+ Add" Command="{Binding AddBranchCommand}"
                                                    FontSize="12" Padding="12,4"
                                                    BackgroundColor="{StaticResource SurfaceDark}" TextColor="{StaticResource Primary}"
                                                    CornerRadius="8" HeightRequest="32" />
                                        </Grid>
                                        <Label Text="No branches configured." Style="{StaticResource EmptyState}"
                                               IsVisible="{Binding Branches.Count, Converter={StaticResource IsZeroConverter}}" />
                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Branches}" Spacing="8">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:Branch">
                                                    <Frame Style="{StaticResource CardFrame}" Padding="12,8">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                                <Label Text="{Binding Name}" Style="{StaticResource BodyMedium}" />
                                                                <Label Text="{Binding LocationStatusDisplay}"
                                                                       Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                                            </VerticalStackLayout>
                                                            <!-- Use SettingsPanel (ContentView) instead of settingsPage (standalone ContentPage) -->
                                                            <Button Grid.Column="1" Text="Edit"
                                                                    Command="{Binding BindingContext.EditBranchCommand, Source={x:Reference SettingsPanel}}"
                                                                    CommandParameter="{Binding .}"
                                                                    Style="{StaticResource TextButton}" FontSize="12" />
                                                            <Button Grid.Column="2" Text="✕"
                                                                    Command="{Binding BindingContext.DeleteBranchCommand, Source={x:Reference SettingsPanel}}"
                                                                    CommandParameter="{Binding .}"
                                                                    BackgroundColor="Transparent" TextColor="{StaticResource Error}"
                                                                    FontSize="14" Padding="8,0" />
                                                        </Grid>
                                                    </Frame>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Leave Policies -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="LEAVE POLICIES" Style="{StaticResource LabelSection}" />
                                        <Label Text="Annual and sick leave entitlements. Pay calculation settings live under Payroll."
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                                            <Label Grid.Row="0" Grid.Column="0" Text="Annual Leave (days/year)" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding AnnualLeaveDays}"
                                                   Keyboard="Numeric" WidthRequest="80" Style="{StaticResource DarkEntry}" HorizontalTextAlignment="End" />
                                            <Label Grid.Row="1" Grid.Column="0" Text="Sick Leave (days/year)" Style="{StaticResource BodyMedium}" VerticalOptions="Center" />
                                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding SickLeaveDays}"
                                                   Keyboard="Numeric" WidthRequest="80" Style="{StaticResource DarkEntry}" HorizontalTextAlignment="End" />
                                        </Grid>
                                        <Button Text="Save Leave Policies" Command="{Binding SavePoliciesCommand}"
                                                Style="{StaticResource PrimaryButton}" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Subscription Plan (owner/admin only) -->
                                <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding IsOwnerOrAdmin}">
                                    <VerticalStackLayout Spacing="14">
                                        <Label Text="SUBSCRIPTION PLAN" Style="{StaticResource LabelSection}" />
                                        <Frame BackgroundColor="{StaticResource SurfaceElevated}" BorderColor="{StaticResource Divider}"
                                               CornerRadius="10" Padding="14,10" HasShadow="False">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding CurrentPlanLabel}" Style="{StaticResource BodyLarge}" />
                                                <Label Text="Active subscription" Style="{StaticResource Caption}"
                                                       TextColor="{StaticResource Success}" IsVisible="{Binding HasActiveSubscription}" />
                                                <Label Text="Inactive or trial — contact support to activate billing"
                                                       Style="{StaticResource Caption}" TextColor="{StaticResource Warning}"
                                                       IsVisible="{Binding HasActiveSubscription, Converter={StaticResource InverseBoolConverter}}" />
                                            </VerticalStackLayout>
                                        </Frame>
                                        <Label Text="Plan changes are handled by KaiFlow billing — not from this screen."
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Button Text="Request plan change" Command="{Binding RequestPlanChangeCommand}"
                                                Style="{StaticResource SecondaryButton}" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- HR Access & Roles -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="HR ACCESS &amp; ROLES" Style="{StaticResource LabelSection}" />
                                        <Label Text="Employees with elevated access in this company."
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="No HR or manager accounts yet." Style="{StaticResource EmptyState}"
                                               IsVisible="{Binding HrStaff.Count, Converter={StaticResource IsZeroConverter}}" />
                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding HrStaff}" Spacing="8">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:Employee">
                                                    <Frame Style="{StaticResource CardFrame}" Padding="12,10">
                                                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                                                            <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44"
                                                                   BackgroundColor="{StaticResource SidebarActive}"
                                                                   Padding="0" BorderColor="Transparent" HasShadow="False">
                                                                <Label Text="{Binding Initials}" FontFamily="PoppinsBold" FontSize="15"
                                                                       TextColor="{StaticResource Primary}"
                                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                                            </Frame>
                                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                                <Label Text="{Binding FullName}" Style="{StaticResource BodyMedium}" />
                                                                <Label Text="{Binding Position}" Style="{StaticResource Caption}"
                                                                       TextColor="{StaticResource TextSecondary}"
                                                                       IsVisible="{Binding Position, Converter={StaticResource IsNotNullConverter}}" />
                                                            </VerticalStackLayout>
                                                            <Frame Grid.Column="2" CornerRadius="6" Padding="8,4" VerticalOptions="Center"
                                                                   BackgroundColor="{StaticResource SurfaceElevated}"
                                                                   BorderColor="{StaticResource Divider}" HasShadow="False">
                                                                <Label Text="{Binding AccessLevelRaw}" FontFamily="PoppinsMedium" FontSize="11"
                                                                       TextColor="{StaticResource Primary}" />
                                                            </Frame>
                                                        </Grid>
                                                    </Frame>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Security -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="SECURITY" Style="{StaticResource LabelSection}" />
                                        <Button Text="Change Password" Command="{Binding ChangePasswordCommand}"
                                                BackgroundColor="{StaticResource SurfaceElevated}" TextColor="{StaticResource TextPrimary}"
                                                CornerRadius="10" HeightRequest="44" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Feedback -->
                                <Frame Style="{StaticResource CardFrame}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="FEEDBACK" Style="{StaticResource LabelSection}" />
                                        <Label Text="Report bugs, suggest features, or contact KaiFlow support."
                                               Style="{StaticResource Caption}" TextColor="{StaticResource TextSecondary}" />
                                        <Button Text="Send Feedback" Command="{Binding GoToSendFeedbackCommand}"
                                                Style="{StaticResource SecondaryButton}" />
                                    </VerticalStackLayout>
                                </Frame>

                                <!-- Danger Zone -->
                                <Frame Style="{StaticResource CardFrame}" BorderColor="{StaticResource Error}" BackgroundColor="#FEF2F2">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="DANGER ZONE" Style="{StaticResource LabelSection}" TextColor="{StaticResource Error}" />
                                        <Label Text="These actions are permanent and cannot be undone."
                                               Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}" />
                                        <!-- Transfer Ownership visible to owner only -->
                                        <Button Text="Transfer Ownership" Command="{Binding TransferOwnershipCommand}"
                                                IsVisible="{Binding IsOwner}"
                                                BackgroundColor="Transparent" TextColor="{StaticResource Error}"
                                                BorderColor="{StaticResource Error}" BorderWidth="1"
                                                CornerRadius="10" HeightRequest="44" />
                                        <Button Text="Sign Out" Command="{Binding SignOutCommand}"
                                                Style="{StaticResource DangerButton}" />
                                    </VerticalStackLayout>
                                </Frame>

                                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                                   Color="{StaticResource Primary}" HorizontalOptions="Center" />

                            </VerticalStackLayout>
                        </ScrollView>
                    </ContentView>
                </Grid>

            </Grid>
        </Grid>

    </Grid>

</ContentPage>
