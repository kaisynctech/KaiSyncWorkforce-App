                        <Label Text="Track all system activity, logins and changes across your company."
                               Style="{StaticResource Caption}" HorizontalTextAlignment="Center" MaximumWidthRequest="320" />
                        <Button Text="Open Activity Log" Command="{Binding GoToActivityLogCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="14"
                                CornerRadius="10" Padding="24,0" HeightRequest="48"
                                HorizontalOptions="Center" Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </Grid>

                <!-- ── Tab 16: Messages ── -->
                <Grid IsVisible="{Binding IsMessagesTab}" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="24,12">
                        <Label Text="Messages" Style="{StaticResource HeadlineSmall}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+ New Thread" Command="{Binding NewThreadCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                FontFamily="PoppinsSemiBold" FontSize="13"
                                CornerRadius="8" Padding="16,0" HeightRequest="44" />
                    </Grid>
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Threads}" Margin="24,0,24,24">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Margin="0,40,0,0">
                                <Label Text="No conversations yet." Style="{StaticResource EmptyState}" />
                                <Label Text="Tap '+ New Thread' to message an employee."
                                       Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:MessageThread">
                                <Frame Style="{StaticResource CardFrame}" Margin="0,4" Padding="16,12">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.OpenThreadCommand, Source={x:Reference Self}}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding ListTitle}"
                                               Style="{StaticResource BodyLarge}" />
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding LastMessageAtDisplay}"
                                               Style="{StaticResource Caption}"
                                               IsVisible="{Binding LastMessageAt, Converter={StaticResource IsNotNullConverter}}" />
                                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding LastMessagePreview, FallbackValue='No messages yet'}"
                                               Style="{StaticResource Caption}" MaxLines="1" LineBreakMode="TailTruncation" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- ── Tab 17: Settings ── -->
                <ScrollView IsVisible="{Binding IsSettingsTab}">
                    <VerticalStackLayout Padding="24" Spacing="16">
                        <Frame Style="{StaticResource CardFrame}" Padding="24">
                            <VerticalStackLayout Spacing="14">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <Frame Grid.Column="0" CornerRadius="22" WidthRequest="44" HeightRequest="44"
                                           BackgroundColor="#3B82F615" Padding="0" BorderColor="Transparent" HasShadow="False">
                                        <Label Text="&#xE8B8;" FontFamily="MaterialIcons" FontSize="24"
                                               TextColor="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding CurrentCompany.Name, FallbackValue='Company'}"
                                               FontFamily="PoppinsSemiBold" FontSize="16" TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="Company settings &amp; configuration"
                                               FontFamily="PoppinsRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource Divider}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="Subscription plan" FontFamily="PoppinsMedium" FontSize="14" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding CurrentCompany.PlanCode, FallbackValue='free'}"
                                           FontFamily="PoppinsMedium" FontSize="13" TextColor="{StaticResource Accent}" VerticalOptions="Center" />
                                </Grid>
                                <Button Text="Open Full Settings" Command="{Binding GoToSettingsCommand}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                                        FontFamily="PoppinsSemiBold" FontSize="14"
                                        CornerRadius="10" HeightRequest="48" HorizontalOptions="Fill" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </ScrollView>

            </Grid>
        </Grid>

    </Grid>

</ContentPage>
