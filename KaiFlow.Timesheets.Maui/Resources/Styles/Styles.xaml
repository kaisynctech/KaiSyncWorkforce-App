<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:KaiFlow.Timesheets.Converters">

    <!-- ═══════════════════════════════════════════════
         Value Converters
    ═══════════════════════════════════════════════ -->
    <conv:IsNullConverter x:Key="IsNullConverter" />
    <conv:IsNotNullConverter x:Key="IsNotNullConverter" />
    <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
    <conv:BoolToStringConverter x:Key="BoolToStringConverter" />
    <conv:IsZeroConverter x:Key="IsZeroConverter" />
    <conv:IsNotZeroConverter x:Key="IsNotZeroConverter" />
    <conv:EqConverter x:Key="EqConverter" />
    <conv:EqToStyleConverter x:Key="EqToStyleConverter" />
    <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    <conv:InitialsConverter x:Key="InitialsConverter" />
    <conv:HexToColorConverter x:Key="HexToColorConverter" />

    <!-- ═══════════════════════════════════════════════
         Typography
    ═══════════════════════════════════════════════ -->
    <Style x:Key="HeadlineLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="HeadlineMedium" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="HeadlineSmall" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsMedium" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyMedium" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="BodySmall" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="LabelSection" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="CharacterSpacing" Value="1.2" />
    </Style>

    <Style x:Key="LabelField" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Layout Helpers
    ═══════════════════════════════════════════════ -->
    <Style x:Key="DividerLine" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="BackgroundColor" Value="{StaticResource Divider}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Card / Frame
    ═══════════════════════════════════════════════ -->
    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="KpiCard" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="KpiNumber" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsBold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <Style x:Key="KpiLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Data tables (prefer over card lists for tabular data)
    ═══════════════════════════════════════════════ -->
    <Style x:Key="DataTableFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="DataTableHeaderLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MinimumHeightRequest" Value="40" />
    </Style>

    <Style x:Key="DataTableCellLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsMedium" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="DataTableCellSecondary" TargetType="Label" BasedOn="{StaticResource DataTableCellLabel}">
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="DataTableRowDivider" TargetType="BoxView" BasedOn="{StaticResource DividerLine}" />

    <Style x:Key="DataTableVLine" TargetType="BoxView">
        <Setter Property="WidthRequest" Value="1" />
        <Setter Property="BackgroundColor" Value="{StaticResource Divider}" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="Margin" Value="4,6" />
    </Style>

    <Style x:Key="DataTableRowPadding" TargetType="Grid">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style x:Key="DataTablePicker" TargetType="Picker">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="DataTableCellMoney" TargetType="Label" BasedOn="{StaticResource DataTableCellSecondary}">
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="Padding" Value="0,0,6,0" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="DataTableCellProgress" TargetType="Label" BasedOn="{StaticResource DataTableCellSecondary}">
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="Padding" Value="0,0,10,0" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <Style x:Key="DataTableCellJobs" TargetType="Label" BasedOn="{StaticResource DataTableCellSecondary}">
        <Setter Property="HorizontalTextAlignment" Value="Start" />
        <Setter Property="Padding" Value="10,0,6,0" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <!-- Attendance / punch session tables -->
    <Style x:Key="AttendanceTableHeaderLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="#94A3B8" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="AttendanceTableCellLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsMedium" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="AttendanceTableCellPrimary" TargetType="Label" BasedOn="{StaticResource AttendanceTableCellLabel}">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <Style x:Key="AttendanceTableCellSecondary" TargetType="Label">
        <Setter Property="FontFamily" Value="Poppins" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <Style x:Key="AttendanceTableDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Color" Value="#1E3A5F" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Buttons
    ═══════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <Style x:Key="OutlinedButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1.5" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="TextButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0,8" />
    </Style>

    <!-- Numpad key for PIN entry / PIN setup screens -->
    <Style x:Key="NumpadButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="80" />
        <Setter Property="HeightRequest" Value="64" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Error}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20,14" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <Style x:Key="MenuButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="PoppinsMedium" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="10,12" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="DashCardButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceCard}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="PoppinsMedium" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="8,14" />
        <Setter Property="BorderColor" Value="{StaticResource Divider}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="HeightRequest" Value="72" />
    </Style>

    <!-- Tab toggle button: active state -->
    <Style x:Key="TabButtonActive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- Tab toggle button: inactive state -->
    <Style x:Key="TabButtonInactive" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Entry / Editor
    ═══════════════════════════════════════════════ -->
    <Style x:Key="DarkEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceElevated}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextDisabled}" />
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="DarkEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceElevated}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextDisabled}" />
        <Setter Property="FontFamily" Value="PoppinsRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Pills / Status badges
    ═══════════════════════════════════════════════ -->
    <Style x:Key="PillActive" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="#DCFCE7" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="PillInactive" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceElevated}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- ═══════════════════════════════════════════════
         Empty State
    ═══════════════════════════════════════════════ -->
    <Style x:Key="EmptyState" TargetType="Label">
        <Setter Property="FontFamily" Value="PoppinsSemiBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
