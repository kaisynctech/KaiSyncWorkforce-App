<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Background surfaces -->
    <Color x:Key="BackgroundDark">#F3F5FB</Color>
    <Color x:Key="SurfaceDark">#FFFFFF</Color>
    <Color x:Key="SurfaceCard">#FFFFFF</Color>
    <Color x:Key="SurfaceElevated">#F9FAFB</Color>

    <!-- Brand -->
    <Color x:Key="Primary">#3B82F6</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryLight">#60A5FA</Color>
    <Color x:Key="Accent">#3B82F6</Color>
    <Color x:Key="AccentLight">#93C5FD</Color>

    <!-- Status -->
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="ErrorDark">#FEE2E2</Color>
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="SuccessDark">#DCFCE7</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningDark">#FEF3C7</Color>
    <Color x:Key="Info">#3B82F6</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextDisabled">#9CA3AF</Color>
    <Color x:Key="TextInverse">#FFFFFF</Color>

    <!-- Divider / Border -->
    <Color x:Key="Divider">#E5E7EB</Color>
    <Color x:Key="Border">#D1D5DB</Color>

    <!-- Sidebar -->
    <Color x:Key="SidebarBackground">#0F172A</Color>
    <Color x:Key="SidebarActive">#DBEAFE</Color>

</ResourceDictionary>
