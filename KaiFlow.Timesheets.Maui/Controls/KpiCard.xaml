<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="KaiFlow.Timesheets.Controls.KpiCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border BackgroundColor="{StaticResource SurfaceCard}"
            Stroke="{StaticResource Divider}"
            StrokeThickness="1"
            Padding="16"
            StrokeShape="RoundRectangle 16">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
            <Label x:Name="TitleLabel"
                   Grid.Row="0" Grid.Column="0"
                   FontFamily="PoppinsSemiBold"
                   FontSize="11"
                   CharacterSpacing="0.6"
                   TextColor="{StaticResource TextSecondary}"
                   LineBreakMode="TailTruncation" />

            <BoxView x:Name="AccentDot"
                     Grid.Row="0" Grid.Column="1"
                     WidthRequest="8" HeightRequest="8"
                     CornerRadius="4"
                     VerticalOptions="Center" />

            <Label x:Name="ValueLabel"
                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                   Margin="0,4,0,0"
                   FontFamily="PoppinsBold"
                   FontSize="26"
                   LineBreakMode="TailTruncation"
                   TextColor="{StaticResource TextPrimary}" />

            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                <Label x:Name="DeltaLabel"
                       FontFamily="PoppinsSemiBold"
                       FontSize="11"
                       IsVisible="False"
                       VerticalOptions="Center" />
                <Label x:Name="CaptionLabel"
                       FontFamily="PoppinsRegular"
                       FontSize="11"
                       TextColor="{StaticResource TextDisabled}"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />
            </HorizontalStackLayout>
        </Grid>
    </Border>

</ContentView>
