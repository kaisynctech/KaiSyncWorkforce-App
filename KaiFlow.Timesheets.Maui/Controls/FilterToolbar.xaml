<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="KaiFlow.Timesheets.Controls.FilterToolbar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Spacing="10">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource SurfaceElevated}"
                    Stroke="{StaticResource Divider}"
                    StrokeThickness="1"
                    Padding="12,0"
                    StrokeShape="RoundRectangle 12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="🔍" FontSize="14" VerticalOptions="Center" />
                    <Entry x:Name="SearchEntry"
                           Placeholder="Search…"
                           Style="{StaticResource SearchEntry}"
                           BackgroundColor="Transparent"
                           HeightRequest="44" />
                </Grid>
            </Border>
            <ContentView x:Name="TrailingHost" Grid.Column="1" VerticalOptions="Center" />
        </Grid>

        <ContentView x:Name="FiltersHost" />
    </VerticalStackLayout>

</ContentView>
